          <mxGeometry x="620" y="170" width="360" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p12-c" value="little_kernel&#xa;Python DSL -&gt; CUDA C++ / inline PTX&#xa;runtime nvcc compile&#xa;适合极细 PTX 控制实验&#xa;不走主 MLIR lowering" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="1120" y="170" width="360" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p12-d" value="与 EP 的关系&#xa;MegaKernel：把 attention / MoE / communication task 纳入统一 scheduler&#xa;AOT：把稳定 B200 kernel 固化为部署产物&#xa;little_kernel：验证 NCCL/SHMEM 之外的 PTX 级通信实验" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="300" y="470" width="1000" height="160" as="geometry" />
