  <diagram id="page02-programming-model" name="02 分布式编程模型">
    <mxGraphModel dx="1553" dy="999" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p2-title" value="分布式编程模型：MPMD + symmetric memory + signal + async-task" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=20;" parent="1" vertex="1">
          <mxGeometry x="80" y="40" width="1440" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p2-a" value="MPMD&#xa;每个 rank 执行同一 Python kernel 但基于 rank/local_rank 走不同分支&#xa;适合把通信 task 和 compute task 空间划分" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="80" y="170" width="320" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p2-b" value="Symmetric Memory&#xa;所有 rank 分配相同逻辑对象&#xa;symm_at(ptr, peer) 把本地地址映射到远端 rank 地址&#xa;是 one-sided put/get 的基础" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="460" y="170" width="320" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p2-c" value="Signal Exchange&#xa;producer 写数据后 notify 或 signal_op&#xa;consumer wait 直到 flag 到达&#xa;用 acquire/release 语义保证可见性" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="840" y="170" width="320" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p2-d" value="Async-task&#xa;通信、copy、reduction、GEMM 分配给不同 SM/stream/copy engine/NIC&#xa;目标是同一时间完成，避免 long tail" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="1220" y="170" width="300" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p2-e" value="Primitive 语义层&#xa;rank / num_ranks：查询 PE 信息&#xa;symm_at：远端 symmetric pointer&#xa;notify：远端信号更新&#xa;wait：等待信号并返回 token&#xa;consume_token：制造数据依赖，防止计算越过通信" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="180" y="420" width="560" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p2-f" value="为什么不用粗粒度 collective&#xa;collective 结束才返回，不能表达 tile 已经到达&#xa;signal 可以按 tile/rank/chunk 粒度释放数据&#xa;one-sided P2P 可以和计算顺序 swizzle 对齐" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="860" y="420" width="560" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p2-note" value="源码入口&#xa;python/triton_dist/language/distributed_ops.py&#xa;include/TritonDistributed/Dialect/Distributed/IR/DistributedOps.td&#xa;lib/Conversion/TritonDistributedToLLVM/NVIDIA/DistributedOpToLLVM.cpp&#xa;docs/primitives.md" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="895" y="740" width="490" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p2-edge1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" parent="1" source="p2-a" target="p2-b" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2-edge2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" parent="1" source="p2-b" target="p2-c" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2-edge3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" parent="1" source="p2-c" target="p2-d" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
