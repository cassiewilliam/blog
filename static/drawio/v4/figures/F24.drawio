        <mxCell id="v2" value="" style="rounded=0;fillColor=#fff;strokeColor=none;html=1;" vertex="1" parent="1"><mxGeometry x="0.0" y="0.0" width="1100.0" height="420.0" as="geometry"/></mxCell><mxCell id="v3" value="mHC 工程实现 · fused kernel + selective recompute + DualPipe overlap" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="233.0" y="6.84" width="634" height="22" as="geometry"/></mxCell><mxCell id="v4" value="" style="rounded=1;arcSize=5;fillColor=#eef3ff;strokeColor=#4a6fd3;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="30.0" y="56.0" width="510.0" height="154.0" as="geometry"/></mxCell><mxCell id="v5" value="① fused mhc_pre / mhc_post kernel" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="152.5" y="63.96" width="265" height="18" as="geometry"/></mxCell><mxCell id="v6" value="inputs  : x [T, n_hc=4, d=7168] bf16" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="90.3" width="245" height="15" as="geometry"/></mxCell><mxCell id="v7" value=": hc_fn [mix_hc=24, n_hc·d=28672] float32 · hc_scale [3] · hc_base [24]" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="108.3" width="484" height="15" as="geometry"/></mxCell><mxCell id="v8" value="stages  : RMSNorm(flatten) → dynamic A/B/C gen → Sinkhorn 20 iters → mix" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="126.3" width="491" height="15" as="geometry"/></mxCell><mxCell id="v9" value="outputs : layer_input [T, d], post_mix [T, n_hc, d], res_mix [T, n_hc, d]" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="144.3" width="497" height="15" as="geometry"/></mxCell><mxCell id="v10" value="• single kernel ⇒ no intermediate materialization" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a3a5c;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="166.3" width="334" height="15" as="geometry"/></mxCell><mxCell id="v11" value="• training &amp; inference share the same CUDA/TileLang kernel (byte-identical)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a3a5c;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="184.3" width="511" height="15" as="geometry"/></mxCell><mxCell id="v12" value="" style="rounded=1;arcSize=5;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="570.0" y="56.0" width="500.0" height="154.0" as="geometry"/></mxCell><mxCell id="v13" value="② Selective recompute (tensor-level checkpointing)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="618.5" y="63.96" width="403" height="18" as="geometry"/></mxCell><mxCell id="v14" value="recompute : inter-layer hidden state [T, d=7168]" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="90.3" width="327" height="15" as="geometry"/></mxCell><mxCell id="v15" value=": RMSNorm outputs [T, d]" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="108.3" width="163" height="15" as="geometry"/></mxCell><mxCell id="v16" value="retain    : wq/wkv GEMM outputs (compute-heavy)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="126.3" width="320" height="15" as="geometry"/></mxCell><mxCell id="v17" value=": compressor intermediates" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="144.3" width="177" height="15" as="geometry"/></mxCell><mxCell id="v18" value="activation memory: n_hc=4 inflates 4× if naive" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a3d1a;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="166.3" width="313" height="15" as="geometry"/></mxCell><mxCell id="v19" value="after selective recompute: extra footprint ≤ 10%" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a3d1a;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="184.3" width="327" height="15" as="geometry"/></mxCell><mxCell id="v20" value="" style="rounded=1;arcSize=5;fillColor=#fff4e0;strokeColor=#e0b300;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="30.0" y="224.0" width="1040.0" height="180.0" as="geometry"/></mxCell><mxCell id="v21" value="③ DualPipe 1F1B schedule tuned for mHC extra traffic" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="340.5" y="231.96" width="419" height="18" as="geometry"/></mxCell><mxCell id="v22" value="conventional 1F1B: fwd[i] → comm → bwd[i]  ·  mHC adds n_hc× residual traffic between pipeline stages" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="258.3" width="688" height="15" as="geometry"/></mxCell><mxCell id="v23" value="V4 change 1: some mHC ops executed concurrently with adjacent compute — hc_pre of stage i+1 overlaps with hc_post of i" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="278.3" width="804" height="15" as="geometry"/></mxCell><mxCell id="v24" value="V4 change 2: send buffers grouped by n_hc slab so a single NVLink packet carries multiple mHC channels" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="298.3" width="695" height="15" as="geometry"/></mxCell><mxCell id="v25" value="wall-time overhead of mHC in production pipeline: 6.7%" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#7a4e00;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="320.3" width="368" height="15" as="geometry"/></mxCell><mxCell id="v26" value="for reference: naive residual adds zero comm → mHC's 6.7% is the whole cost of going from R^d to R^(n_hc·d)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#7a4e00;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="342.3" width="729" height="15" as="geometry"/></mxCell><mxCell id="v27" value="see dedicated mHC paper (Xie et al., 2026) for engineering appendix" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#555;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="366.3" width="456" height="15" as="geometry"/></mxCell>
