        <mxCell id="dbo_overlap_3" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=none;opacity=30;" parent="1" vertex="1">
          <mxGeometry x="620" y="1460" width="280" height="150" as="geometry" />
        </mxCell>
        <mxCell id="dbo_gantt_legend" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;font color=&quot;#FFF9C4&quot;&gt;█&lt;/font&gt; = 通信与计算重叠区域 | &lt;font color=&quot;#FFCDD2&quot;&gt;█&lt;/font&gt; = ubatch 0 | &lt;font color=&quot;#BBDEFB&quot;&gt;█&lt;/font&gt; = ubatch 1&lt;br&gt;&lt;br&gt;&lt;b&gt;关键重叠:&lt;/b&gt;&lt;br&gt;• Dispatch(ub0) 与 Gate(ub1) 重叠 — ub1 的 Gate 计算隐藏了 ub0 的 Dispatch 通信延迟&lt;br&gt;• Dispatch(ub1) 与 DeepGEMM(ub0) 重叠 — ub0 的 Expert 计算隐藏了 ub1 的 Dispatch&lt;br&gt;• Combine(ub0) 与 DeepGEMM(ub1) 部分重叠 + Shared Expert(ub0) 与 Combine(ub1) 重叠&lt;br&gt;&lt;br&gt;&lt;b&gt;vs 无 DBO (串行):&lt;/b&gt;&lt;br&gt;Gate → Dispatch → &lt;font color=&quot;#999&quot;&gt;等待&lt;/font&gt; → DeepGEMM → Combine → &lt;font color=&quot;#999&quot;&gt;等待&lt;/font&gt; → Shared Expert → Residual&lt;br&gt;&lt;font color=&quot;#C62828&quot;&gt;通信等待时间 = Dispatch + Combine = ~14.1 ms (纯浪费)&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;使用 DBO:&lt;/b&gt; 隐藏 Dispatch ~4.7ms (完全) + Combine ~9.4ms (部分) → &lt;font color=&quot;#2E7D32&quot;&gt;&lt;b&gt;节省 ~30-50% 通信延迟&lt;/b&gt;&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;" parent="1" vertex="1">
          <mxGeometry x="50" y="1620" width="1100" height="130" as="geometry" />
        </mxCell>
        <mxCell id="dbo_switch_title" value="&lt;font style=&quot;font-size:16px&quot;&gt;&lt;b&gt;Stream 切换协议 (CUDA Event 同步)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="300" y="1775" width="600" height="25" as="geometry" />
        </mxCell>
        <mxCell id="dbo_switch_table" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#263238;color:#fff&quot;&gt;&lt;th&gt;方法&lt;/th&gt;&lt;th&gt;步骤&lt;/th&gt;&lt;th&gt;用途&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;switch_to_comm()&lt;/b&gt;&lt;/td&gt;&lt;td&gt;torch.cuda.set_stream(comm_stream)&lt;/td&gt;&lt;td&gt;仅切换 PyTorch 当前 stream, 无同步&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;&lt;b&gt;switch_to_compute()&lt;/b&gt;&lt;/td&gt;&lt;td&gt;torch.cuda.set_stream(compute_stream)&lt;/td&gt;&lt;td&gt;仅切换, 无同步&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;switch_to_comm_sync()&lt;/b&gt;&lt;/td&gt;&lt;td&gt;① record compute_done on compute_stream&lt;br&gt;② set_stream(comm_stream)&lt;br&gt;③ comm_stream.wait_event(compute_done)&lt;/td&gt;&lt;td&gt;Comm 等待 Compute 完成后再开始&lt;br&gt;(确保 dispatch/combine 看到计算结果)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;&lt;b&gt;switch_to_compute_sync()&lt;/b&gt;&lt;/td&gt;&lt;td&gt;① record comm_done on comm_stream&lt;br&gt;② set_stream(compute_stream)&lt;br&gt;③ compute_stream.wait_event(comm_done)&lt;/td&gt;&lt;td&gt;Compute 等待 Comm 完成后再开始&lt;br&gt;(确保 expert compute 看到 dispatch 数据)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;yield_and_switch_&lt;br&gt;from_compute_to_comm()&lt;/b&gt;&lt;/td&gt;&lt;td&gt;① record compute_done&lt;br&gt;② &lt;font color=&quot;#E65100&quot;&gt;&lt;b&gt;cpu_signal → cpu_wait&lt;/b&gt;&lt;/font&gt; (让出 CPU)&lt;br&gt;③ set_stream(comm_stream)&lt;br&gt;④ comm_stream.wait_event(compute_done)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#E65100&quot;&gt;&lt;b&gt;核心: Dispatch/Combine 前调用&lt;/b&gt;&lt;/font&gt;&lt;br&gt;让另一 ubatch 线程用 CPU&lt;br&gt;同时保证 GPU 依赖正确&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;&lt;b&gt;yield_and_switch_&lt;br&gt;from_comm_to_compute()&lt;/b&gt;&lt;/td&gt;&lt;td&gt;① record comm_done&lt;br&gt;② &lt;font color=&quot;#E65100&quot;&gt;&lt;b&gt;cpu_signal → cpu_wait&lt;/b&gt;&lt;/font&gt;&lt;br&gt;③ set_stream(compute_stream)&lt;br&gt;④ compute_stream.wait_event(comm_done)&lt;/td&gt;&lt;td&gt;Combine async receiver 中的 copy_ 后&lt;br&gt;切换回 compute&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;yield_()&lt;/b&gt;&lt;/td&gt;&lt;td&gt;① save current_stream&lt;br&gt;② cpu_signal → cpu_wait&lt;br&gt;③ restore current_stream&lt;/td&gt;&lt;td&gt;纯 CPU 让步, 不改变 stream&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#424242;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="50" y="1810" width="1100" height="340" as="geometry" />
        </mxCell>
        <mxCell id="dbo_handle_title" value="&lt;font style=&quot;font-size:16px&quot;&gt;&lt;b&gt;Handle 生命周期 + 数据隔离&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="300" y="2175" width="600" height="25" as="geometry" />
        </mxCell>
        <mxCell id="dbo_handle_detail" value="&lt;font style=&quot;font-size:11px&quot;&gt;&lt;b&gt;DeepEP Handle 隔离&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;问题:&lt;/b&gt; buffer.dispatch() 返回 handle, buffer.combine() 需要同一 handle。&lt;br&gt;两个 ubatch 线程共享同一个 DeepEPHTPrepareAndFinalize 实例, 单 handle 会竞争。&lt;br&gt;&lt;br&gt;&lt;b&gt;解决:&lt;/b&gt; self.handles = [None, None] — 按 ubatch id 索引&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;3&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#263238;color:#fff&quot;&gt;&lt;th&gt;时刻&lt;/th&gt;&lt;th&gt;操作&lt;/th&gt;&lt;th&gt;handles[0]&lt;/th&gt;&lt;th&gt;handles[1]&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;初始&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;None&lt;/td&gt;&lt;td&gt;None&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFEBEE&quot;&gt;&lt;td&gt;T2b&lt;/td&gt;&lt;td&gt;dispatch(ub0) → handle_0&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;handle_0&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;None&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;td&gt;T3&lt;/td&gt;&lt;td&gt;dispatch(ub1) → handle_1&lt;/td&gt;&lt;td&gt;handle_0&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#1565C0&quot;&gt;&lt;b&gt;handle_1&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFEBEE&quot;&gt;&lt;td&gt;T4a&lt;/td&gt;&lt;td&gt;combine(ub0, handles[0])&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;consumed&lt;/font&gt;&lt;/td&gt;&lt;td&gt;handle_1&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;td&gt;T4b&lt;/td&gt;&lt;td&gt;combine(ub1, handles[1])&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#1565C0&quot;&gt;consumed&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#424242;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="50" y="2210" width="530" height="280" as="geometry" />
        </mxCell>
        <mxCell id="dbo_data_isolation" value="&lt;font style=&quot;font-size:11px&quot;&gt;&lt;b&gt;数据缓冲区隔离 (per-ubatch)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;3&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#263238;color:#fff&quot;&gt;&lt;th&gt;数据结构&lt;/th&gt;&lt;th&gt;Shape (DBO 开启)&lt;/th&gt;&lt;th&gt;索引方式&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;batched_hidden_states&lt;/b&gt;&lt;/td&gt;&lt;td&gt;(2, max_tokens, 7168)&lt;/td&gt;&lt;td&gt;[dbo_current_ubatch_id()]&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;&lt;b&gt;batched_router_logits&lt;/b&gt;&lt;/td&gt;&lt;td&gt;(2, max_tokens, 256)&lt;/td&gt;&lt;td&gt;[dbo_current_ubatch_id()]&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;workspace&lt;/b&gt;&lt;/td&gt;&lt;td&gt;WorkspaceManager._current[2]&lt;/td&gt;&lt;td&gt;[dbo_current_ubatch_id()]&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;&lt;b&gt;handles&lt;/b&gt;&lt;/td&gt;&lt;td&gt;[handle_0, handle_1]&lt;/td&gt;&lt;td&gt;[dbo_current_ubatch_id()]&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;b&gt;线程标识:&lt;/b&gt;&lt;br&gt;_THREAD_ID_TO_CONTEXT[threading.get_ident()] = ctx.id&lt;br&gt;dbo_current_ubatch_id() 返回 0 或 1&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;所有 per-ubatch 数据通过 ubatch_id 索引,&lt;br&gt;两线程不会写入对方的缓冲区。&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#424242;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="600" y="2210" width="550" height="280" as="geometry" />
        </mxCell>
        <mxCell id="dbo_dispatch_title" value="&lt;font style=&quot;font-size:16px&quot;&gt;&lt;b&gt;Dispatch 阶段 DBO 调用序列 (deepep_ht_prepare_finalize.py)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="200" y="2520" width="800" height="25" as="geometry" />
        </mxCell>
        <mxCell id="dbo_dispatch_seq" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#C62828;color:#fff&quot;&gt;&lt;th&gt;#&lt;/th&gt;&lt;th&gt;调用&lt;/th&gt;&lt;th&gt;Stream 状态&lt;/th&gt;&lt;th&gt;说明&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;&lt;b&gt;dbo_yield_and_switch_from_compute_to_comm()&lt;/b&gt;&lt;/td&gt;&lt;td&gt;compute → &lt;font color=&quot;#1565C0&quot;&gt;&lt;b&gt;comm&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;让出 CPU 给另一 ubatch, GPU 切换到 comm stream&lt;br&gt;comm_stream.wait_event(compute_done) 保证数据可见&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;2&lt;/td&gt;&lt;td&gt;previous_event = &lt;b&gt;dbo_get_previous_event&lt;/b&gt;(buffer.capture)&lt;/td&gt;&lt;td&gt;(临时切到 compute 执行 capture)&lt;/td&gt;&lt;td&gt;在 compute_stream 上录制依赖 event, 传给 DeepEP&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;3&lt;/td&gt;&lt;td&gt;buffer.&lt;b&gt;get_dispatch_layout&lt;/b&gt;(previous_event=...)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#1565C0&quot;&gt;comm&lt;/font&gt;&lt;/td&gt;&lt;td&gt;计算路由分布 (send_count, recv_count 等)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;4&lt;/td&gt;&lt;td&gt;buffer.&lt;b&gt;dispatch&lt;/b&gt;(async_finish=&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;False when DBO&lt;/b&gt;&lt;/font&gt;)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#1565C0&quot;&gt;comm&lt;/font&gt;&lt;/td&gt;&lt;td&gt;提交 All2All 到 comm_stream (20 SMs 执行)&lt;br&gt;DBO 时 async_finish=False, 由 DBO 自己管理异步&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;5&lt;/td&gt;&lt;td&gt;self.handles[dbo_current_ubatch_id()] = handle&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;保存 handle 到对应 ubatch 槽位&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;6&lt;/td&gt;&lt;td&gt;&lt;b&gt;dbo_switch_to_compute_sync()&lt;/b&gt;&lt;/td&gt;&lt;td&gt;comm → &lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;compute&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;切回 compute, compute 等待 comm_done&lt;br&gt;确保 dispatch 数据已可见后才开始 expert compute&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;7&lt;/td&gt;&lt;td&gt;return _receiver (closure)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;compute&lt;/font&gt;&lt;/td&gt;&lt;td&gt;_receiver 在 compute stream 上执行:&lt;br&gt;fix expert_topk_ids, build ExpertTokensMetadata&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="50" y="2555" width="1100" height="260" as="geometry" />
        </mxCell>
        <mxCell id="dbo_combine_title" value="&lt;font style=&quot;font-size:16px&quot;&gt;&lt;b&gt;Combine 阶段 DBO 调用序列 (_finalize)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="200" y="2840" width="800" height="25" as="geometry" />
        </mxCell>
        <mxCell id="dbo_combine_seq" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#1565C0;color:#fff&quot;&gt;&lt;th&gt;#&lt;/th&gt;&lt;th&gt;调用&lt;/th&gt;&lt;th&gt;Stream 状态&lt;/th&gt;&lt;th&gt;说明&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;handle = self.handles[dbo_current_ubatch_id()]&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;compute&lt;/font&gt;&lt;/td&gt;&lt;td&gt;取出 dispatch 阶段保存的 handle&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;2&lt;/td&gt;&lt;td&gt;(可选) TopKWeightAndReduce on fused_expert_output&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;compute&lt;/font&gt;&lt;/td&gt;&lt;td&gt;Expert 输出加权归约 (DeepGEMM 模式通常 NoOP)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;3&lt;/td&gt;&lt;td&gt;&lt;b&gt;dbo_yield_and_switch_from_compute_to_comm()&lt;/b&gt;&lt;/td&gt;&lt;td&gt;compute → &lt;font color=&quot;#1565C0&quot;&gt;&lt;b&gt;comm&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;让出 CPU + 切换 stream + 等待 compute 完成&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;4&lt;/td&gt;&lt;td&gt;previous_event = dbo_get_previous_event(buffer.capture)&lt;/td&gt;&lt;td&gt;(临时 compute)&lt;/td&gt;&lt;td&gt;录制依赖 event&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;5&lt;/td&gt;&lt;td&gt;buffer.&lt;b&gt;combine&lt;/b&gt;(handle, async_finish=&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;False when DBO&lt;/b&gt;&lt;/font&gt;)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#1565C0&quot;&gt;comm&lt;/font&gt;&lt;/td&gt;&lt;td&gt;提交反向 All2All 到 comm_stream&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;6&lt;/td&gt;&lt;td&gt;&lt;b&gt;dbo_switch_to_compute()&lt;/b&gt; (无 sync)&lt;/td&gt;&lt;td&gt;comm → &lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;compute&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;切回 compute, 不等待 (combine 可能仍在执行)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;7&lt;/td&gt;&lt;td&gt;return _receiver (async)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;compute&lt;/font&gt;&lt;/td&gt;&lt;td&gt;_receiver 内部:&lt;br&gt;① event.current_stream_wait() (等 combine 完成)&lt;br&gt;② &lt;b&gt;dbo_switch_to_comm()&lt;/b&gt;&lt;br&gt;③ output.copy_(combined_x, non_blocking=True)&lt;br&gt;④ &lt;b&gt;dbo_yield_and_switch_from_comm_to_compute()&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="50" y="2875" width="1100" height="260" as="geometry" />
        </mxCell>
        <mxCell id="dbo_flow_title" value="&lt;font style=&quot;font-size:16px&quot;&gt;&lt;b&gt;Stream 状态流转图 (单 ubatch 视角)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" parent="1" vertex="1">
