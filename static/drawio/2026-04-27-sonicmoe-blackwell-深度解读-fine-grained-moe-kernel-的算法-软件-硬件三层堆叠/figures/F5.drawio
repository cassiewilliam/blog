<mxfile host="embed.diagrams.net"><diagram name="figure" id="figure"><mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1180" pageHeight="560" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="title" value="SonicMoE optimization map: where each cost disappears" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=28;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="18" width="1080" height="40" as="geometry" /></mxCell><mxCell id="sub" value="Read left to right as the path from routing metadata to HBM output." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=13;fontColor=#667085;" vertex="1" parent="1"><mxGeometry x="40" y="58" width="900" height="24" as="geometry" /></mxCell><mxCell id="s1" value="&lt;b&gt;Router&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;TopK&lt;sub&gt;K&lt;/sub&gt;(S&lt;sub&gt;t&lt;/sub&gt;)&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef7ff;strokeColor=#4a6fd3;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="55" y="125" width="175" height="82" as="geometry" /></mxCell><mxCell id="c1" value="&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;t&lt;sub&gt;router&lt;/sub&gt;&lt;/i&gt;&lt;/font&gt;&lt;br&gt;↓" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#d0d7de;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="67" y="270" width="151" height="76" as="geometry" /></mxCell><mxCell id="d1" edge="1" parent="1" source="s1" target="c1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="s2" value="&lt;b&gt;Load&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;X&lt;sub&gt;e&lt;/sub&gt;=G(X,π[:,e])&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="275" y="125" width="175" height="82" as="geometry" /></mxCell><mxCell id="c2" value="&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;¬X&lt;sub&gt;e&lt;/sub&gt;∈ℝ&lt;sub&gt;TK×d&lt;/sub&gt;&lt;/i&gt;&lt;/font&gt;&lt;br&gt;no materialize" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#d0d7de;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="287" y="270" width="151" height="76" as="geometry" /></mxCell><mxCell id="d2" edge="1" parent="1" source="s2" target="c2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e2" edge="1" parent="1" source="s1" target="s2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="s3" value="&lt;b&gt;GEMM&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;T&lt;sub&gt;e&lt;/sub&gt; mod M&lt;sub&gt;tile&lt;/sub&gt;&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e7;strokeColor=#e0b300;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="495" y="125" width="175" height="82" as="geometry" /></mxCell><mxCell id="c3" value="&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;R&lt;sub&gt;e&lt;/sub&gt;=T&lt;sub&gt;e&lt;/sub&gt; mod M&lt;sub&gt;tile&lt;/sub&gt;&lt;/i&gt;&lt;/font&gt;&lt;br&gt;TR reduces tail" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#d0d7de;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="507" y="270" width="151" height="76" as="geometry" /></mxCell><mxCell id="d3" edge="1" parent="1" source="s3" target="c3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e3" edge="1" parent="1" source="s2" target="s3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="s4" value="&lt;b&gt;Epilogue&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;dS=⟨dA′,A⟩&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f7eff8;strokeColor=#a33ea1;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="715" y="125" width="175" height="82" as="geometry" /></mxCell><mxCell id="c4" value="&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;MMA ∥ IO&lt;sub&gt;epi&lt;/sub&gt;&lt;/i&gt;&lt;/font&gt;&lt;br&gt;hide stalls" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#d0d7de;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="727" y="270" width="151" height="76" as="geometry" /></mxCell><mxCell id="d4" edge="1" parent="1" source="s4" target="c4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e4" edge="1" parent="1" source="s3" target="s4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="s5" value="&lt;b&gt;Output&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;O&lt;sub&gt;t&lt;/sub&gt;=Σ&lt;sub&gt;e&lt;/sub&gt;πSY&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="935" y="125" width="175" height="82" as="geometry" /></mxCell><mxCell id="c5" value="&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;Y&lt;sub&gt;expert&lt;/sub&gt; → O&lt;/i&gt;&lt;/font&gt;&lt;br&gt;no scatter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#d0d7de;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="947" y="270" width="151" height="76" as="geometry" /></mxCell><mxCell id="d5" edge="1" parent="1" source="s5" target="c5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e5" edge="1" parent="1" source="s4" target="s5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="rule" value="The contribution is the product of small decisions across the whole MoE path, not a single faster GEMM." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f7f8fa;strokeColor=#d0d7de;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="140" y="420" width="900" height="54" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>
