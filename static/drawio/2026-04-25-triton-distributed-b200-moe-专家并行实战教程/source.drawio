        <mxCell id="p12-title" value="MegaKernel / AOT / little_kernel：与 EP 接入相关的旁路系统" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=20;" parent="1" vertex="1">
          <mxGeometry x="80" y="40" width="1440" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p12-a" value="Mega Triton Kernel&#xa;Graph -&gt; Task -&gt; Scheduler&#xa;work queue + scoreboard&#xa;generated MEGA_TRITON_KERNEL&#xa;适合 decode pipeline 级融合" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="120" y="170" width="360" height="170" as="geometry" />
        </mxCell>
