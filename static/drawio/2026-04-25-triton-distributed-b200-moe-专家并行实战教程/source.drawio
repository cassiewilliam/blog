  <diagram id="page04-primitive-backend" name="04 Primitive 后端映射">
    <mxGraphModel dx="1242" dy="799" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p4-title" value="Primitive 到后端通信库映射：SHMEM 模型与 NCCL Device API 对照" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=20;" parent="1" vertex="1">
