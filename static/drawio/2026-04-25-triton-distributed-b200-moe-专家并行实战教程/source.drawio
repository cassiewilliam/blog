        <mxCell id="p4-d" value="NCCL Device API 对照&#xa;LSA：P2P load/store window&#xa;Multimem：NVLink SHARP multicast/reduce&#xa;GIN：GPU-initiated networking&#xa;device communicator + symmetric window" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=15;" parent="1" vertex="1">
