ace model: KV depends only on current pos" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a3a5c;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="-13.5" y="288.3" width="347" height="15" as="geometry"/></mxCell><mxCell id="v19" value="does not fit PagedAttention's uniform paging," style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a3a5c;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="7.0" y="308.3" width="306" height="15" as="geometry"/></mxCell><mxCell id="v20" value="dedicated pre-allocated pool avoids fragmentation" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a3a5c;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="-7.0" y="326.3" width="334" height="15" as="geometry"/></mxCell><mxCell id="v21" value="" style="rounded=1;arcSize=5;fillColor=#f6f8fa;strokeColor=#555;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="320.0" y="54.0" width="640.0" height="326.0" as="geometry"/></mxCell><mxCell id="v22" value="Classical Paged KV Cache" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="543.5" y="59.96" width="193" height="18" as="geometry"/></mxCell><mxCell id="v23" value="each block covers lcm(m, m') = 128 original tokens → k1 = 32 CSA, k2 = 1 HCA" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#555;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="393.0" y="81.08" width="494" height="14" as="geometry"/></mxCell><mxCell id="v24" value="" style="rounded=0;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="340.0" y="108.0" width="140.0" height="80.0" as="geometry"/></mxCell><mxCell id="v25" value="Block 0" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap