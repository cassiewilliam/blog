as="geometry"/></mxCell><mxCell id="v48" value="• block_size is a multiple of lcm(m, m') for kernel alignment" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#555;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="360.0" y="323.08" width="397" height="14" as="geometry"/></mxCell><mxCell id="v49" value="• PagedAttention only for classical cache; SWA+tail lives in the state pool" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#555;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="360.0" y="339.08" width="488" height="14" as="geometry"/></mxCell>
