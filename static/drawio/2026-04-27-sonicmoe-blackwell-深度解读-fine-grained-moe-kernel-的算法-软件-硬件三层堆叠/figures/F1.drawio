<mxfile host="embed.diagrams.net"><diagram name="figure" id="figure"><mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1160" pageHeight="520" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="title" value="Standard MoE: the hidden cost is materialized routing tensors" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=28;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="18" width="1080" height="40" as="geometry" /></mxCell><mxCell id="sub" value="The math is simple; the expensive part is carrying gathered/scattered activations through HBM." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=13;fontColor=#667085;" vertex="1" parent="1"><mxGeometry x="40" y="58" width="1000" height="24" as="geometry" /></mxCell><mxCell id="lane1" value="Forward" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=14;fontColor=#667085;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="55" y="105" width="180" height="24" as="geometry" /></mxCell><mxCell id="f1" value="&lt;b&gt;Gather&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;X&lt;sub&gt;e&lt;/sub&gt; = G(X,π)&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e7;strokeColor=#e0b300;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="110" y="145" width="150" height="78" as="geometry" /></mxCell><mxCell id="f2" value="&lt;b&gt;Up + act&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;H&lt;sub&gt;e&lt;/sub&gt; → A&lt;sub&gt;e&lt;/sub&gt;&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e7;strokeColor=#e0b300;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="285" y="145" width="150" height="78" as="geometry" /></mxCell><mxCell id="ef2" edge="1" parent="1" source="f1" target="f2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="f3" value="&lt;b&gt;Down&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;Y&lt;sub&gt;e&lt;/sub&gt; = A&lt;sub&gt;e&lt;/sub&gt;W&lt;sub&gt;2,e&lt;/sub&gt;&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e7;strokeColor=#e0b300;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="470" y="145" width="150" height="78" as="geometry" /></mxCell><mxCell id="ef3" edge="1" parent="1" source="f2" target="f3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="f4" value="&lt;b&gt;Scatter&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;Y → Y&lt;sub&gt;dense&lt;/sub&gt;&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e7;strokeColor=#e0b300;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="650" y="145" width="150" height="78" as="geometry" /></mxCell><mxCell id="ef4" edge="1" parent="1" source="f3" target="f4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="f5" value="&lt;b&gt;Aggregate&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;O&lt;sub&gt;t&lt;/sub&gt; = Σ&lt;sub&gt;e&lt;/sub&gt;π&lt;sub&gt;t,e&lt;/sub&gt;S&lt;sub&gt;t,e&lt;/sub&gt;Y&lt;sub&gt;e,t&lt;/sub&gt;&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e7;strokeColor=#e0b300;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="840" y="145" width="195" height="78" as="geometry" /></mxCell><mxCell id="ef5" edge="1" parent="1" source="f4" target="f5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="lane2" value="Backward needs cached intermediates" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=14;fontColor=#667085;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="55" y="285" width="300" height="24" as="geometry" /></mxCell><mxCell id="b1" value="&lt;b&gt;Activation grad&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;dY = S ⊙ dO&lt;/i&gt;&lt;/font&gt;&lt;br&gt;dY ∈ ℝ&lt;sub&gt;TK×d&lt;/sub&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="120" y="330" width="190" height="86" as="geometry" /></mxCell><mxCell id="b2" value="&lt;b&gt;Weight grad&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;dW&lt;sub&gt;1&lt;/sub&gt; = X&lt;sub&gt;e&lt;/sub&gt;&lt;sup&gt;T&lt;/sup&gt;dH&lt;sub&gt;e&lt;/sub&gt;&lt;/i&gt;&lt;/font&gt;&lt;br&gt;X&lt;sub&gt;e&lt;/sub&gt; ∈ ℝ&lt;sub&gt;TK×d&lt;/sub&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="375" y="330" width="190" height="86" as="geometry" /></mxCell><mxCell id="b3" value="&lt;b&gt;Router grad&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;dS = ⟨dO,Y⟩&lt;/i&gt;&lt;/font&gt;&lt;br&gt;Y ∈ ℝ&lt;sub&gt;TK×d&lt;/sub&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="630" y="330" width="205" height="86" as="geometry" /></mxCell><mxCell id="b4" value="&lt;b&gt;Peak cache&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;{X&lt;sub&gt;e&lt;/sub&gt;,Y,dY,dO&lt;sub&gt;e&lt;/sub&gt;}&lt;/i&gt;&lt;/font&gt;&lt;br&gt;∼ O(TKd)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="910" y="330" width="190" height="86" as="geometry" /></mxCell><mxCell id="eb12" edge="1" parent="1" source="b1" target="b2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="eb23" edge="1" parent="1" source="b2" target="b3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="eb34" edge="1" parent="1" source="b3" target="b4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="d1" edge="1" parent="1" source="f1" target="b1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;dashed=1;strokeColor=#667085;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="d2" edge="1" parent="1" source="f2" target="b2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;dashed=1;strokeColor=#667085;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="d3" edge="1" parent="1" source="f4" target="b3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;dashed=1;strokeColor=#667085;"><mxGeometry relative="1" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>
