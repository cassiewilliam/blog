<mxfile host="app.diagrams.net" agent="svg2drawio" version="22.0.0">
  <diagram id="conv" name="Page-1">
    <mxGraphModel dx="1100" dy="360" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="360" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="v2" value="" style="rounded=0;fillColor=#fff;strokeColor=none;html=1;" vertex="1" parent="1"><mxGeometry x="0.0" y="0.0" width="1100.0" height="360.0" as="geometry"/></mxCell><mxCell id="v3" value="Preemptible rollout · token-granular WAL correctness (no length bias)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="208.0" y="6.84" width="684" height="22" as="geometry"/></mxCell><mxCell id="v4" value="" style="rounded=1;arcSize=5;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="30.0" y="56.0" width="510.0" height="140.0" as="geometry"/></mxCell><mxCell id="v5" value="Naive: regenerate-from-scratch on preemption" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="108.0" y="63.96" width="354" height="18" as="geometry"/></mxCell><mxCell id="v6" value="• preempt → lose generated tokens + KV" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="90.3" width="259" height="15" as="geometry"/></mxCell><mxCell id="v7" value="• on resume → start over from prefill" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="108.3" width="252" height="15" as="geometry"/></mxCell><mxCell id="v8" value="SUBTLE BUG — length bias:" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#b85450;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="132.3" width="170" height="15" as="geometry"/></mxCell><mxCell id="v9" value="shorter responses more likely to finish before preemption" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#b85450;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="150.3" width="388" height="15" as="geometry"/></mxCell><mxCell id="v10" value="→ surviving distribution skews short → model learns to output shorter sequences" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#b85450;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="168.3" width="538" height="15" as="geometry"/></mxCell><mxCell id="v11" value="" style="rounded=1;arcSize=5;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="570.0" y="56.0" width="500.0" height="140.0" as="geometry"/></mxCell><mxCell id="v12" value="V4: token-granular write-ahead log" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="683.0" y="63.96" width="274" height="18" as="geometry"/></mxCell><mxCell id="v13" value="• per-request WAL: append every generated token immediately" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="90.3" width="402" height="15" as="geometry"/></mxCell><mxCell id="v14" value="• preempt → pause engine → save KV cache to persistent storage" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="108.3" width="422" height="15" as="geometry"/></mxCell><mxCell id="v15" value="• resume → load KV, continue from last WAL token" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="126.3" width="327" height="15" as="geometry"/></mxCell><mxCell id="v16" value="• on fatal HW failure: rerun prefill using WAL tokens, rebuild KV" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="146.3" width="443" height="15" as="geometry"/></mxCell><mxCell id="v17" value="→ preserves full sequence distribution" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a3d1a;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="168.3" width="259" height="15" as="geometry"/></mxCell><mxCell id="v18" value="" style="rounded=1;arcSize=5;fillColor=#eef3ff;strokeColor=#4a6fd3;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="30.0" y="216.0" width="1040.0" height="130.0" as="geometry"/></mxCell><mxCell id="v19" value="Alternative if kernels are batch-invariant (what V4 has)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="324.5" y="223.96" width="451" height="18" as="geometry"/></mxCell><mxCell id="v20" value="• regenerate from scratch BUT use fixed RNG seed for sampler → deterministic replay → same distribution, no length bias" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="250.3" width="811" height="15" as="geometry"/></mxCell><mxCell id="v21" value="• downside: repays entire decode cost (typically 10×–100× the WAL cost)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="268.3" width="484" height="15" as="geometry"/></mxCell><mxCell id="v22" value="• so V4 prefers WAL for speed, but bit-invariance ensures it can FALL BACK to deterministic replay if WAL is lost" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="288.3" width="770" height="15" as="geometry"/></mxCell><mxCell id="v23" value="→ dual safety net: fast path WAL + correctness floor via bit-invariant kernels" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#4a6fd3;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="314.3" width="531" height="15" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
