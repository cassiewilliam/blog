  <diagram id="page01-learning-path" name="01 学习路径总览">
    <mxGraphModel dx="1774" dy="1141" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p1-title" value="Triton-distributed B200 / NCCL EP 学习路径&#xa;从普通 Triton kernel 到 device-side communication + tile-level overlap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=20;" parent="1" vertex="1">
          <mxGeometry x="80" y="40" width="1440" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p1-a" value="传统路径&#xa;PyTorch + NCCL collective + GEMM&#xa;host launch 粒度粗&#xa;collective 完成后再计算" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="80" y="170" width="300" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p1-b" value="问题&#xa;通信、访存、计算分层优化&#xa;tile 数据已到但 kernel 不知道&#xa;无法细粒度隐藏信号和网络尾延迟" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="440" y="170" width="320" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p1-c" value="Triton-distributed 路径&#xa;one-sided communication&#xa;symmetric memory + signal&#xa;tile-level wait/compute&#xa;Python 写通信计算融合 kernel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="820" y="170" width="320" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p1-d" value="B200 / EP 目标&#xa;HGX B200 x8 单机验证&#xa;多节点 IB/RDMA 扩展&#xa;接入 NCCL Device API / NCCL EP 风格 dispatch/combine" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="1200" y="170" width="320" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p1-e" value="递进教程结构&#xa;1 概念模型&#xa;2 编译器栈&#xa;3 runtime 生命周期&#xa;4 overlapping kernel 模式&#xa;5 AG+GEMM / GEMM+RS&#xa;6 EP A2A / NCCL EP 接入&#xa;7 B200 验证与调优" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="320" y="390" width="960" height="230" as="geometry" />
