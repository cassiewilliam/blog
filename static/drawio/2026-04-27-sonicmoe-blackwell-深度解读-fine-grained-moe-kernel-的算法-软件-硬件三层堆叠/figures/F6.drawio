        </mxCell>
        <mxCell id="topk" value="&lt;b&gt;Top-K kernel&lt;/b&gt;&lt;br&gt;&lt;br&gt;same token-choice" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1">
