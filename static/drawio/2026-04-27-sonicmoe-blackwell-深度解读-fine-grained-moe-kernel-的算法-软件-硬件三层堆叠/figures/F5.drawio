        <mxCell id="d_10" edge="1" parent="1" source="d_5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;endArrow=block;html=1;rounded=1;" target="d_6">
          <mxGeometry relative="1" as="geometry" />
