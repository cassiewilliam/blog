  <diagram id="moe-full-flow" name="2. MoE Prefill 推理全流程">
    <mxGraphModel dx="1242" dy="1199" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1600" pageHeight="2800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t2" value="&lt;font style=&quot;font-size:22px&quot;&gt;&lt;b&gt;vLLM MoE Prefill 推理全流程&lt;/b&gt;&lt;/font&gt;&lt;br&gt;单个DecoderLayer内的完整调用链 (GPU 0视角)" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="250" y="-50" width="550" height="50" as="geometry" />
        </mxCell>
        <mxCell id="f_engine" value="&lt;b&gt;DPEngineCoreProc&lt;/b&gt;&lt;br&gt;Scheduler.schedule() → SchedulerOutput" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="300" y="20" width="400" height="45" as="geometry" />
        </mxCell>
        <mxCell id="f_e1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_engine" target="f_worker" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_worker" value="&lt;b&gt;Worker.execute_model()&lt;/b&gt;&lt;br&gt;→ ModelRunner.execute_model()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="300" y="90" width="400" height="45" as="geometry" />
        </mxCell>
        <mxCell id="f_w1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_worker" target="f_dp_sync" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_dp_sync" value="&lt;b&gt;DP Sync (All-Reduce)&lt;/b&gt;&lt;br&gt;交换各rank的batch token数&lt;br&gt;&lt;font color=&quot;#0000CC&quot;&gt;输出: num_tokens_across_dp = [4096, 3072, 2048, 3500]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="280" y="160" width="440" height="55" as="geometry" />
        </mxCell>
        <mxCell id="f_ds1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_dp_sync" target="f_embed" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_embed" value="&lt;b&gt;Embedding&lt;/b&gt;&lt;br&gt;input_ids → hidden_states (4096, 7168) BF16" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="300" y="240" width="400" height="40" as="geometry" />
        </mxCell>
        <mxCell id="f_em1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_embed" target="f_layernorm1" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="decoder_layer_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;strokeWidth=2;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="100" y="295" width="850" height="1830" as="geometry" />
        </mxCell>
        <mxCell id="decoder_label" value="&lt;font style=&quot;font-size:14px&quot;&gt;&lt;b&gt;DecoderLayer × N&lt;/b&gt; (每层重复)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="110" y="298" width="300" height="25" as="geometry" />
        </mxCell>
        <mxCell id="f_layernorm1" value="&lt;b&gt;RMSNorm + Residual&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="350" y="330" width="300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="f_ln1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_layernorm1" target="f_attn" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_attn" value="&lt;b&gt;MLA Attention&lt;/b&gt; (Data Parallel — 无通信)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;输入: (4096, 7168) → 输出: (4096, 7168)&lt;br&gt;4个GPU各自独立计算&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="300" y="380" width="400" height="60" as="geometry" />
        </mxCell>
        <mxCell id="f_at1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_attn" target="f_layernorm2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_layernorm2" value="&lt;b&gt;RMSNorm + Residual&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="350" y="460" width="300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="f_ln2" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_layernorm2" target="f_gate" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="moe_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;strokeWidth=3;" parent="1" vertex="1">
          <mxGeometry x="130" y="500" width="790" height="1600" as="geometry" />
        </mxCell>
        <mxCell id="moe_label" value="&lt;font style=&quot;font-size:16px&quot; color=&quot;#2E7D32&quot;&gt;&lt;b&gt;MoE Layer (FusedMoEModularKernel)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="140" y="505" width="400" height="25" as="geometry" />
        </mxCell>
        <mxCell id="f_gate" value="&lt;b&gt;Gate Linear + Router (TopK=8)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;输入: hidden_states (4096, 7168)&lt;br&gt;Gate: Linear(7168→256) → logits (4096, 256)&lt;br&gt;Router: softmax + bias + topk8&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;输出: topk_ids (4096, 8) int64, topk_weights (4096, 8) float32&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="230" y="540" width="540" height="90" as="geometry" />
        </mxCell>
        <mxCell id="f_g1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_gate" target="f_quant" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="phase1_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="155" y="645" width="740" height="450" as="geometry" />
        </mxCell>
        <mxCell id="phase1_label" value="&lt;font style=&quot;font-size:13px&quot; color=&quot;#0D47A1&quot;&gt;&lt;b&gt;阶段1: Prepare (FP8量化 + DeepEP Dispatch)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="165" y="650" width="500" height="22" as="geometry" />
        </mxCell>
        <mxCell id="f_quant" value="&lt;b&gt;FP8 Block Quantization&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;per_token_group_quant_fp8(block_shape=[128,128])&lt;br&gt;输入: (4096, 7168) BF16&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;输出: a1q (4096, 7168) FP8, a1q_scale (4096, 56) FP32&lt;/font&gt;&lt;br&gt;56 groups = 7168/128&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="230" y="680" width="540" height="85" as="geometry" />
        </mxCell>
        <mxCell id="f_q1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_quant" target="f_layout" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_layout" value="&lt;b&gt;DeepEP: get_dispatch_layout()&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;分析topk_ids确定每个rank的token传输计划&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;输出: num_tokens_per_rank (4,), num_tokens_per_rdma_rank (4,)&lt;br&gt;dispatch_expert_num_tokens (64,)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0050ef;fontColor=#ffffff;strokeColor=#001DBC;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="230" y="785" width="540" height="70" as="geometry" />
        </mxCell>
        <mxCell id="f_l1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_layout" target="f_dispatch" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_dispatch" value="&lt;b&gt;DeepEP: buffer.dispatch() — 4-way All2All&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;输入: a1q (4096,7168) FP8 + scales + topk_ids + topk_weights&lt;br&gt;NVLink路径 → GPU 1 (~25%, ~59MB)&lt;br&gt;RDMA路径 → GPU 2,3 (~50%, ~118MB) ★瓶颈★&lt;br&gt;本地保留 ~25%&lt;br&gt;&lt;font color=&quot;#FFFF00&quot;&gt;输出: dispatched_tokens (N_recv, 7168) FP8&lt;br&gt;expert_topk_ids (N_recv, topk) local space&lt;br&gt;expert_num_tokens [T0..T63] per expert&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0050ef;fontColor=#ffffff;strokeColor=#001DBC;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="185" y="875" width="680" height="120" as="geometry" />
        </mxCell>
        <mxCell id="f_d1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_dispatch" target="f_receiver" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_receiver" value="&lt;b&gt;_receiver(): ID修正 + Meta构建&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;topk_ids += rank_expert_offset (GPU0: +0)&lt;br&gt;构建ExpertTokensMetadata&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="280" y="1015" width="440" height="55" as="geometry" />
        </mxCell>
        <mxCell id="f_r1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_receiver" target="f_permute" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="phase2_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBE9E7;strokeColor=#BF360C;strokeWidth=2;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="155" y="1100" width="740" height="575" as="geometry" />
        </mxCell>
        <mxCell id="phase2_label" value="&lt;font style=&quot;font-size:13px&quot; color=&quot;#BF360C&quot;&gt;&lt;b&gt;阶段2: Expert Compute (DeepGEMM FP8 Grouped GEMM)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="165" y="1105" width="500" height="22" as="geometry" />
        </mxCell>
        <mxCell id="f_permute" value="&lt;b&gt;Step 1: Permute (ep_scatter Triton kernel)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;输入: dispatched_tokens (N_recv, 7168) FP8 + topk_ids&lt;br&gt;按expert分组排列, 每组对齐到128行&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;输出: a1q_perm (M_sum, 7168) FP8, expert_ids (M_sum,), inv_perm&lt;/font&gt;&lt;br&gt;M_sum = sum(ceil_128(T_i)) for 64 experts&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="200" y="1135" width="650" height="85" as="geometry" />
        </mxCell>
        <mxCell id="f_p1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_permute" target="f_gemm1" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_gemm1" value="&lt;b&gt;Step 2: GEMM1 — Gate+Up Projection&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;m_grouped_fp8_gemm_nt_contiguous()&lt;br&gt;A = a1q_perm (M_sum, K=7168) FP8&lt;br&gt;B = W1 (64, N=2I, K=7168) FP8&lt;br&gt;&lt;font color=&quot;#FFFF00&quot;&gt;C = mm1_out (M_sum, 2I) BF16&lt;/font&gt;&lt;br&gt;每个expert: C[rows_e] = A[rows_e] × W1[e]ᵀ&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="200" y="1240" width="650" height="95" as="geometry" />
        </mxCell>
        <mxCell id="f_gm1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_gemm1" target="f_act" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_act" value="&lt;b&gt;Step 3: SiLU Activation + FP8 Re-quantize&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;silu_mul_per_token_group_quant_fp8_colmajor()&lt;br&gt;输入: mm1_out (M_sum, 2I)&lt;br&gt;SiLU(mm1[:,:I]) × mm1[:,I:] → FP8&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;输出: a2q (M_sum, I) FP8, a2q_scale (M_sum, I/128) FP32&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="200" y="1355" width="650" height="80" as="geometry" />
        </mxCell>
        <mxCell id="f_ac1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_act" target="f_gemm2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_gemm2" value="&lt;b&gt;Step 4: GEMM2 — Down Projection&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;m_grouped_fp8_gemm_nt_contiguous()&lt;br&gt;A = a2q (M_sum, I) FP8&lt;br&gt;B = W2 (64, K=7168, I) FP8&lt;br&gt;&lt;font color=&quot;#FFFF00&quot;&gt;C = mm2_out (M_sum, 7168) BF16&lt;/font&gt;&lt;br&gt;每个expert: C[rows_e] = A[rows_e] × W2[e]ᵀ&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="200" y="1455" width="650" height="95" as="geometry" />
        </mxCell>
        <mxCell id="f_gm2" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_gemm2" target="f_unperm" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_unperm" value="&lt;b&gt;Step 5: Unpermute + Weighted Reduce (ep_gather)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;deepgemm_unpermute_and_reduce()&lt;br&gt;输入: mm2_out (M_sum, 7168), inv_perm, topk_weights&lt;br&gt;output[t] += topk_weights[t,k] × mm2_out[inv_perm[t,k]]&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;输出: expert_output (N_recv, 7168) BF16&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="200" y="1570" width="650" height="80" as="geometry" />
        </mxCell>
        <mxCell id="f_up1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_unperm" target="f_combine" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="phase3_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="155" y="1690" width="740" height="220" as="geometry" />
        </mxCell>
        <mxCell id="phase3_label" value="&lt;font style=&quot;font-size:13px&quot; color=&quot;#0D47A1&quot;&gt;&lt;b&gt;阶段3: Finalize (DeepEP Combine + Shared Experts)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="165" y="1695" width="500" height="22" as="geometry" />
        </mxCell>
        <mxCell id="f_combine" value="&lt;b&gt;DeepEP: buffer.combine() — 4-way All2All&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;输入: expert_output (N_recv, 7168) BF16&lt;br&gt;NVLink路径 ← GPU 1 (~117MB)&lt;br&gt;RDMA路径 ← GPU 2,3 (~234MB) ★瓶颈★&lt;br&gt;&lt;font color=&quot;#FFFF00&quot;&gt;输出: combined_x (4096, 7168) BF16 — 还原到原始token顺序&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0050ef;fontColor=#ffffff;strokeColor=#001DBC;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="185" y="1725" width="440" height="95" as="geometry" />
        </mxCell>
        <mxCell id="f_shared" value="&lt;b&gt;Shared Expert MLP&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;(4096, 7168) → (4096, 7168)&lt;br&gt;与Combine并行执行&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="660" y="1740" width="210" height="65" as="geometry" />
        </mxCell>
        <mxCell id="f_parallel_label" value="&lt;font color=&quot;#4CAF50&quot; style=&quot;font-size:11px&quot;&gt;&lt;b&gt;⇆ 并行执行 ⇆&lt;/b&gt;&lt;br&gt;Comm Stream | Compute Stream&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="600" y="1825" width="200" height="35" as="geometry" />
        </mxCell>
        <mxCell id="f_add" value="&lt;b&gt;Output = routed_output × scale + shared_output&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="280" y="1870" width="440" height="35" as="geometry" />
        </mxCell>
        <mxCell id="f_c1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_combine" target="f_add" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_s1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_shared" target="f_add" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_residual" value="&lt;b&gt;Residual Add&lt;/b&gt;&lt;br&gt;hidden_states += residual → 输出到下一层" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="300" y="2140" width="400" height="40" as="geometry" />
        </mxCell>
        <mxCell id="f_a1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="f_add" target="f_residual" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="deepep-dataflow" name="3. DeepEP Dispatch/Combine 完整流程">
    <mxGraphModel grid="1" page="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="2200" pageHeight="3600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t3" value="&lt;font style=&quot;font-size:22px&quot;&gt;&lt;b&gt;DeepEP All2All 完整计算与通信流程&lt;/b&gt;&lt;/font&gt;&lt;br&gt;Dispatch (FP8) + Combine (BF16) | 2 Nodes × 2 GPUs | GPU 0 视角" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="250" y="-400" width="700" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ep_s0" value="&lt;font style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Step 0: MoE Gate / Router&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;输入: hidden_states (M=4096, H=7168) BF16&lt;br&gt;&lt;br&gt;gate_output = gate_linear(hidden_states)  → (4096, 256) FP32&lt;br&gt;topk_weights, topk_ids = topk(softmax(gate_output), k=8)&lt;br&gt;&lt;br&gt;输出:&lt;br&gt;  topk_ids: (4096, 8) int64  ← 每token选的8个global expert id [0-255]&lt;br&gt;  topk_weights: (4096, 8) FP32 ← 对应的路由权重&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="-340" width="1100" height="170" as="geometry" />
        </mxCell>
        <mxCell id="ep_s0_arr" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1" source="ep_s0" target="ep_s1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_s1" value="&lt;font style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Step 1: FP8 Block Quantization (Dispatch 前)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;函数:&lt;/b&gt; moe_kernel_quantize_input → per_token_group_quant_fp8&lt;br&gt;&lt;b&gt;文件:&lt;/b&gt; fp8_utils.py, deepep_ht_prepare_finalize.py:prepare_async&lt;br&gt;&lt;br&gt;输入: hidden_states (4096, 7168) BF16&lt;br&gt;&lt;br&gt;对每行的每 128 元素组:&lt;br&gt;  1. absmax = max(|x[i:i+128]|)&lt;br&gt;  2. scale = absmax / 240.0  (FP8_MAX=240)&lt;br&gt;  3. 如果 use_ue8m0: scale = 2^ceil(log2(scale))  ← power-of-2 量化&lt;br&gt;  4. x_q[i:i+128] = clamp(x / scale, -240, 240)  → FP8 E4M3FN&lt;br&gt;&lt;br&gt;输出:&lt;br&gt;  &lt;font color=&quot;#CC0000&quot;&gt;a1q: (4096, 7168) float8_e4m3fn&lt;/font&gt; (1 byte/elem, 原BF16的一半)&lt;br&gt;  a1q_scale: (4096, 56) FP32  (7168/128=56 groups, &lt;b&gt;column-major&lt;/b&gt; for TMA)&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;★ 量化在 Dispatch 前做: 通信传输 FP8(1B) 而非 BF16(2B), 节省 50% 带宽&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="-130" width="1100" height="280" as="geometry" />
        </mxCell>
        <mxCell id="ep_s1_arr" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1" source="ep_s1" target="ep_s2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_s2" value="&lt;font style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Step 2: get_dispatch_layout() — 计算路由分布&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;函数:&lt;/b&gt; buffer.get_dispatch_layout(topk_idx, num_experts, ...)&lt;br&gt;&lt;b&gt;执行位置:&lt;/b&gt; comm stream (通过 dbo_yield_and_switch_from_compute_to_comm)&lt;br&gt;&lt;br&gt;输入: topk_ids (4096, 8) — 每token的8个目标expert id [0-255]&lt;br&gt;&lt;br&gt;计算逻辑: 遍历 topk_ids, 统计每个 EP rank 需要接收的 token 数量&lt;br&gt;  EP rank 0 (GPU 0): experts [0-63]   → 统计目标在 [0-63] 的 token×topk 条目&lt;br&gt;  EP rank 1 (GPU 1): experts [64-127]  → 统计目标在 [64-127] 的条目&lt;br&gt;  EP rank 2 (GPU 2): experts [128-191] → 统计目标在 [128-191] 的条目&lt;br&gt;  EP rank 3 (GPU 3): experts [192-255] → 统计目标在 [192-255] 的条目&lt;br&gt;&lt;br&gt;输出 (&lt;b&gt;区分 NVLink / RDMA 两条路径&lt;/b&gt;):&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;3&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;th&gt;输出&lt;/th&gt;&lt;th&gt;Shape&lt;/th&gt;&lt;th&gt;GPU 0 示例值&lt;/th&gt;&lt;th&gt;含义&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;num_tokens_per_rank&lt;/b&gt;&lt;/td&gt;&lt;td&gt;(4,)&lt;/td&gt;&lt;td&gt;[T₀, T₁, T₂, T₃]&lt;/td&gt;&lt;td&gt;每rank总token数 (含NVLink+本地)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFEBEE&quot;&gt;&lt;td&gt;&lt;b&gt;num_tokens_per_rdma_rank&lt;/b&gt;&lt;/td&gt;&lt;td&gt;(4,)&lt;/td&gt;&lt;td&gt;[0, 0, T₂, T₃]&lt;/td&gt;&lt;td&gt;需走RDMA的token数 (跨Node才有)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;dispatch_expert_num_tokens&lt;/b&gt;&lt;/td&gt;&lt;td&gt;(64,)&lt;/td&gt;&lt;td&gt;[32, 45, 28, ...]&lt;/td&gt;&lt;td&gt;本地每expert的token数&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E8F5E9&quot;&gt;&lt;td&gt;&lt;b&gt;is_token_in_rank&lt;/b&gt;&lt;/td&gt;&lt;td&gt;(4096, 8)&lt;/td&gt;&lt;td&gt;bool mask&lt;/td&gt;&lt;td&gt;标记哪些token×topk属于本rank&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;font color=&quot;#C62828&quot;&gt;GPU 0→GPU 1: 同 Node 0 → NVLink (rdma_rank[1]=0)&lt;br&gt;GPU 0→GPU 2,3: 跨 Node → RDMA (rdma_rank[2]=T₂, rdma_rank[3]=T₃)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="190" width="1100" height="360" as="geometry" />
        </mxCell>
        <mxCell id="ep_s2_arr" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1" source="ep_s2" target="ep_s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_s3" value="&lt;font style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Step 3: buffer.dispatch() — All2All 通信 (核心)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;函数:&lt;/b&gt; buffer.dispatch(x=(a1q, a1q_scale), handle, num_tokens_per_rank, num_tokens_per_rdma_rank, ...)&lt;br&gt;&lt;b&gt;执行位置:&lt;/b&gt; comm stream, async_finish=True (可与 shared experts overlap)&lt;br&gt;&lt;b&gt;SM 占用:&lt;/b&gt; 20 SMs (self.num_sms=20, 剩余 SM 可做 shared expert 计算)&lt;br&gt;&lt;br&gt;&lt;b&gt;发送内容 (GPU 0 → 其他):&lt;/b&gt;&lt;br&gt;  打包: tokens (FP8) + scales (FP32) + topk_ids + topk_weights&lt;br&gt;  按目标 rank 分类并发送&lt;br&gt;&lt;br&gt;&lt;b&gt;接收内容 (其他 → GPU 0):&lt;/b&gt;&lt;br&gt;  从 GPU 0/1/2/3 收集所有路由到 experts [0-63] 的 tokens&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0050ef;fontColor=#ffffff;strokeColor=#001DBC;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="610" width="1100" height="200" as="geometry" />
        </mxCell>
        <mxCell id="ep_comm_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#424242;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="850" width="1100" height="420" as="geometry" />
        </mxCell>
        <mxCell id="ep_comm_title" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;Dispatch All2All 通信详细数据流 (GPU 0 视角, 4096 tokens × 8 experts)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="250" y="855" width="700" height="25" as="geometry" />
        </mxCell>
        <mxCell id="ep_gpu0_send" value="&lt;font style=&quot;font-size:11px&quot;&gt;&lt;b&gt;GPU 0 发送端&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;4096 tokens × 8 topk&lt;br&gt;= 32768 token×expert 条目&lt;br&gt;均匀分布 → 每rank ~8192&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="70" y="877.5" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ep_local" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;本地保留 (零拷贝)&lt;/b&gt;&lt;br&gt;experts [0-63] 的条目&lt;br&gt;~8192 条 (~59 MB FP8+scales)&lt;br&gt;&lt;font color=&quot;#2E7D32&quot;&gt;延迟: 0&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="310" y="885" width="230" height="55" as="geometry" />
        </mxCell>
        <mxCell id="ep_nvl" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;→ GPU 1 via NVLink (同 Node 0)&lt;/b&gt;&lt;br&gt;experts [64-127] 的条目&lt;br&gt;~8192 条 (~59 MB)&lt;br&gt;&lt;font color=&quot;#1565C0&quot;&gt;&lt;b&gt;NVLink ~450 GB/s → 0.13 ms&lt;/b&gt;&lt;/font&gt;&lt;br&gt;通过 NVLink shared memory buffer 传输&lt;br&gt;warp-size int4 原子拷贝 (512B/次)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="310" y="950" width="230" height="95" as="geometry" />
        </mxCell>
        <mxCell id="ep_rdma2" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;→ GPU 2 via RDMA (跨 Node 1) ★&lt;/b&gt;&lt;br&gt;experts [128-191] 的条目&lt;br&gt;~8192 条 (~59 MB)&lt;br&gt;&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;RDMA ~50 GB/s → 1.2 ms&lt;/b&gt;&lt;/font&gt;&lt;br&gt;写入 RDMA 注册内存 → IB 网卡发送&lt;br&gt;10 QPs/rank (num_sms/2=10)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="310" y="1055" width="230" height="95" as="geometry" />
        </mxCell>
        <mxCell id="ep_rdma3" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;→ GPU 3 via RDMA (跨 Node 1) ★&lt;/b&gt;&lt;br&gt;experts [192-255] 的条目&lt;br&gt;~8192 条 (~59 MB)&lt;br&gt;&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;RDMA ~50 GB/s → 1.2 ms&lt;/b&gt;&lt;/font&gt;&lt;br&gt;与 GPU 2 的 RDMA 并行发送&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="310" y="1160" width="230" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ep_sa" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1" source="ep_gpu0_send" target="ep_local">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_sb" style="endArrow=classic;html=1;strokeWidth=3;strokeColor=#1565C0;" edge="1" parent="1" source="ep_gpu0_send" target="ep_nvl">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_sc" style="endArrow=classic;html=1;strokeWidth=3;strokeColor=#C62828;dashed=1;" edge="1" parent="1" source="ep_gpu0_send" target="ep_rdma2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_sd" style="endArrow=classic;html=1;strokeWidth=3;strokeColor=#C62828;dashed=1;" edge="1" parent="1" source="ep_gpu0_send" target="ep_rdma3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_gpu0_recv" value="&lt;font style=&quot;font-size:11px&quot;&gt;&lt;b&gt;GPU 0 接收端&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;汇聚来自 4 个 rank 的&lt;br&gt;路由到 experts [0-63] 的 tokens&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;" vertex="1" parent="1">
          <mxGeometry x="870" y="895" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ep_r_local" value="&lt;font style=&quot;font-size:9px&quot;&gt;← GPU 0 本地: ~8192 条&lt;br&gt;&lt;font color=&quot;#2E7D32&quot;&gt;0 ms&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="620" y="885" width="175" height="32" as="geometry" />
        </mxCell>
        <mxCell id="ep_r_nvl" value="&lt;font style=&quot;font-size:9px&quot;&gt;← GPU 1 NVLink: ~8192 条&lt;br&gt;&lt;font color=&quot;#1565C0&quot;&gt;0.13 ms&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="620" y="922" width="175" height="32" as="geometry" />
        </mxCell>
        <mxCell id="ep_r_rdma2" value="&lt;font style=&quot;font-size:9px&quot;&gt;← GPU 2 RDMA: ~8192 条&lt;br&gt;&lt;font color=&quot;#C62828&quot;&gt;1.2 ms ★&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;" vertex="1" parent="1">
          <mxGeometry x="620" y="959" width="175" height="32" as="geometry" />
        </mxCell>
        <mxCell id="ep_r_rdma3" value="&lt;font style=&quot;font-size:9px&quot;&gt;← GPU 3 RDMA: ~8192 条&lt;br&gt;&lt;font color=&quot;#C62828&quot;&gt;1.2 ms ★&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;" vertex="1" parent="1">
          <mxGeometry x="620" y="996" width="175" height="32" as="geometry" />
        </mxCell>
        <mxCell id="ep_ra" style="endArrow=classic;html=1;" edge="1" parent="1" source="ep_r_local" target="ep_gpu0_recv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_rb" style="endArrow=classic;html=1;" edge="1" parent="1" source="ep_r_nvl" target="ep_gpu0_recv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_rc" style="endArrow=classic;html=1;" edge="1" parent="1" source="ep_r_rdma2" target="ep_gpu0_recv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_rd" style="endArrow=classic;html=1;" edge="1" parent="1" source="ep_r_rdma3" target="ep_gpu0_recv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_timeline" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Dispatch 时序 (GPU 0):&lt;/b&gt;&lt;br&gt;&lt;br&gt;  &lt;font color=&quot;#2E7D32&quot;&gt;━━━━&lt;/font&gt; 本地 (0ms)&lt;br&gt;  &lt;font color=&quot;#1565C0&quot;&gt;━━━━━━━━━━━━&lt;/font&gt; NVLink (~0.13ms)&lt;br&gt;  &lt;font color=&quot;#C62828&quot;&gt;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&lt;/font&gt; RDMA (~1.2ms) ★瓶颈★&lt;br&gt;&lt;br&gt;NVLink 和 RDMA 通信可以&lt;b&gt;并行执行&lt;/b&gt;&lt;br&gt;总延迟 ≈ max(NVLink, RDMA) = RDMA 延迟&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;strokeWidth=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="550" y="1055" width="590" height="175" as="geometry" />
        </mxCell>
        <mxCell id="ep_s3_out" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;Dispatch 输出 (GPU 0 上)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;3&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#E8EAF6&quot;&gt;&lt;th&gt;输出&lt;/th&gt;&lt;th&gt;Shape&lt;/th&gt;&lt;th&gt;Dtype&lt;/th&gt;&lt;th&gt;说明&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;dispatched_tokens&lt;/b&gt;&lt;/td&gt;&lt;td&gt;(N_recv, 7168)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#CC0000&quot;&gt;FP8&lt;/font&gt;&lt;/td&gt;&lt;td&gt;汇聚后的所有 tokens (来自 4 个 rank)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;dispatched_scales&lt;/b&gt;&lt;/td&gt;&lt;td&gt;(N_recv, 56)&lt;/td&gt;&lt;td&gt;FP32&lt;/td&gt;&lt;td&gt;对应的 block scales&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;expert_topk_ids&lt;/b&gt;&lt;/td&gt;&lt;td&gt;(N_recv, topk)&lt;/td&gt;&lt;td&gt;int64&lt;/td&gt;&lt;td&gt;local expert ids [0-63]&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;expert_topk_weights&lt;/b&gt;&lt;/td&gt;&lt;td&gt;(N_recv, topk)&lt;/td&gt;&lt;td&gt;FP32&lt;/td&gt;&lt;td&gt;路由权重&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;expert_num_tokens&lt;/b&gt;&lt;/td&gt;&lt;td&gt;(64,)&lt;/td&gt;&lt;td&gt;int&lt;/td&gt;&lt;td&gt;每 local expert 的 token 数&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;handle&lt;/b&gt;&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;opaque&lt;/td&gt;&lt;td&gt;Combine 时必须传入 (路由元数据)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="1320" width="1100" height="180" as="geometry" />
        </mxCell>
        <mxCell id="ep_s3_arr2" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1" source="ep_comm_box" target="ep_s3_out">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_s4_title" value="&lt;font style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Step 4: _receiver() — 接收后处理&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;1. expert_topk_ids 修正&lt;/b&gt; (local → global expert space):&lt;br&gt;  expert_topk_ids = torch.where(expert_topk_ids == -1,&lt;br&gt;      num_experts-1 if rank==0 else 0,   ← 无效条目设为远离本 rank 的 expert&lt;br&gt;      expert_topk_ids + rank_expert_offset)  ← GPU 0: +0, GPU 1: +64, GPU 2: +128, GPU 3: +192&lt;br&gt;&lt;br&gt;&lt;b&gt;2. expert_tokens_meta 构建:&lt;/b&gt;&lt;br&gt;  ExpertTokensMetadata.make_from_list([32, 45, 28, ...]) → GPU tensor&lt;br&gt;  包含: num_tokens_per_expert (64,), expert_start_indices 等&lt;br&gt;&lt;br&gt;&lt;b&gt;3. (可选) 非 block-quant 场景的延后量化:&lt;/b&gt;&lt;br&gt;  如果 dispatch 以 BF16 传输 (非 FP8 block scales), 在此处量化&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="1540" width="1100" height="200" as="geometry" />
        </mxCell>
        <mxCell id="ep_s3_arr3" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1" source="ep_s3_out" target="ep_s4_title">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_expert_box" value="&lt;font style=&quot;font-size:16px&quot; color=&quot;#ffffff&quot;&gt;&lt;b&gt;DeepGEMM Expert Compute (详见 Page 4/6/7)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#ffffff&quot;&gt;ep_scatter → GEMM1 → SiLU+Quant → GEMM2 → ep_gather&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;fontSize=12;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="250" y="1780" width="700" height="55" as="geometry" />
        </mxCell>
        <mxCell id="ep_s4_arr" style="endArrow=classic;html=1;strokeWidth=3;strokeColor=#a20025;" edge="1" parent="1" source="ep_s4_title" target="ep_expert_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_s5" value="&lt;font style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Step 5: _finalize() — TopK 加权 (Combine 前)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;函数:&lt;/b&gt; weight_and_reduce_impl.apply(fused_expert_output, topk_weights, ...)&lt;br&gt;&lt;br&gt;对于 DeepGemmExperts:&lt;br&gt;  ep_gather (unpermute_and_reduce) 已在 Expert Compute 阶段完成加权聚合&lt;br&gt;  → 此处 weight_and_reduce 是 &lt;b&gt;NoOP&lt;/b&gt;&lt;br&gt;&lt;br&gt;输入: fused_expert_output (N_recv, 7168) BF16  ← Expert Compute 的输出&lt;br&gt;输出: 同上 (不变, 已包含 topk_weights 加权)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="1870" width="1100" height="160" as="geometry" />
        </mxCell>
        <mxCell id="ep_s4_arr2" style="endArrow=classic;html=1;strokeWidth=3;strokeColor=#a20025;" edge="1" parent="1" source="ep_expert_box" target="ep_s5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_s6" value="&lt;font style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Step 6: buffer.combine() — All2All 反向通信&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;函数:&lt;/b&gt; buffer.combine(x=fused_expert_output, handle=handle, topk_weights=None, ...)&lt;br&gt;&lt;b&gt;执行位置:&lt;/b&gt; comm stream, async_finish=True (可与 shared experts overlap)&lt;br&gt;&lt;b&gt;必须传入 dispatch 返回的 handle:&lt;/b&gt; 包含路由元数据, 知道每个 token 应发回哪个 rank&lt;br&gt;&lt;br&gt;&lt;b&gt;通信方向: Dispatch 的逆操作&lt;/b&gt;&lt;br&gt;  Dispatch: 源 rank → expert rank (按 expert id 路由)&lt;br&gt;  Combine:  expert rank → 源 rank (按原始 token 归属路由)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0050ef;fontColor=#ffffff;strokeColor=#001DBC;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="2060" width="1100" height="150" as="geometry" />
        </mxCell>
        <mxCell id="ep_s5_arr" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1" source="ep_s5" target="ep_s6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_comb_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#424242;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="2330" width="1100" height="260" as="geometry" />
        </mxCell>
        <mxCell id="ep_comb_title" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;Combine All2All 通信详细数据流 (GPU 0 视角)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="300" y="2335" width="600" height="25" as="geometry" />
        </mxCell>
        <mxCell id="ep_c_send" value="&lt;font style=&quot;font-size:11px&quot;&gt;&lt;b&gt;GPU 0 发送端&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;experts [0-63] 的输出&lt;br&gt;按原始 token 归属分发&lt;br&gt;数据类型: &lt;b&gt;BF16 (2B)&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;" vertex="1" parent="1">
          <mxGeometry x="70" y="2375" width="160" height="65" as="geometry" />
        </mxCell>
        <mxCell id="ep_c_local" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;本地保留&lt;/b&gt; GPU 0 tokens → experts [0-63] 的结果&lt;br&gt;&lt;font color=&quot;#2E7D32&quot;&gt;0 ms&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="310" y="2370" width="230" height="32" as="geometry" />
        </mxCell>
        <mxCell id="ep_c_nvl" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;→ GPU 1 NVLink:&lt;/b&gt; GPU 1 原始 tokens 的结果&lt;br&gt;~117 MB BF16  &lt;font color=&quot;#1565C0&quot;&gt;&lt;b&gt;0.26 ms&lt;/b&gt;&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="310" y="2410" width="230" height="35" as="geometry" />
        </mxCell>
        <mxCell id="ep_c_rdma2" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;→ GPU 2 RDMA ★:&lt;/b&gt; GPU 2 原始 tokens 的结果&lt;br&gt;~117 MB BF16  &lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;2.3 ms&lt;/b&gt;&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="310" y="2455" width="230" height="35" as="geometry" />
        </mxCell>
        <mxCell id="ep_c_rdma3" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;→ GPU 3 RDMA ★:&lt;/b&gt; GPU 3 原始 tokens 的结果&lt;br&gt;~117 MB BF16  &lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;2.3 ms&lt;/b&gt;&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="310" y="2500" width="230" height="35" as="geometry" />
        </mxCell>
        <mxCell id="ep_ca" style="endArrow=classic;html=1;" edge="1" parent="1" source="ep_c_send" target="ep_c_local">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_cb" style="endArrow=classic;html=1;strokeColor=#1565C0;strokeWidth=2;" edge="1" parent="1" source="ep_c_send" target="ep_c_nvl">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_cc" style="endArrow=classic;html=1;strokeColor=#C62828;strokeWidth=2;dashed=1;" edge="1" parent="1" source="ep_c_send" target="ep_c_rdma2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_cd" style="endArrow=classic;html=1;strokeColor=#C62828;strokeWidth=2;dashed=1;" edge="1" parent="1" source="ep_c_send" target="ep_c_rdma3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_c_recv" value="&lt;font style=&quot;font-size:11px&quot;&gt;&lt;b&gt;GPU 0 接收端&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;收集 GPU 0 原始 4096 tokens&lt;br&gt;在所有 256 experts 的计算结果&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;" vertex="1" parent="1">
          <mxGeometry x="870" y="2375" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ep_cr_l" value="&lt;font style=&quot;font-size:8px&quot;&gt;← 本地: experts [0-63] 结果 &lt;font color=&quot;#2E7D32&quot;&gt;0ms&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="640" y="2370" width="170" height="22" as="geometry" />
        </mxCell>
        <mxCell id="ep_cr_n" value="&lt;font style=&quot;font-size:8px&quot;&gt;← GPU 1 NVLink: experts [64-127] &lt;font color=&quot;#1565C0&quot;&gt;0.26ms&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="640" y="2396" width="170" height="22" as="geometry" />
        </mxCell>
        <mxCell id="ep_cr_r2" value="&lt;font style=&quot;font-size:8px&quot;&gt;← GPU 2 RDMA: experts [128-191] &lt;font color=&quot;#C62828&quot;&gt;2.3ms★&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;" vertex="1" parent="1">
          <mxGeometry x="640" y="2422" width="170" height="22" as="geometry" />
        </mxCell>
        <mxCell id="ep_cr_r3" value="&lt;font style=&quot;font-size:8px&quot;&gt;← GPU 3 RDMA: experts [192-255] &lt;font color=&quot;#C62828&quot;&gt;2.3ms★&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;" vertex="1" parent="1">
          <mxGeometry x="640" y="2448" width="170" height="22" as="geometry" />
        </mxCell>
        <mxCell id="ep_cra" style="endArrow=classic;html=1;" edge="1" parent="1" source="ep_cr_l" target="ep_c_recv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_crb" style="endArrow=classic;html=1;" edge="1" parent="1" source="ep_cr_n" target="ep_c_recv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_crc" style="endArrow=classic;html=1;" edge="1" parent="1" source="ep_cr_r2" target="ep_c_recv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_crd" style="endArrow=classic;html=1;" edge="1" parent="1" source="ep_cr_r3" target="ep_c_recv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_c_note" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Combine 关键差异 vs Dispatch:&lt;/b&gt;&lt;br&gt;1. 数据类型 BF16 (2B) vs Dispatch FP8 (1B) → &lt;font color=&quot;#C62828&quot;&gt;通信量翻倍&lt;/font&gt;&lt;br&gt;2. 无需传输 topk_ids/weights/scales (已在 Expert 阶段消费)&lt;br&gt;3. RDMA 延迟 ~2.3ms vs Dispatch ~1.2ms → &lt;font color=&quot;#C62828&quot;&gt;Combine 是更大瓶颈&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;" vertex="1" parent="1">
          <mxGeometry x="620" y="2500" width="410" height="75" as="geometry" />
        </mxCell>
        <mxCell id="ep_s7" value="&lt;font style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Step 7: Combine 输出 + copy_&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;输出:&lt;/b&gt; combined_x: (4096, 7168) &lt;font color=&quot;#CC0000&quot;&gt;BF16&lt;/font&gt;&lt;br&gt;  GPU 0 的每个原始 token 已获得所有 8 个 expert 的加权聚合结果&lt;br&gt;&lt;br&gt;&lt;b&gt;_receiver():&lt;/b&gt;&lt;br&gt;  event.current_stream_wait()  ← 等待 combine 异步完成&lt;br&gt;  output.copy_(combined_x, non_blocking=True)  ← 复制到 MoE 输出 tensor&lt;br&gt;&lt;br&gt;→ 输出回到 DecoderLayer: residual_add(attn_out + moe_out + shared_expert_out)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="2630" width="1100" height="200" as="geometry" />
        </mxCell>
        <mxCell id="ep_s6_arr" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1" source="ep_comb_box" target="ep_s7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep_dtype_cmp" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;Dispatch vs Combine 全面对比&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#1565C0;color:#fff&quot;&gt;&lt;th&gt;维度&lt;/th&gt;&lt;th&gt;Dispatch (Prepare)&lt;/th&gt;&lt;th&gt;Combine (Finalize)&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;数据类型&lt;/b&gt;&lt;/td&gt;&lt;td&gt;FP8 (1B) + FP32 scales&lt;/td&gt;&lt;td&gt;BF16 (2B)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;td&gt;&lt;b&gt;通信方向&lt;/b&gt;&lt;/td&gt;&lt;td&gt;源 rank → expert rank&lt;/td&gt;&lt;td&gt;expert rank → 源 rank&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;路由依据&lt;/b&gt;&lt;/td&gt;&lt;td&gt;topk_ids (expert id)&lt;/td&gt;&lt;td&gt;handle (dispatch 记录的反向路由)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;td&gt;&lt;b&gt;附加元数据&lt;/b&gt;&lt;/td&gt;&lt;td&gt;topk_ids + weights + scales&lt;/td&gt;&lt;td&gt;仅 expert output&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;每 token 数据量&lt;/b&gt;&lt;/td&gt;&lt;td&gt;~7168B (FP8) + 224B (scales) + 64B (ids) = ~7.5KB&lt;/td&gt;&lt;td&gt;~14336B (BF16) = ~14KB&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFEBEE&quot;&gt;&lt;td&gt;&lt;b&gt;RDMA 单 rank 数据量&lt;/b&gt;&lt;/td&gt;&lt;td&gt;~59 MB (FP8+meta)&lt;/td&gt;&lt;td&gt;~117 MB (BF16)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFCDD2&quot;&gt;&lt;td&gt;&lt;b&gt;RDMA 延迟 (50GB/s)&lt;/b&gt;&lt;/td&gt;&lt;td&gt;~1.2 ms&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;~2.3 ms ★更慢★&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;NVLink 延迟 (450GB/s)&lt;/b&gt;&lt;/td&gt;&lt;td&gt;~0.13 ms&lt;/td&gt;&lt;td&gt;~0.26 ms&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;td&gt;&lt;b&gt;Overlap 对象&lt;/b&gt;&lt;/td&gt;&lt;td&gt;可与 shared experts overlap&lt;/td&gt;&lt;td&gt;可与 shared experts overlap&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;SM 占用&lt;/b&gt;&lt;/td&gt;&lt;td&gt;20 SMs (通信专用)&lt;/td&gt;&lt;td&gt;20 SMs (通信专用)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="2880" width="1100" height="270" as="geometry" />
        </mxCell>
        <mxCell id="ep_buffer" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;DeepEP Buffer 配置 (HT 模式)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;3&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#E0E0E0&quot;&gt;&lt;th&gt;参数&lt;/th&gt;&lt;th&gt;值&lt;/th&gt;&lt;th&gt;说明&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;NVLink buffer&lt;/td&gt;&lt;td&gt;1 GB&lt;/td&gt;&lt;td&gt;节点内 GPU 间共享内存 (每 GPU)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;RDMA buffer&lt;/td&gt;&lt;td&gt;1 GB&lt;/td&gt;&lt;td&gt;跨节点 RDMA 注册内存 (每 GPU, 仅 internode)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;num_sms&lt;/td&gt;&lt;td&gt;20&lt;/td&gt;&lt;td&gt;通信专用 SM 数 (H100 总 132 SMs)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;num_qps_per_rank&lt;/td&gt;&lt;td&gt;10&lt;/td&gt;&lt;td&gt;每远端 rank 的 RDMA QP 数 (= num_sms/2)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;low_latency_mode&lt;/td&gt;&lt;td&gt;False&lt;/td&gt;&lt;td&gt;HT 模式 (大 batch, 高吞吐优先)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;显存占用/GPU&lt;/td&gt;&lt;td&gt;~2 GB&lt;/td&gt;&lt;td&gt;NVLink (1GB) + RDMA (1GB)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;xfer_atom_size&lt;/td&gt;&lt;td&gt;512 B&lt;/td&gt;&lt;td&gt;32(warp) × 16B(int4) 原子拷贝单元&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;b&gt;NVLink→RDMA 二级路由:&lt;/b&gt;&lt;br&gt;dispatch 内部: 先 NVLink 聚合到节点内 buffer → 再 RDMA 发往远端节点 → 远端 NVLink 分发到目标 GPU&lt;br&gt;combine 内部: 路径对称反向&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#546E7A;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="3190" width="1100" height="230" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="deepgemm-compute" name="4. DeepGEMM Expert Compute 详解">
    <mxGraphModel dx="1035" dy="1066" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="3100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t4" value="&lt;font style=&quot;font-size:22px&quot;&gt;&lt;b&gt;DeepGEMM Expert Compute 详解&lt;/b&gt;&lt;/font&gt;&lt;br&gt;FP8 Grouped GEMM | 64 Local Experts | GPU 0视角" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="250" y="-40" width="600" height="50" as="geometry" />
        </mxCell>
        <mxCell id="g_input" value="&lt;b&gt;DeepEP Dispatch 输出 (DeepGEMM 输入)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;dispatched_tokens: (N_recv, 7168) &lt;font color=&quot;#CC0000&quot;&gt;FP8 (float8_e4m3fn)&lt;/font&gt;&lt;br&gt;a1q_scale: (N_recv, 56) FP32 &lt;font color=&quot;#666666&quot;&gt;(56 = 7168/128 block groups)&lt;/font&gt;&lt;br&gt;topk_ids: (N_recv, topk) int64 &lt;font color=&quot;#666666&quot;&gt;(global expert ids, 已offset)&lt;/font&gt;&lt;br&gt;topk_weights: (N_recv, topk) FP32&lt;br&gt;expert_tokens_meta: {expert_id → token_count} per 64 local experts&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="100" y="30" width="900" height="120" as="geometry" />
        </mxCell>
        <mxCell id="g_w1" value="&lt;b&gt;W1 (Gate+Up)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;(64, 2×I, 7168) FP8&lt;br&gt;w1_scale: block scales&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="100" y="160" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="g_w2" value="&lt;b&gt;W2 (Down)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;(64, 7168, I) FP8&lt;br&gt;w2_scale: block scales&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="800" y="160" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="g_permute" value="&lt;b&gt;Step 1: Permute (ep_scatter Triton kernel — 两阶段)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;按expert ID重组tokens, 每组对齐到 &lt;font color=&quot;#FFFF00&quot;&gt;128行&lt;/font&gt; (DeepGEMM tile对齐要求)&lt;br&gt;&lt;br&gt;&lt;b&gt;Phase 1 (_fwd_kernel_ep_scatter_1):&lt;/b&gt;&lt;br&gt;tokens_per_expert = round_up_128(num_tokens[e])&lt;br&gt;expert_start_loc = cumsum(tokens_per_expert) &lt;font color=&quot;#AAAAAA&quot;&gt;// 前缀和计算每expert起始行&lt;/font&gt;&lt;br&gt;m_indices[start..start+T_e] = e &lt;font color=&quot;#AAAAAA&quot;&gt;// 填写expert_ids, 超出部分保持-1&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Phase 2 (_fwd_kernel_ep_scatter_2):&lt;/b&gt;&lt;br&gt;dest = atomic_add(expert_start_loc[e], 1) &lt;font color=&quot;#AAAAAA&quot;&gt;// 原子分配行号&lt;/font&gt;&lt;br&gt;output[dest] = recv_x[token_id] &lt;font color=&quot;#AAAAAA&quot;&gt;// 复制FP8 token data + scale&lt;/font&gt;&lt;br&gt;inv_perm[token_id, topk_idx] = dest &lt;font color=&quot;#AAAAAA&quot;&gt;// 记录反向索引&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;2&quot; style=&quot;border-collapse:collapse;font-size:9px&quot;&gt;&lt;tr style=&quot;background:#E8EAF6&quot;&gt;&lt;th&gt;Expert 0&lt;/th&gt;&lt;th&gt;Expert 1&lt;/th&gt;&lt;th&gt;...&lt;/th&gt;&lt;th&gt;Expert 63&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;32 tokens + 96 pad = 128 rows&lt;/td&gt;&lt;td&gt;45 tokens + 83 pad = 128 rows&lt;/td&gt;&lt;td&gt;...&lt;/td&gt;&lt;td&gt;28 tokens + 100 pad = 128 rows&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;font color=&quot;#00FF00&quot;&gt;输出: a1q_perm (M_sum, 7168) FP8 | a1q_scale (M_sum, 56) FP32 | expert_ids (M_sum,) | inv_perm (N_recv, topk)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="150" y="250" width="800" height="250" as="geometry" />
        </mxCell>
        <mxCell id="gp1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="g_input" target="g_permute" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="g_gemm1" value="&lt;b&gt;Step 2: GEMM1 — m_grouped_fp8_gemm_nt_contiguous()&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;&lt;br&gt;&lt;font color=&quot;#FFFF00&quot;&gt;A&lt;/font&gt; = a1q_perm &lt;font color=&quot;#AAAAAA&quot;&gt;(M_sum, K=7168)&lt;/font&gt; FP8 + a1q_scale &lt;font color=&quot;#AAAAAA&quot;&gt;(M_sum, 56) col-major&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#FFFF00&quot;&gt;B&lt;/font&gt; = W1 &lt;font color=&quot;#AAAAAA&quot;&gt;(64, N=2I, K=7168)&lt;/font&gt; FP8 + w1_scale &lt;font color=&quot;#AAAAAA&quot;&gt;(64, 2I/128, 56) transformed layout&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#00FF00&quot;&gt;C&lt;/font&gt; = mm1_out &lt;font color=&quot;#AAAAAA&quot;&gt;(M_sum, 2I)&lt;/font&gt; BF16&lt;br&gt;&lt;br&gt;&lt;b&gt;Kernel内部:&lt;/b&gt; Per expert e: C[rows_e] = dequant(A[rows_e], A_s) × dequant(B[e], B_s[e])ᵀ&lt;br&gt;expert_ids (M_sum,) 指定每行所属expert | -1=padding→scheduler跳过&lt;br&gt;&lt;font color=&quot;#AAAAAA&quot;&gt;dequant: fp8_val × a_scale[row][k//128] × b_scale[expert][n//128][k//128]&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#AAAAAA&quot;&gt;Tiling: block_m∈{64,128,256} × block_n × block_k=128 | TMA异步加载 | FP32累加→BF16输出&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="150" y="540" width="800" height="180" as="geometry" />
        </mxCell>
        <mxCell id="gg1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="g_permute" target="g_gemm1" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="gw1a" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#F57F17;" parent="1" source="g_w1" target="g_gemm1" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="g_act" value="&lt;b&gt;Step 3: SiLU Activation + FP8 Re-quantize (_act_mul_quant)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;&lt;br&gt;输入: mm1_out (M_sum, 2I) BF16&lt;br&gt;&lt;br&gt;&lt;b&gt;路径1 (Hopper, 最常用): silu_mul_per_token_group_quant_fp8_colmajor&lt;/b&gt;&lt;br&gt;  gate = mm1_out[:, :I], up = mm1_out[:, I:2I]&lt;br&gt;  act = &lt;font color=&quot;#FFFF00&quot;&gt;SiLU(gate)&lt;/font&gt; × up → FP8 quantize (单个融合Triton kernel)&lt;br&gt;  scale = absmax(128-elem block) / 240.0 &lt;font color=&quot;#AAAAAA&quot;&gt;// use_ue8m0=True时: 2^ceil(log2(scale))&lt;/font&gt;&lt;br&gt;  scales存储: &lt;font color=&quot;#FFFF00&quot;&gt;column-major&lt;/font&gt; (I/128, M_sum).T → TMA对齐&lt;br&gt;&lt;br&gt;&lt;b&gt;路径2 (Blackwell SM100): packed UE8M0&lt;/b&gt;&lt;br&gt;  activation → per_token_group_quant_fp8_packed_for_deepgemm&lt;br&gt;  scales: packed int32 (4个UE8M0/int32), stride=(1, tma_aligned_mn)&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#00FF00&quot;&gt;输出: a2q (M_sum, I) FP8, a2q_scale col-major FP32 (或packed UE8M0)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="150" y="760" width="800" height="220" as="geometry" />
        </mxCell>
        <mxCell id="ga1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="g_gemm1" target="g_act" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="g_gemm2" value="&lt;b&gt;Step 4: GEMM2 — m_grouped_fp8_gemm_nt_contiguous()&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;&lt;br&gt;&lt;font color=&quot;#FFFF00&quot;&gt;A&lt;/font&gt; = a2q &lt;font color=&quot;#AAAAAA&quot;&gt;(M_sum, I)&lt;/font&gt; FP8 + a2q_scale &lt;font color=&quot;#AAAAAA&quot;&gt;col-major&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#FFFF00&quot;&gt;B&lt;/font&gt; = W2 &lt;font color=&quot;#AAAAAA&quot;&gt;(64, K=7168, I)&lt;/font&gt; FP8 + w2_scale &lt;font color=&quot;#AAAAAA&quot;&gt;(64, 7168/128, I/128) transformed&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#00FF00&quot;&gt;C&lt;/font&gt; = mm2_out &lt;font color=&quot;#AAAAAA&quot;&gt;(M_sum, 7168)&lt;/font&gt; BF16&lt;br&gt;&lt;br&gt;Per expert e: C[rows_e] = dequant(A[rows_e]) × dequant(B[e])ᵀ&lt;br&gt;&lt;font color=&quot;#AAAAAA&quot;&gt;复用GEMM1相同的expert_ids (M_sum,) — 同一Contiguous Layout&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="150" y="1020" width="800" height="150" as="geometry" />
        </mxCell>
        <mxCell id="gg2" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="g_act" target="g_gemm2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="gw2a" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#F57F17;" parent="1" source="g_w2" target="g_gemm2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="g_unperm" value="&lt;b&gt;Step 5: Unpermute + Weighted Reduce (ep_gather Triton kernel)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;&lt;br&gt;输入: mm2_out (M_sum, 7168), inv_perm (N_recv, topk), topk_weights&lt;br&gt;&lt;br&gt;&lt;b&gt;inv_perm是scatter map, 不是传统的逆排列矩阵:&lt;/b&gt;&lt;br&gt;inv_perm[t,k] = Phase 2中atomic_add分配的行号 → mm2_out中的位置&lt;br&gt;&lt;br&gt;For each token t, topk slot k:&lt;br&gt;  if expert_map[topk_ids[t,k]] ≥ 0:  &lt;font color=&quot;#AAAAAA&quot;&gt;// 本地expert&lt;/font&gt;&lt;br&gt;    src = mm2_out[inv_perm[t,k]]  &lt;font color=&quot;#AAAAAA&quot;&gt;// 从grouped layout读取&lt;/font&gt;&lt;br&gt;    output[t] += &lt;font color=&quot;#FFFF00&quot;&gt;topk_weights[t,k]&lt;/font&gt; × src  &lt;font color=&quot;#AAAAAA&quot;&gt;// FP32累加&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#00FF00&quot;&gt;输出: expert_output (N_recv, 7168) BF16 → DeepEP Combine&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="150" y="1200" width="800" height="200" as="geometry" />
        </mxCell>
        <mxCell id="gu1" style="endArrow=classic;html=1;strokeWidth=2;" parent="1" source="g_gemm2" target="g_unperm" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="g_output" value="&lt;b&gt;→ DeepEP Combine (buffer.combine)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;expert_output (N_recv, 7168) BF16&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0050ef;fontColor=#ffffff;strokeColor=#001DBC;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="300" y="1420" width="500" height="45" as="geometry" />
        </mxCell>
        <mxCell id="go1" style="endArrow=classic;html=1;strokeWidth=3;strokeColor=#0050ef;" parent="1" source="g_unperm" target="g_output" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="g_summary" value="&lt;font style=&quot;font-size:12px&quot;&gt;&lt;b&gt;DeepGEMM 核心设计要点&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;3&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#FFF9C4&quot;&gt;&lt;th&gt;特性&lt;/th&gt;&lt;th&gt;说明&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;JIT编译&lt;/b&gt;&lt;/td&gt;&lt;td&gt;NVCC运行时编译CUDA kernel, 缓存到 DG_JIT_CACHE_DIR, 后续直接加载.cubin&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;Contiguous Layout&lt;/b&gt;&lt;/td&gt;&lt;td&gt;expert_ids(M_sum,) 标记每行expert归属; -1=padding→kernel跳过; 同expert行连续排列&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;128对齐&lt;/b&gt;&lt;/td&gt;&lt;td&gt;M per expert → ceil_128 (kernel tile大小); N, K → %128==0; block_shape=[128,128]&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;FP8量化&lt;/b&gt;&lt;/td&gt;&lt;td&gt;float8_e4m3fn + 128×128 block scales; SM90:FP32 scales; SM100:UE8M0(2^ceil(log2))&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;TMA加载&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Tensor Memory Accelerator异步加载: scales需column-major/TMA对齐stride&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;Kernel Tiling&lt;/b&gt;&lt;/td&gt;&lt;td&gt;block_m∈{64,128,256}, block_n∈{16..256, step16}, block_k=128; JIT自动选最优配置&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;计算精度&lt;/b&gt;&lt;/td&gt;&lt;td&gt;FP8 Tensor Core MMA (wgmma), FP32累加, BF16输出; ~1550 TFLOPS on H800&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;融合SiLU+Quant&lt;/b&gt;&lt;/td&gt;&lt;td&gt;GEMM1→GEMM2间: 单个Triton kernel完成 SiLU×gate + FP8 re-quantize + scale计算&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="100" y="1485" width="900" height="210" as="geometry" />
        </mxCell>
        <mxCell id="g_layout" value="&lt;font style=&quot;font-size:11px&quot;&gt;&lt;b&gt;Contiguous Layout 内存示意&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;┌──Expert 0──┐┌──Expert 1──┐...┌──Expert 63─┐&lt;br&gt;│T0 T1..pad=128││T0 T1..pad=128│...│T0 T1..pad=128│&lt;br&gt;│ids=[0,0..-1] ││ids=[1,1..-1]│...│ids=[63,63.-1]│&lt;br&gt;└─ ceil_128(T₀)┘└─ceil_128(T₁)┘...└─ceil_128(T₆₃)┘&lt;br&gt;← M_sum = Σ ceil_128(Tᵢ) →&lt;br&gt;&lt;br&gt;&lt;b&gt;ep_scatter Triton kernel (两阶段):&lt;/b&gt;&lt;br&gt;Phase 1: prefix_sum(round_up_128(tokens_per_expert)) → expert_start_loc&lt;br&gt;Phase 2: atomic_add(expert_start_loc[e]) → 分配行号, 写入token+scale+inv_perm&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#5C6BC0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="1720" width="900" height="160" as="geometry" />
        </mxCell>
        <mxCell id="g_vs" value="&lt;font style=&quot;font-size:11px&quot;&gt;&lt;b&gt;Contiguous vs Masked Layout&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;2&quot; style=&quot;border-collapse:collapse&quot;&gt;&lt;tr style=&quot;background:#E0E0E0&quot;&gt;&lt;th&gt;&lt;/th&gt;&lt;th&gt;Contiguous (Prefill/HT)&lt;/th&gt;&lt;th&gt;Masked (Decode/LL)&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;输入&lt;/td&gt;&lt;td&gt;(M_sum, K) + expert_ids&lt;/td&gt;&lt;td&gt;(E, max_m, K) + num_tokens&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Permute&lt;/td&gt;&lt;td&gt;需要 (ep_scatter)&lt;/td&gt;&lt;td&gt;不需要&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Padding&lt;/td&gt;&lt;td&gt;少 (128对齐)&lt;/td&gt;&lt;td&gt;多 (pad到max_m)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;CUDA Graph&lt;/td&gt;&lt;td&gt;不兼容 (动态M)&lt;/td&gt;&lt;td&gt;兼容&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="1890" width="900" height="120" as="geometry" />
        </mxCell>
        <mxCell id="g_kernel" value="&lt;font style=&quot;font-size:12px&quot;&gt;&lt;b&gt;DeepGEMM Kernel 内部流程 (单个Thread Block处理128×128 tile)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;3&quot; style=&quot;border-collapse:collapse;font-size:9px&quot;&gt;&lt;tr style=&quot;background:#E8F5E9&quot;&gt;&lt;th&gt;阶段&lt;/th&gt;&lt;th&gt;TMA Warp-Group (128 threads)&lt;/th&gt;&lt;th&gt;Math Warp-Groups (256 threads)&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;1. Scheduler&lt;/b&gt;&lt;/td&gt;&lt;td colspan=&quot;2&quot;&gt;scheduler.get_next_block(m_block_idx, n_block_idx)&lt;br&gt;persistent模式: 每个SM循环领取tile直到全部完成&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;2. Expert选择&lt;/b&gt;&lt;/td&gt;&lt;td colspan=&quot;2&quot;&gt;expert_id = &lt;b&gt;__ldg&lt;/b&gt;(grouped_layout + m_block_idx * BLOCK_M)&lt;br&gt;→ 用于索引B矩阵: B[expert_id, n_block:, k_block:]&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;3. Skip检查&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;(per WG)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;TMA不做skip检查&lt;br&gt;无条件加载整个128×128 tile&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#CC0000&quot;&gt;is_computation_valid(m_block_idx, &lt;b&gt;math_wg_idx × 64&lt;/b&gt;)&lt;/font&gt;&lt;br&gt;每个WG &lt;b&gt;独立检查&lt;/b&gt; 自己负责的64行:&lt;br&gt;WG0检查row[0], WG1检查row[64]&lt;br&gt;= -1 → 该WG跳过: 只做barrier wait+arrive, &lt;b&gt;零WGMMA&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;可能WG0计算、WG1跳过 (expert边界处)&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFF3E0&quot;&gt;&lt;td&gt;&lt;b&gt;4. K循环&lt;/b&gt;&lt;br&gt;(56次)&lt;/td&gt;&lt;td&gt;TMA异步加载 (pipeline):&lt;br&gt;A_tile(128,128) FP8&lt;br&gt;B_tile(128,128) FP8&lt;br&gt;A_scale(128,) FP32&lt;br&gt;arrive(full_barrier)&lt;/td&gt;&lt;td&gt;wait(full_barrier)&lt;br&gt;&lt;b&gt;WGMMA: FP8×FP8→FP32&lt;/b&gt;&lt;br&gt;Scale promotion: accum += (a_scale × b_scale) × raw&lt;br&gt;arrive(empty_barrier)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;5. 写回&lt;/b&gt;&lt;/td&gt;&lt;td&gt;TMA Store:&lt;br&gt;smem_d → out[tile] Global Mem&lt;/td&gt;&lt;td&gt;STSM: FP32 → BF16 + swizzle&lt;br&gt;final_accum → smem_d&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="2025" width="900" height="260" as="geometry" />
        </mxCell>
        <mxCell id="g_skip" value="&lt;font style=&quot;font-size:11px&quot;&gt;&lt;b&gt;-1 Padding 跳过机制 — Warp-Group 粒度 (源码级)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;初始化:&lt;/b&gt; expert_ids = torch.full((M_sum,), fill_value=&lt;font color=&quot;#CC0000&quot;&gt;-1&lt;/font&gt;) ← 全-1&lt;br&gt;&lt;b&gt;Phase 1:&lt;/b&gt; 只对真实token行写入expert id, padding行保持-1&lt;br&gt;&lt;br&gt;&lt;b&gt;Kernel:&lt;/b&gt; is_computation_valid(m_block_idx, &lt;font color=&quot;#CC0000&quot;&gt;math_wg_idx × WGMMA::M&lt;/font&gt;):&lt;br&gt;  WG0: __ldg(grouped_layout + m_block_idx×128 + &lt;b&gt;0&lt;/b&gt;) ≥ 0 ?  ← 检查第0行&lt;br&gt;  WG1: __ldg(grouped_layout + m_block_idx×128 + &lt;b&gt;64&lt;/b&gt;) ≥ 0 ? ← 检查第64行&lt;br&gt;  &lt;font color=&quot;#1565C0&quot;&gt;两个WG独立判断, 可能一个计算一个跳过!&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;2&quot; style=&quot;border-collapse:collapse;font-size:8px&quot;&gt;&lt;tr style=&quot;background:#E8EAF6&quot;&gt;&lt;th&gt;场景&lt;/th&gt;&lt;th&gt;行0-63&lt;/th&gt;&lt;th&gt;行64-127&lt;/th&gt;&lt;th&gt;WG0&lt;/th&gt;&lt;th&gt;WG1&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Expert≥128 tokens&lt;/td&gt;&lt;td&gt;id=e&lt;/td&gt;&lt;td&gt;id=e&lt;/td&gt;&lt;td&gt;计算&lt;/td&gt;&lt;td&gt;计算&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFEBEE&quot;&gt;&lt;td&gt;Expert=50 tokens&lt;/td&gt;&lt;td&gt;id=e&lt;/td&gt;&lt;td&gt;&lt;b&gt;-1&lt;/b&gt;&lt;/td&gt;&lt;td&gt;计算&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#CC0000&quot;&gt;&lt;b&gt;跳过&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;全padding&lt;/td&gt;&lt;td&gt;-1&lt;/td&gt;&lt;td&gt;-1&lt;/td&gt;&lt;td&gt;跳过&lt;/td&gt;&lt;td&gt;跳过&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;b&gt;跳过时:&lt;/b&gt; for k in K/128: barrier.wait() → barrier.arrive() → &lt;font color=&quot;#CC0000&quot;&gt;零计算零写回&lt;/font&gt;&lt;br&gt;&lt;b&gt;TMA无条件加载整个128×128 tile, 不受skip影响&lt;/b&gt;&lt;br&gt;&lt;br&gt;★ 为什么跳过的WG还要wait+arrive? TMA已发起pipeline加载, 必须消费barrier维持同步, 否则死锁&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="2305" width="900" height="295" as="geometry" />
        </mxCell>
        <mxCell id="g_64grain" value="&lt;font style=&quot;font-size:11px&quot;&gt;&lt;b&gt;最小计算单元 = 64 行 (WGMMA::M) — 64 行内无更细粒度跳过&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;br&gt;&lt;b&gt;核心结论: is_computation_valid 只检查 64 行块的首行, 若首行有效则整个 64 行参与 WGMMA, 包括其中的 padding 行&lt;/b&gt;&lt;br&gt;&lt;br&gt;以 Expert 有 50 个真实 token, pad 到 128 行 (1 个 BLOCK_M) 为例:&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;3&quot; style=&quot;border-collapse:collapse;font-size:9px&quot;&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;th&gt;行范围&lt;/th&gt;&lt;th&gt;expert_id&lt;/th&gt;&lt;th&gt;WG&lt;/th&gt;&lt;th&gt;检查点&lt;/th&gt;&lt;th&gt;判定&lt;/th&gt;&lt;th&gt;实际行为&lt;/th&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#C8E6C9&quot;&gt;&lt;td&gt;[0, 49]&lt;/td&gt;&lt;td&gt;e (真实token)&lt;/td&gt;&lt;td rowspan=&quot;2&quot;&gt;WG0&lt;/td&gt;&lt;td rowspan=&quot;2&quot;&gt;row[0]=e ≥ 0&lt;/td&gt;&lt;td rowspan=&quot;2&quot;&gt;&lt;font color=&quot;#2E7D32&quot;&gt;&lt;b&gt;有效&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;有效计算 ✓&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFF9C4&quot;&gt;&lt;td&gt;&lt;b&gt;[50, 63]&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;-1 (padding)&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#E65100&quot;&gt;&lt;b&gt;无效但参与计算 (浪费)&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFCDD2&quot;&gt;&lt;td&gt;[64, 127]&lt;/td&gt;&lt;td&gt;-1 (padding)&lt;/td&gt;&lt;td&gt;WG1&lt;/td&gt;&lt;td&gt;row[64]=-1 &amp;lt; 0&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;跳过&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;零WGMMA, 仅barrier sync&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;b&gt;为什么 64 行内不能更细粒度跳过?&lt;/b&gt;&lt;br&gt;→ WGMMA 指令 SM90_&lt;b&gt;64&lt;/b&gt;x128x32 硬件原子性: 一条指令必须处理 64 行, 无法只算其中一部分&lt;br&gt;&lt;br&gt;&lt;b&gt;正确性保证:&lt;/b&gt;&lt;br&gt;→ padding 行 (50-63) 虽然参与了 WGMMA 计算, 但其输出&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;永远不会被读取&lt;/b&gt;&lt;/font&gt;&lt;br&gt;→ 后续 ep_gather 通过 inv_perm 只读取真实 token 的行, padding 行的结果被丢弃&lt;br&gt;&lt;br&gt;&lt;b&gt;浪费量分析 (per expert, per 128行块):&lt;/b&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;2&quot; style=&quot;border-collapse:collapse;font-size:8px&quot;&gt;&lt;tr style=&quot;background:#ECEFF1&quot;&gt;&lt;th&gt;真实tokens&lt;/th&gt;&lt;th&gt;pad到128行&lt;/th&gt;&lt;th&gt;WG0 (行0-63)&lt;/th&gt;&lt;th&gt;WG1 (行64-127)&lt;/th&gt;&lt;th&gt;浪费行数&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;128&lt;/td&gt;&lt;td&gt;128&lt;/td&gt;&lt;td&gt;64行计算 (全有效)&lt;/td&gt;&lt;td&gt;64行计算 (全有效)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#2E7D32&quot;&gt;&lt;b&gt;0&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;100&lt;/td&gt;&lt;td&gt;128&lt;/td&gt;&lt;td&gt;64行计算 (全有效)&lt;/td&gt;&lt;td&gt;64行计算 (&lt;font color=&quot;#E65100&quot;&gt;28行浪费&lt;/font&gt;)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#E65100&quot;&gt;&lt;b&gt;28&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;65&lt;/td&gt;&lt;td&gt;128&lt;/td&gt;&lt;td&gt;64行计算 (全有效)&lt;/td&gt;&lt;td&gt;64行计算 (&lt;font color=&quot;#E65100&quot;&gt;63行浪费&lt;/font&gt;)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#E65100&quot;&gt;&lt;b&gt;63&lt;/b&gt;&lt;/font&gt; (最坏)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;64&lt;/td&gt;&lt;td&gt;128&lt;/td&gt;&lt;td&gt;64行计算 (全有效)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;跳过 (零计算)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#2E7D32&quot;&gt;&lt;b&gt;0&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;50&lt;/td&gt;&lt;td&gt;128&lt;/td&gt;&lt;td&gt;64行计算 (&lt;font color=&quot;#E65100&quot;&gt;14行浪费&lt;/font&gt;)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;跳过 (零计算)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#E65100&quot;&gt;&lt;b&gt;14&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;128&lt;/td&gt;&lt;td&gt;64行计算 (&lt;font color=&quot;#E65100&quot;&gt;63行浪费&lt;/font&gt;)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;跳过 (零计算)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#E65100&quot;&gt;&lt;b&gt;63&lt;/b&gt;&lt;/font&gt; (最坏)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;★ 最坏情况: 每个128行块最多浪费63行的计算量 (tokens = 64k+1, k=0,1,...)&lt;br&gt;★ ceil_128对齐保证: 每个expert最多1个不满块, 浪费上限 = min(63, pad_rows)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="2630" width="900" height="460" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="parallel-strategy" name="5. 混合并行策略 + 通信量计算详解">
    <mxGraphModel dx="1242" dy="1199" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1600" pageHeight="3200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t5" value="&lt;font style=&quot;font-size:22px&quot;&gt;&lt;b&gt;混合并行策略 + 通信量计算详解&lt;/b&gt;&lt;/font&gt;&lt;br&gt;DP=4 EP=4 | DeepSeek-V3 | 2 Nodes × 2 GPUs | Prefill Stage" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="250" y="-40" width="700" height="50" as="geometry" />
        </mxCell>
        <mxCell id="attn_section" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;strokeWidth=3;" parent="1" vertex="1">
          <mxGeometry x="50" y="30" width="1100" height="200" as="geometry" />
        </mxCell>
        <mxCell id="attn_title" value="&lt;font style=&quot;font-size:16px&quot;&gt;&lt;b&gt;Attention (MLA) — Data Parallel (DP=4, TP=1)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="300" y="35" width="600" height="25" as="geometry" />
        </mxCell>
        <mxCell id="a_gpu0" value="&lt;b&gt;GPU 0&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Attn权重: &lt;font color=&quot;#0000CC&quot;&gt;完整副本&lt;/font&gt;&lt;br&gt;输入: (4096, 7168) 本 rank batch&lt;br&gt;MLA → 输出: (4096, 7168)&lt;br&gt;KV Cache: 本地, 不共享&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="70" y="70" width="170" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a_gpu1" value="&lt;b&gt;GPU 1&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Attn权重: &lt;font color=&quot;#0000CC&quot;&gt;完整副本&lt;/font&gt;&lt;br&gt;输入: (3072, 7168)&lt;br&gt;MLA → 输出&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="260" y="70" width="170" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a_gpu2" value="&lt;b&gt;GPU 2&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Attn权重: &lt;font color=&quot;#0000CC&quot;&gt;完整副本&lt;/font&gt;&lt;br&gt;输入: (2048, 7168)&lt;br&gt;MLA → 输出&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="450" y="70" width="170" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a_gpu3" value="&lt;b&gt;GPU 3&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Attn权重: &lt;font color=&quot;#0000CC&quot;&gt;完整副本&lt;/font&gt;&lt;br&gt;输入: (3500, 7168)&lt;br&gt;MLA → 输出&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="640" y="70" width="170" height="80" as="geometry" />
        </mxCell>
        <mxCell id="dp_props" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Data Parallel 特征:&lt;/b&gt;&lt;br&gt;• 权重: 4×完整副本 (浪费显存)&lt;br&gt;• 数据: 每rank独立batch (无依赖)&lt;br&gt;• 通信: &lt;font color=&quot;#2E7D32&quot;&gt;&lt;b&gt;零 (完全独立)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;• 吞吐: 线性扩展, batch不均匀&lt;br&gt;  时需 dummy token padding 对齐&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;" parent="1" vertex="1">
          <mxGeometry x="840" y="60" width="290" height="100" as="geometry" />
        </mxCell>
        <mxCell id="dp_comm" value="&lt;font color=&quot;#2E7D32&quot; style=&quot;font-size:11px&quot;&gt;&lt;b&gt;通信量 = 0 (每rank完全独立计算, 无 AllReduce/AllGather)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="165" width="700" height="20" as="geometry" />
        </mxCell>
        <mxCell id="dp_note" value="&lt;font style=&quot;font-size:9px&quot; color=&quot;#666666&quot;&gt;注: DP dummy batch 同步仅需标量通信 (几字节), 可忽略。TP=1 时无 AllReduce。&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="185" width="700" height="20" as="geometry" />
        </mxCell>
        <mxCell id="moe_section" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;strokeWidth=3;" parent="1" vertex="1">
          <mxGeometry x="50" y="280" width="1100" height="280" as="geometry" />
        </mxCell>
        <mxCell id="moe_title" value="&lt;font style=&quot;font-size:16px&quot;&gt;&lt;b&gt;Routed Experts — Expert Parallel (EP=4)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="300" y="285" width="600" height="25" as="geometry" />
        </mxCell>
        <mxCell id="m_gpu0" value="&lt;b&gt;GPU 0&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Experts: &lt;font color=&quot;#CC0000&quot;&gt;[0-63]&lt;/font&gt; (1/4)&lt;br&gt;W1: (64, 18432, 7168) FP8&lt;br&gt;W2: (64, 7168, 9216) FP8&lt;br&gt;Gate 权重: 完整副本&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="70" y="320" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="gLSy4Sa-aWWLU9geGOW4-1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="m_gpu1" target="m_gpu0">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m_gpu1" value="&lt;b&gt;GPU 1&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Experts: &lt;font color=&quot;#CC0000&quot;&gt;[64-127]&lt;/font&gt; (1/4)&lt;br&gt;W1,W2: 同结构&lt;br&gt;Gate: 完整副本&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="310" y="320" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m_gpu2" value="&lt;b&gt;GPU 2&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Experts: &lt;font color=&quot;#CC0000&quot;&gt;[128-191]&lt;/font&gt; (1/4)&lt;br&gt;W1,W2: 同结构&lt;br&gt;Gate: 完整副本&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;" parent="1" vertex="1">
