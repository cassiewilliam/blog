        </mxCell>
        <mxCell id="p4-b" value="NVIDIA NVSHMEM lowering&#xa;rank -&gt; nvshmem_my_pe&#xa;num_ranks -&gt; nvshmem_n_pes&#xa;symm_at -&gt; nvshmem_ptr&#xa;wait -&gt; inline PTX polling&#xa;notify -&gt; remote store / signal_op" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="430" y="150" width="330" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p4-c" value="AMD SHMEM lowering&#xa;ROCSHMEM / MORI wrapper&#xa;rank / n_pes / ptr wrapper&#xa;wait -&gt; atomic load loop + barrier&#xa;notify 覆盖度需按源码确认" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="430" y="440" width="330" height="180" as="geometry" />
