<mxfile host="app.diagrams.net" agent="svg2drawio" version="22.0.0">
  <diagram id="conv" name="Page-1">
    <mxGraphModel dx="1100" dy="340" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="340" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="v2" value="" style="rounded=0;fillColor=#fff;strokeColor=none;html=1;" vertex="1" parent="1"><mxGeometry x="0.0" y="0.0" width="1100.0" height="340.0" as="geometry"/></mxCell><mxCell id="v3" value="Tensor-level Activation Checkpointing · TorchFX 追踪 + 最小重算子图" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="257.5" y="6.84" width="585" height="22" as="geometry"/></mxCell><mxCell id="v4" value="" style="rounded=1;arcSize=5;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="30.0" y="50.0" width="510.0" height="270.0" as="geometry"/></mxCell><mxCell id="v5" value="Conventional (per-module)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="184.5" y="57.96" width="201" height="18" as="geometry"/></mxCell><mxCell id="v6" value="• granularity : entire nn.Module" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="84.3" width="218" height="15" as="geometry"/></mxCell><mxCell id="v7" value="• coarse tradeoff : retain all outputs OR recompute all" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="102.3" width="375" height="15" as="geometry"/></mxCell><mxCell id="v8" value="• can't preserve cheap-but-used tensors while dropping expensive ones" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="120.3" width="470" height="15" as="geometry"/></mxCell><mxCell id="v9" value="Manual alternative:" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="142.3" width="129" height="15" as="geometry"/></mxCell><mxCell id="v10" value="• hand-write fwd + bwd for each layer" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="160.3" width="252" height="15" as="geometry"/></mxCell><mxCell id="v11" value="• fine-grained but loses autograd ergonomics" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="178.3" width="300" height="15" as="geometry"/></mxCell><mxCell id="v12" value="• error-prone, hard to maintain under arch iterations" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="196.3" width="361" height="15" as="geometry"/></mxCell><mxCell id="v13" value="→ V4 has dozens of custom ops (mHC, compressor, indexer, fused ops)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#b85450;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="45.0" y="236.3" width="456" height="15" as="geometry"/></mxCell><mxCell id="v14" value="→ neither extreme is practical at the architecture's complexity" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#b85450;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="45.0" y="254.3" width="429" height="15" as="geometry"/></mxCell><mxCell id="v15" value="✘ 粗：每层要么全存要么全重算" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="45.0" y="280.3" width="102" height="15" as="geometry"/></mxCell><mxCell id="v16" value="✘ 手写：放弃自动微分便利" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="45.0" y="298.3" width="88" height="15" as="geometry"/></mxCell><mxCell id="v17" value="" style="rounded=1;arcSize=5;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="570.0" y="50.0" width="500.0" height="270.0" as="geometry"/></mxCell><mxCell id="v18" value="V4: tensor-level annotation + TorchFX" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="671.0" y="57.96" width="298" height="18" as="geometry"/></mxCell><mxCell id="v19" value="developer flow:" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="84.3" width="102" height="15" as="geometry"/></mxCell><mxCell id="v20" value="1. write forward as usual (PyTorch)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="102.3" width="238" height="15" as="geometry"/></mxCell><mxCell id="v21" value="2. annotate target tensors for checkpointing" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="120.3" width="300" height="15" as="geometry"/></mxCell><mxCell id="v22" value="framework then:" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="138.3" width="102" height="15" as="geometry"/></mxCell><mxCell id="v23" value="3. TorchFX concrete trace of full graph" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="156.3" width="265" height="15" as="geometry"/></mxCell><mxCell id="v24" value="4. backward walk → minimal recomputation subgraph" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="174.3" width="334" height="15" as="geometry"/></mxCell><mxCell id="v25" value="5. insert recomputation just before matching grad calc" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="192.3" width="368" height="15" as="geometry"/></mxCell><mxCell id="v26" value="runtime:" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="214.3" width="54" height="15" as="geometry"/></mxCell><mxCell id="v27" value="• free annotated tensor's memory" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="232.3" width="218" height="15" as="geometry"/></mxCell><mxCell id="v28" value="• reuse original storage pointer (no memcpy)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="250.3" width="300" height="15" as="geometry"/></mxCell><mxCell id="v29" value="• track storage pointers → dedup reshape-like aliases" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="268.3" width="361" height="15" as="geometry"/></mxCell><mxCell id="v30" value="✔ zero runtime overhead vs hand-written · full autograd ergonomics" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a3d1a;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="585.0" y="292.3" width="450" height="15" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
