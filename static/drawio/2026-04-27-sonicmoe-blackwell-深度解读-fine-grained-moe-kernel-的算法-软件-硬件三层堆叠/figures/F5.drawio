        <mxCell id="d_1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontFamily=Times New Roman;fontSize=50;" value="&lt;font style=&quot;font-size: 50px;&quot;&gt;&lt;b&gt;SonicMoE optimization map from router to HBM&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="60" width="1140" x="30" y="10" as="geometry" />
        </mxCell>
        <mxCell id="d_2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=16;" value="&lt;b&gt;Router / routing&lt;br&gt;&lt;/b&gt;&lt;br&gt;top-K sorting kernel&lt;br&gt;top-K softmax fusion&lt;br&gt;token rounding TR&lt;br&gt;custom router interface" vertex="1">
          <mxGeometry height="150" width="205" x="10" y="100" as="geometry" />
        </mxCell>
        <mxCell id="d_3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=16;" value="&lt;b&gt;GMEM → SMEM load&lt;br&gt;&lt;/b&gt;&lt;br&gt;gather fusion on M dim&lt;br&gt;gather fusion on K dim&lt;br&gt;cp.async / TMA gather4&lt;br&gt;relay warp for 2CTA gather" vertex="1">
          <mxGeometry height="150" width="205" x="240" y="100" as="geometry" />
        </mxCell>
        <mxCell id="d_4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=16;" value="&lt;b&gt;Grouped GEMM mainloop&lt;br&gt;&lt;/b&gt;&lt;br&gt;varlen-M / varlen-K kernels&lt;br&gt;Ping-Pong scheduling on Hopper&lt;br&gt;UMMA + TMEM on Blackwell&lt;br&gt;2CTA MMA + CLC scheduler" vertex="1">
          <mxGeometry height="150" width="225" x="470" y="100" as="geometry" />
        </mxCell>
        <mxCell id="d_5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=16;" value="&lt;b&gt;Epilogue fusion&lt;br&gt;&lt;/b&gt;&lt;br&gt;SwiGLU / dSwiGLU&lt;br&gt;dH + dS + A_S outputs&lt;br&gt;async TMA load of H&lt;br&gt;async TMA store for heavy stores" vertex="1">
          <mxGeometry height="150" width="205" x="720" y="100" as="geometry" />
        </mxCell>
        <mxCell id="d_6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=16;" value="&lt;b&gt;Output / aggregation&lt;br&gt;&lt;/b&gt;&lt;br&gt;keep transient Y recyclable&lt;br&gt;gather-and-sum aggregation&lt;br&gt;avoid atomic scatter&lt;br&gt;avoid sync st.global scatter fusion" vertex="1">
          <mxGeometry height="150" width="205" x="950" y="100" as="geometry" />
        </mxCell>
