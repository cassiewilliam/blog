5.08" width="208" height="14" as="geometry"/></mxCell><mxCell id="v71" value="– wave 内若有 100 个 packet ⇒ 50 – 100 μs overhead" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#7a2f2b;" vertex="1" parent="1"><mxGeometry x="600.0" y="325.08" width="299" height="14" as="geometry"/></mxCell><mxCell id="v72" value="+ 未来若 signaling &lt; 100 ns，push 重新可用" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#1a3d1a;" vertex="1" parent="1"><mxGeometry x="600.0" y="345.08" width="221" height="14" as="geometry"/></mxCell><mxCell id="v73" value="总开销 ≈ N · doorbell 延迟（&gt;&gt; pull）" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#7a2f2b;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="600.0" y="368.3" width="204" height="15" as="geometry"/></mxCell><mxCell id="v74" value="论文 §3.1 ③：硬件若把 cross-GPU signaling 做到亚 100 ns，push 模式将允许更细粒度的 wave overlap，逼近 1.92× 理论上限。" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#6b7280;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="260.5" y="419.08" width="579" height="14" as="geometry"/></mxCell><mxCell id="v75" value="绿色 = 数据传输；紫色 = 通知 / signaling；橙色 = barrier；蓝色 = 接收端处理" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#6b7280;" vertex="1" parent="1"><mxGeometry x="377.5" y="437.08" width="345" height="14" as="geometry"/></mxCell>
