        <mxCell id="d_11" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;strokeWidth=1.5;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=14;" value="&lt;b&gt;Router overhead&lt;br&gt;&lt;/b&gt;&lt;br&gt;torch.topk can be ~40% of router time; generic top-K becomes visible after compute kernels get faster." vertex="1">
          <mxGeometry height="115" width="205" x="10" y="310" as="geometry" />
        </mxCell>
        <mxCell id="d_12" edge="1" parent="1" source="d_2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;endArrow=block;html=1;rounded=1;" target="d_11">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d_13" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;strokeWidth=1.5;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=14;" value="&lt;b&gt;HBM traffic&lt;br&gt;&lt;/b&gt;&lt;br&gt;Separate gather/pad materializes O(TKd) buffers; fused load keeps source tensor compact and L2-friendly." vertex="1">
          <mxGeometry height="115" width="205" x="240" y="310" as="geometry" />
        </mxCell>
        <mxCell id="d_14" edge="1" parent="1" source="d_3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;endArrow=block;html=1;rounded=1;" target="d_13">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d_15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;strokeWidth=1.5;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=14;" value="&lt;b&gt;Small GEMM tiles&lt;br&gt;&lt;/b&gt;&lt;br&gt;Fine-grained experts reduce arithmetic intensity; persistent scheduling and tile sharing keep SMs busy." vertex="1">
          <mxGeometry height="115" width="205" x="480" y="310" as="geometry" />
        </mxCell>
        <mxCell id="d_16" edge="1" parent="1" source="d_4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;endArrow=block;html=1;rounded=1;" target="d_15">
