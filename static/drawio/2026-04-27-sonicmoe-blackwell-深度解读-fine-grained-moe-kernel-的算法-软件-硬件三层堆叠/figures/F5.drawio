        </mxCell>
        <mxCell id="d_17" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;strokeWidth=1.5;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=14;" value="&lt;b&gt;Heavy epilogue&lt;br&gt;&lt;/b&gt;&lt;br&gt;dSwiGLU/reduction/multi-output store would stall MMA unless overlapped with async IO." vertex="1">
          <mxGeometry height="115" width="205" x="720" y="310" as="geometry" />
        </mxCell>
        <mxCell id="d_18" edge="1" parent="1" source="d_5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;endArrow=block;html=1;rounded=1;" target="d_17">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d_19" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;strokeWidth=1.5;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=14;" value="&lt;b&gt;Aggregation choice&lt;br&gt;&lt;/b&gt;&lt;br&gt;Scatter fusion looks attractive but hurts determinism/BF16 atomic/all2all and may block next MMA tile." vertex="1">
          <mxGeometry height="115" width="205" x="950" y="310" as="geometry" />
        </mxCell>
        <mxCell id="d_20" edge="1" parent="1" source="d_6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;endArrow=block;html=1;rounded=1;" target="d_19">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d_21" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;strokeWidth=1.5;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=14;" value="&lt;b&gt;Design rule:&lt;/b&gt; optimize the whole MoE workflow, not just one GEMM. SonicMoE wins by deciding what never materializes, what fuses into load/epilogue, what overlaps with MMA, and what remains as a separate memory-bound kernel." vertex="1">
