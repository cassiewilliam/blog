        <mxCell id="v2" value="" style="rounded=0;fillColor=#fff;strokeColor=none;html=1;" vertex="1" parent="1"><mxGeometry x="0.0" y="0.0" width="1100.0" height="420.0" as="geometry"/></mxCell><mxCell id="v3" value="DeepSeekMoE 在 V4 中的路由策略 · Hash (first 3 MoE layers) + Learned (rest)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="213.0" y="6.84" width="674" height="22" as="geometry"/></mxCell><mxCell id="v4" value="" style="rounded=1;arcSize=5;fillColor=#eef3ff;strokeColor=#4a6fd3;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="30.0" y="56.0" width="510.0" height="200.0" as="geometry"/></mxCell><mxCell id="v5" value="Layers 0–2 · Hash routing (zero parameter, deterministic)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="55.5" y="63.96" width="459" height="18" as="geometry"/></mxCell><mxCell id="v6" value="expert_id = hash(token_id) % n_routed_experts" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="90.3" width="306" height="15" as="geometry"/></mxCell><mxCell id="v7" value="gating_score = fixed (no learned weights)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="108.3" width="279" height="15" as="geometry"/></mxCell><mxCell id="v8" value="• no cold-start for router (starts balanced)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="132.3" width="300" height="15" as="geometry"/></mxCell><mxCell id="v9" value="• deterministic per-token assignment" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="150.3" width="245" height="15" as="geometry"/></mxCell><mxCell id="v10" value="• early layers capture lexical features — learned" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="168.3" width="334" height="15" as="geometry"/></mxCell><mxCell id="v11" value="routing gives little benefit here anyway" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="186.3" width="272" height="15" as="geometry"/></mxCell><mxCell id="v12" value="→ replaces dense FFN from V3 and learned-router MoE" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a3a5c;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="45.0" y="212.3" width="347" height="15" as="geometry"/></mxCell><mxCell id="v13" value="→ saves training compute; Hash outputs one-hot mask" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a3a5c;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="45.0" y="230.3" width="347" height="15" as="geometry"/></mxCell><mxCell id="v14" value="" style="rounded=1;arcSize=5;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="570.0" y="56.0" width="500.0" height="200.0" as="geometry"/></mxCell><mxCell id="v15" value="Layers 3+ · Learned router (DeepSeekMoE)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="659.0" y="63.96" width="322" height="18" as="geometry"/></mxCell><mxCell id="v16" value="score_ij = Sqrt(Softplus(hidden_i · W_gate_j))" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="90.3" width="313" height="15" as="geometry"/></mxCell><mxCell id="v17" value="top-6 routing · 1 shared + 256/384 routed experts" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="108.3" width="334" height="15" as="geometry"/></mxCell><mxCell id="v18" value="load balancing: auxiliary-loss-free (bias adjustment)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="132.3" width="361" height="15" as="geometry"/></mxCell><mxCell id="v19" value="+ sequence-wise balance loss (w = 1e-4)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="150.3" width="265" height="15" as="geometry"/></mxCell><mxCell id="v20" value="no constraint on # target nodes (V3 had a cap)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="168.3" width="313" height="15" as="geometry"/></mxCell><mxCell id="v21" value="parallelism strategy redesigned for removed cap" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="186.3" width="320" height="15" as="geometry"/></mxCell><mxCell id="v22" value="→ Sqrt(Softplus) vs Sigmoid: sharper gradient near 0," style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a3d1a;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="585.0" y="212.3" width="361" height="15" as="geometry"/></mxCell><mxCell id="v23" value="compressed tail for stability" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a3d1a;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="585.0" y="230.3" width="197" height="15" as="geometry"/></mxCell><mxCell id="v24" value="" style="rounded=1;arcSize=5;fillColor=#fff4e0;strokeColor=#e0b300;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="30.0" y="276.0" width="1040.0" height="130.0" as="geometry"/></mxCell><mxCell id="v25" value="Multi-Token Prediction (MTP) · unchanged from V3" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="357.0" y="283.96" width="386" height="18" as="geometry"/></mxCell><mxCell id="v26" value="depth = 1 (one draft token per step)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="310.3" width="245" height="15" as="geometry"/></mxCell><mxCell id="v27" value="loss weight: 0.3 during most of training, dropped to 0.1 near LR decay" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="328.3" width="477" height="15" as="geometry"/></mxCell><mxCell id="v28" value="input: main model's last hidden → MTP decoder layer (same mHC + attention + MoE block shape)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="346.3" width="627" height="15" as="geometry"/></mxCell><mxCell id="v29" value="output: predict next-next token → used as speculative draft at inference" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="366.3" width="491" height="15" as="geometry"/></mxCell><mxCell id="v30" value="reuse of same block shape = MTP shares tile_scheduler metadata with main decode at inference" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#7a4e00;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="386.3" width="627" height="15" as="geometry"/></mxCell>
