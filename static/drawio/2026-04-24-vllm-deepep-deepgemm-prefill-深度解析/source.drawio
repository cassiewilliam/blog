        <mxCell id="rdma_lab" value="&lt;font color=&quot;#C62828&quot; style=&quot;font-size:9px&quot;&gt;&lt;b&gt;RDMA (跨节点)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="240" y="430" width="190" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ep_props" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Expert Parallel 特征:&lt;/b&gt;&lt;br&gt;• 权重: 256 experts / 4 = 64/GPU&lt;br&gt;  显存节省 75% (Expert 权重部分)&lt;br&gt;• 通信: &lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;4-way All2All × 2&lt;/b&gt;&lt;/font&gt;&lt;br&gt;  (Dispatch + Combine)&lt;br&gt;• 路由: Gate(DP) → topk → EP All2All&lt;br&gt;• SM分配: 20 SMs 通信, 112 SMs 计算&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;" parent="1" vertex="1">
          <mxGeometry x="840" y="305" width="290" height="110" as="geometry" />
        </mxCell>
        <mxCell id="ep_comm" value="&lt;font color=&quot;#C62828&quot; style=&quot;font-size:11px&quot;&gt;&lt;b&gt;通信量 ≈ 1.07 GB/层/rank (Dispatch FP8 + Combine BF16, 双向)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="105" y="490" width="705" height="20" as="geometry" />
        </mxCell>
        <mxCell id="ep_note" value="&lt;font style=&quot;font-size:9px&quot; color=&quot;#666666&quot;&gt;NVLink 通信: ~176 MB 双向 (可忽略) | RDMA 通信: ~704 MB 双向 (★ 主要瓶颈 ★) | RDMA 占跨 rank 通信的 2/3&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="180" y="530" width="800" height="20" as="geometry" />
        </mxCell>
        <mxCell id="shared_section" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;strokeWidth=3;" parent="1" vertex="1">
          <mxGeometry x="50" y="590" width="1100" height="160" as="geometry" />
        </mxCell>
        <mxCell id="shared_title" value="&lt;font style=&quot;font-size:16px&quot;&gt;&lt;b&gt;Shared Expert — Data Parallel + Combine Overlap&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="300" y="595" width="600" height="25" as="geometry" />
        </mxCell>
        <mxCell id="shared_detail" value="&lt;font style=&quot;font-size:10px&quot;&gt;权重: 4×完整副本 | 通信: &lt;font color=&quot;#2E7D32&quot;&gt;&lt;b&gt;零&lt;/b&gt;&lt;/font&gt; | 每 rank 独立对自己 batch 的 hidden_states 做 MLP (W_shared)&lt;br&gt;&lt;br&gt;&lt;b&gt;双 Stream 并行:&lt;/b&gt;&lt;br&gt;Compute Stream: [Gate+Router] → [FP8 Quant] → [DeepGEMM Expert Compute] → &lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;[Shared Expert MLP]&lt;/b&gt;&lt;/font&gt; → [等待Combine] → [Residual Add]&lt;br&gt;Comm Stream:    ─────────────→ [Dispatch All2All] ──────────────────────→ [Combine All2All] ─→ [完成]&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#2E7D32&quot;&gt;★ Shared Expert 在 Compute Stream 上与 Combine 的 Comm Stream 并行执行, 可隐藏部分 RDMA 延迟&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;" vertex="1" parent="1">
          <mxGeometry x="70" y="640" width="1060" height="70" as="geometry" />
        </mxCell>
        <mxCell id="comm_calc_title" value="&lt;font style=&quot;font-size:18px&quot;&gt;&lt;b&gt;单层 MoE 通信量详细计算&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;M=4096 tokens, H=7168, TopK=8, EP=4, 256 experts, 2 Nodes × 2 GPUs&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="250" y="750" width="700" height="40" as="geometry" />
        </mxCell>
        <mxCell id="calc_params" value="&lt;font style=&quot;font-size:12px&quot;&gt;&lt;b&gt;基础参数推导&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;Token-Expert 条目总数:&lt;/b&gt; M × TopK = 4096 × 8 = &lt;b&gt;32,768&lt;/b&gt; 条&lt;br&gt;&lt;b&gt;每 expert 平均 tokens:&lt;/b&gt; 32768 / 256 = &lt;b&gt;128&lt;/b&gt; tokens/expert&lt;br&gt;&lt;b&gt;每 rank 本地 experts:&lt;/b&gt; 256 / 4 = &lt;b&gt;64&lt;/b&gt; experts (experts [0-63] on GPU 0)&lt;br&gt;&lt;b&gt;本地保留比例:&lt;/b&gt; 64 / 256 = &lt;b&gt;25%&lt;/b&gt; (约 8192 条留在本地)&lt;br&gt;&lt;b&gt;需要发送比例:&lt;/b&gt; 75% (约 24576 条需要通过 All2All 发出)&lt;br&gt;&lt;br&gt;&lt;b&gt;通信路径分布 (GPU 0 视角):&lt;/b&gt;&lt;br&gt;  → GPU 0 (本地): 25% → 无通信&lt;br&gt;  → GPU 1 (同 Node): 25% → &lt;font color=&quot;#1565C0&quot;&gt;&lt;b&gt;NVLink&lt;/b&gt;&lt;/font&gt;&lt;br&gt;  → GPU 2 (跨 Node): 25% → &lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;RDMA&lt;/b&gt;&lt;/font&gt;&lt;br&gt;  → GPU 3 (跨 Node): 25% → &lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;RDMA&lt;/b&gt;&lt;/font&gt;&lt;br&gt;  NVLink 占跨 rank 通信: 1/3 | RDMA 占跨 rank 通信: &lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;2/3&lt;/b&gt;&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="800" width="540" height="280" as="geometry" />
        </mxCell>
        <mxCell id="calc_pertoken" value="&lt;font style=&quot;font-size:12px&quot;&gt;&lt;b&gt;每 Token 数据量&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;Dispatch (FP8 + 元数据):&lt;/b&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;2&quot; style=&quot;border-collapse:collapse;font-size:9px&quot;&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;th&gt;数据&lt;/th&gt;&lt;th&gt;Shape&lt;/th&gt;&lt;th&gt;Dtype&lt;/th&gt;&lt;th&gt;大小&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Token 激活值&lt;/td&gt;&lt;td&gt;(7168,)&lt;/td&gt;&lt;td&gt;FP8 (1B)&lt;/td&gt;&lt;td&gt;7,168 B&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Block scales&lt;/td&gt;&lt;td&gt;(56,)&lt;/td&gt;&lt;td&gt;FP32 (4B)&lt;/td&gt;&lt;td&gt;224 B&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;topk_id&lt;/td&gt;&lt;td&gt;(1,)&lt;/td&gt;&lt;td&gt;int64 (8B)&lt;/td&gt;&lt;td&gt;8 B&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;topk_weight&lt;/td&gt;&lt;td&gt;(1,)&lt;/td&gt;&lt;td&gt;FP32 (4B)&lt;/td&gt;&lt;td&gt;4 B&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#BBDEFB&quot;&gt;&lt;td&gt;&lt;b&gt;合计&lt;/b&gt;&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;&lt;b&gt;~7.4 KB&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;b&gt;Combine (BF16, 无元数据):&lt;/b&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;2&quot; style=&quot;border-collapse:collapse;font-size:9px&quot;&gt;&lt;tr style=&quot;background:#E8F5E9&quot;&gt;&lt;th&gt;数据&lt;/th&gt;&lt;th&gt;Shape&lt;/th&gt;&lt;th&gt;Dtype&lt;/th&gt;&lt;th&gt;大小&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Expert 输出&lt;/td&gt;&lt;td&gt;(7168,)&lt;/td&gt;&lt;td&gt;BF16 (2B)&lt;/td&gt;&lt;td&gt;14,336 B&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#C8E6C9&quot;&gt;&lt;td&gt;&lt;b&gt;合计&lt;/b&gt;&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;&lt;b&gt;~14 KB&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;font color=&quot;#C62828&quot;&gt;Combine/token ≈ 2× Dispatch/token&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#424242;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="610" y="800" width="540" height="280" as="geometry" />
        </mxCell>
        <mxCell id="calc_total" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;单层单 Rank 通信量汇总 (GPU 0 视角, 双向)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#1565C0;color:#fff&quot;&gt;&lt;th&gt;目标&lt;/th&gt;&lt;th&gt;链路&lt;/th&gt;&lt;th&gt;带宽&lt;/th&gt;&lt;th&gt;条目数&lt;/th&gt;&lt;th&gt;Dispatch发(FP8)&lt;/th&gt;&lt;th&gt;Dispatch收(FP8)&lt;/th&gt;&lt;th&gt;Combine发(BF16)&lt;/th&gt;&lt;th&gt;Combine收(BF16)&lt;/th&gt;&lt;th&gt;双向合计&lt;/th&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#C8E6C9&quot;&gt;&lt;td&gt;GPU 0 (本地)&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;~8192&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#2E7D32&quot;&gt;&lt;b&gt;0&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#BBDEFB&quot;&gt;&lt;td&gt;GPU 1 (同Node)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#1565C0&quot;&gt;&lt;b&gt;NVLink&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;~450 GB/s&lt;/td&gt;&lt;td&gt;~8192&lt;/td&gt;&lt;td&gt;~59 MB&lt;/td&gt;&lt;td&gt;~59 MB&lt;/td&gt;&lt;td&gt;~117 MB&lt;/td&gt;&lt;td&gt;~117 MB&lt;/td&gt;&lt;td&gt;&lt;b&gt;~352 MB&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFCDD2&quot;&gt;&lt;td&gt;GPU 2 (跨Node)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;RDMA&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;~50 GB/s&lt;/td&gt;&lt;td&gt;~8192&lt;/td&gt;&lt;td&gt;~59 MB&lt;/td&gt;&lt;td&gt;~59 MB&lt;/td&gt;&lt;td&gt;~117 MB&lt;/td&gt;&lt;td&gt;~117 MB&lt;/td&gt;&lt;td&gt;&lt;b&gt;~352 MB&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFCDD2&quot;&gt;&lt;td&gt;GPU 3 (跨Node)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;RDMA&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;~50 GB/s&lt;/td&gt;&lt;td&gt;~8192&lt;/td&gt;&lt;td&gt;~59 MB&lt;/td&gt;&lt;td&gt;~59 MB&lt;/td&gt;&lt;td&gt;~117 MB&lt;/td&gt;&lt;td&gt;~117 MB&lt;/td&gt;&lt;td&gt;&lt;b&gt;~352 MB&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E0E0E0&quot;&gt;&lt;td colspan=&quot;4&quot;&gt;&lt;b&gt;NVLink 合计&lt;/b&gt;&lt;/td&gt;&lt;td colspan=&quot;2&quot;&gt;~118 MB (D 双向)&lt;/td&gt;&lt;td colspan=&quot;2&quot;&gt;~234 MB (C 双向)&lt;/td&gt;&lt;td&gt;&lt;b&gt;~352 MB&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFEBEE&quot;&gt;&lt;td colspan=&quot;4&quot;&gt;&lt;b&gt;RDMA 合计&lt;/b&gt;&lt;/td&gt;&lt;td colspan=&quot;2&quot;&gt;~236 MB (D 双向)&lt;/td&gt;&lt;td colspan=&quot;2&quot;&gt;~468 MB (C 双向)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;~704 MB ★&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#263238;color:#fff&quot;&gt;&lt;td colspan=&quot;4&quot;&gt;&lt;b&gt;单层总计&lt;/b&gt;&lt;/td&gt;&lt;td colspan=&quot;2&quot;&gt;~354 MB&lt;/td&gt;&lt;td colspan=&quot;2&quot;&gt;~702 MB&lt;/td&gt;&lt;td&gt;&lt;b&gt;~1056 MB&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;计算: 8192 条 × 7.4 KB ≈ 59 MB (Dispatch 单向/rank) | 8192 × 14 KB ≈ 117 MB (Combine 单向/rank)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#424242;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="1110" width="1100" height="280" as="geometry" />
        </mxCell>
        <mxCell id="latency_title" value="&lt;font style=&quot;font-size:18px&quot;&gt;&lt;b&gt;通信延迟分析&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="400" y="1420" width="400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="latency_table" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#1565C0;color:#fff&quot;&gt;&lt;th&gt;阶段&lt;/th&gt;&lt;th&gt;NVLink 数据量&lt;/th&gt;&lt;th&gt;NVLink 延迟&lt;/th&gt;&lt;th&gt;RDMA 数据量&lt;/th&gt;&lt;th&gt;RDMA 延迟&lt;/th&gt;&lt;th&gt;实际延迟 (并行)&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;Dispatch (FP8)&lt;/b&gt;&lt;/td&gt;&lt;td&gt;59 MB 单向&lt;/td&gt;&lt;td&gt;59/225≈&lt;b&gt;0.26 ms&lt;/b&gt;&lt;/td&gt;&lt;td&gt;118 MB 单向 (2 ranks)&lt;/td&gt;&lt;td&gt;118/25≈&lt;b&gt;4.72 ms&lt;/b&gt;&lt;/td&gt;&lt;td&gt;max(NVL,RDMA)≈&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;4.72 ms&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;&lt;b&gt;Combine (BF16)&lt;/b&gt;&lt;/td&gt;&lt;td&gt;117 MB 单向&lt;/td&gt;&lt;td&gt;117/225≈&lt;b&gt;0.52 ms&lt;/b&gt;&lt;/td&gt;&lt;td&gt;234 MB 单向 (2 ranks)&lt;/td&gt;&lt;td&gt;234/25≈&lt;b&gt;9.36 ms&lt;/b&gt;&lt;/td&gt;&lt;td&gt;max(NVL,RDMA)≈&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;9.36 ms&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFEBEE&quot;&gt;&lt;td&gt;&lt;b&gt;单层合计&lt;/b&gt;&lt;/td&gt;&lt;td&gt;176 MB&lt;/td&gt;&lt;td&gt;&lt;b&gt;0.78 ms&lt;/b&gt;&lt;/td&gt;&lt;td&gt;352 MB&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;14.08 ms&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;~14.1 ms (RDMA 主导)&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot; color=&quot;#666666&quot;&gt;注: 单向有效带宽取半双工 — NVLink ~225 GB/s, RDMA ~25 GB/s (共享 IB 端口, 2 remote ranks 分摊)&lt;br&gt;NVLink 和 RDMA 并行执行, 总延迟 ≈ max(NVLink, RDMA) = RDMA 延迟&lt;br&gt;Combine RDMA 延迟是 Dispatch 的 2 倍: BF16 (2B) vs FP8 (1B)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="1460" width="1100" height="190" as="geometry" />
        </mxCell>
        <mxCell id="fullmodel_title" value="&lt;font style=&quot;font-size:18px&quot;&gt;&lt;b&gt;全模型 Prefill 通信开销 (DeepSeek-V3, 60 MoE 层)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="250" y="1680" width="700" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fullmodel_table" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#263238;color:#fff&quot;&gt;&lt;th&gt;指标&lt;/th&gt;&lt;th&gt;NVLink 部分&lt;/th&gt;&lt;th&gt;RDMA 部分&lt;/th&gt;&lt;th&gt;合计&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;60 层 RDMA 通信总量&lt;/b&gt;&lt;/td&gt;&lt;td&gt;60 × 352 MB = &lt;b&gt;20.6 GB&lt;/b&gt;&lt;/td&gt;&lt;td&gt;60 × 704 MB = &lt;b&gt;41.2 GB&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;~61.8 GB&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;&lt;b&gt;60 层理论通信时间&lt;/b&gt;&lt;/td&gt;&lt;td&gt;60 × 0.78 ms = &lt;b&gt;47 ms&lt;/b&gt;&lt;/td&gt;&lt;td&gt;60 × 14.08 ms = &lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;845 ms&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;~845 ms&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;vs 单节点 EP=4 (全 NVLink)&lt;/b&gt;&lt;/td&gt;&lt;td colspan=&quot;2&quot;&gt;60 × 1.04 GB / 450 GB/s ≈ 139 ms&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;双节点 ~6× 慢&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#546E7A;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="1720" width="1100" height="130" as="geometry" />
        </mxCell>
        <mxCell id="dbo_detail" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;DBO (Dual Batch Overlap) 并行优化&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;原理:&lt;/b&gt; 将 batch 分为 2 个 micro-batch (ubatch), 通信与计算交替重叠&lt;br&gt;&lt;br&gt;&lt;b&gt;时序示意 (单层):&lt;/b&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;3&quot; style=&quot;border-collapse:collapse;font-size:9px&quot;&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;th&gt;时间段&lt;/th&gt;&lt;th&gt;Compute Stream (112 SMs)&lt;/th&gt;&lt;th&gt;Comm Stream (20 SMs)&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;T0&lt;/td&gt;&lt;td&gt;Gate+Quant (ubatch 0)&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;T1&lt;/td&gt;&lt;td&gt;Gate+Quant (ubatch 1)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#0050ef&quot;&gt;Dispatch ubatch 0&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;T2&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#a20025&quot;&gt;DeepGEMM (ubatch 0)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#0050ef&quot;&gt;Dispatch ubatch 1&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;T3&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#a20025&quot;&gt;DeepGEMM (ubatch 1)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#0050ef&quot;&gt;Combine ubatch 0&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;T4&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;Shared Expert (ubatch 0)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#0050ef&quot;&gt;Combine ubatch 1&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;T5&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;Shared Expert (ubatch 1)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;(drain)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;b&gt;效果:&lt;/b&gt;&lt;br&gt;• Dispatch 通信与前一 ubatch 的 Gate 计算重叠&lt;br&gt;• Combine 通信与 DeepGEMM 计算重叠&lt;br&gt;• Shared Expert 与 Combine drain 重叠&lt;br&gt;• &lt;font color=&quot;#2E7D32&quot;&gt;&lt;b&gt;理论上可隐藏 ~50% RDMA 延迟, 实际因依赖链降为 30-40%&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;代码入口:&lt;/b&gt; dbo_yield(), dbo_switch_from_compute_to_comm(), dbo_current_ubatch_id()&lt;br&gt;&lt;b&gt;handle 隔离:&lt;/b&gt; self.handles = [None, None] — 每个 ubatch 独立 handle, 避免竞争&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="1880" width="1100" height="370" as="geometry" />
        </mxCell>
        <mxCell id="opt_strategies" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;优化策略总结&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;3&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#2E7D32;color:#fff&quot;&gt;&lt;th&gt;策略&lt;/th&gt;&lt;th&gt;原理&lt;/th&gt;&lt;th&gt;效果&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;Dispatch FP8&lt;/b&gt;&lt;/td&gt;&lt;td&gt;通信 FP8 (1B) 而非 BF16 (2B)&lt;/td&gt;&lt;td&gt;Dispatch RDMA 数据量减半, 延迟减半&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;&lt;b&gt;DBO&lt;/b&gt;&lt;/td&gt;&lt;td&gt;2 micro-batch 通信/计算交替&lt;/td&gt;&lt;td&gt;隐藏 30-50% RDMA 延迟&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;NVLink+RDMA 双通路&lt;/b&gt;&lt;/td&gt;&lt;td&gt;节点内 NVLink, 跨节点 RDMA 并行&lt;/td&gt;&lt;td&gt;延迟 = max(NVL, RDMA) 而非串行和&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#F5F5F5&quot;&gt;&lt;td&gt;&lt;b&gt;Shared Expert Overlap&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Shared Expert 在 compute stream 与 Combine 在 comm stream 并行&lt;/td&gt;&lt;td&gt;Shared Expert 延迟可部分隐藏&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;增大 batch&lt;/b&gt;&lt;/td&gt;&lt;td&gt;提高计算/通信比&lt;/td&gt;&lt;td&gt;更好 amortize RDMA 固定开销&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFEBEE&quot;&gt;&lt;td&gt;&lt;b&gt;拓扑优化&lt;/b&gt;&lt;/td&gt;&lt;td&gt;DP=2 EP=2/Node + PP=2 跨 Node&lt;/td&gt;&lt;td&gt;避免 MoE 层跨节点 All2All (根本解决)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="2280" width="1100" height="200" as="geometry" />
        </mxCell>
        <mxCell id="summary_table" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;混合并行策略总结&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#263238;color:#fff&quot;&gt;&lt;th&gt;子模块&lt;/th&gt;&lt;th&gt;并行策略&lt;/th&gt;&lt;th&gt;权重存储&lt;/th&gt;&lt;th&gt;通信类型&lt;/th&gt;&lt;th&gt;通信量/层/rank&lt;/th&gt;&lt;th&gt;延迟/层&lt;/th&gt;&lt;th&gt;Stream&lt;/th&gt;&lt;th&gt;瓶颈&lt;/th&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFF8E1&quot;&gt;&lt;td&gt;&lt;b&gt;Attention (MLA)&lt;/b&gt;&lt;/td&gt;&lt;td&gt;DP=4&lt;/td&gt;&lt;td&gt;4 × 完整副本&lt;/td&gt;&lt;td&gt;无&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;Compute&lt;/td&gt;&lt;td&gt;显存 (权重×4)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E8F5E9&quot;&gt;&lt;td&gt;&lt;b&gt;Gate / Router&lt;/b&gt;&lt;/td&gt;&lt;td&gt;DP=4&lt;/td&gt;&lt;td&gt;4 × 完整副本&lt;/td&gt;&lt;td&gt;无&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;~0.1 ms&lt;/td&gt;&lt;td&gt;Compute&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;td&gt;&lt;b&gt;EP Dispatch&lt;/b&gt;&lt;/td&gt;&lt;td&gt;EP=4&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;4-way All2All (FP8)&lt;/td&gt;&lt;td&gt;~354 MB (双向)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;~4.7 ms&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#0050ef&quot;&gt;Comm&lt;/font&gt;&lt;/td&gt;&lt;td&gt;RDMA 带宽&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFEBEE&quot;&gt;&lt;td&gt;&lt;b&gt;DeepGEMM Expert&lt;/b&gt;&lt;/td&gt;&lt;td&gt;EP=4 (local)&lt;/td&gt;&lt;td&gt;1/4 分片 (64 experts)&lt;/td&gt;&lt;td&gt;无&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;~5-8 ms&lt;/td&gt;&lt;td&gt;Compute&lt;/td&gt;&lt;td&gt;GEMM 计算量&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;td&gt;&lt;b&gt;EP Combine&lt;/b&gt;&lt;/td&gt;&lt;td&gt;EP=4&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;4-way All2All (BF16)&lt;/td&gt;&lt;td&gt;~702 MB (双向)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;~9.4 ms ★&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#0050ef&quot;&gt;Comm&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;RDMA 最大瓶颈&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FCE4EC&quot;&gt;&lt;td&gt;&lt;b&gt;Shared Expert&lt;/b&gt;&lt;/td&gt;&lt;td&gt;DP=4&lt;/td&gt;&lt;td&gt;4 × 完整副本&lt;/td&gt;&lt;td&gt;无&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;~2-3 ms&lt;/td&gt;&lt;td&gt;Compute (overlap)&lt;/td&gt;&lt;td&gt;与 Combine 并行&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#424242;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="50" y="2510" width="1100" height="230" as="geometry" />
        </mxCell>
        <mxCell id="pipe_summary" value="&lt;font style=&quot;font-size:12px&quot;&gt;&lt;b&gt;单层 MoE 延迟分解 (无 DBO):&lt;/b&gt; Gate(0.1) + Quant(0.3) + Dispatch(&lt;font color=&quot;#C62828&quot;&gt;4.7&lt;/font&gt;) + DeepGEMM(6) + Combine(&lt;font color=&quot;#C62828&quot;&gt;9.4&lt;/font&gt;) + SharedExpert(overlap) ≈ &lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;20.5 ms&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;b&gt;其中 RDMA 通信占比:&lt;/b&gt; (4.7 + 9.4) / 20.5 ≈ &lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;69%&lt;/b&gt;&lt;/font&gt; — 跨节点场景下通信是绝对瓶颈&lt;br&gt;&lt;b&gt;使用 DBO 后:&lt;/b&gt; 可隐藏 ~30-50% 通信, 有效延迟降至 ~13-15 ms/层&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#263238;fontColor=#E0E0E0;strokeColor=#546E7A;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="2770" width="1100" height="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="wgmma-decomposition" name="6. WGMMA 三层循环计算分解">
    <mxGraphModel dx="1242" dy="1199" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1600" pageHeight="2400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="w_title" value="&lt;font style=&quot;font-size:22px&quot;&gt;&lt;b&gt;WGMMA 三层循环计算分解&lt;/b&gt;&lt;/font&gt;&lt;br&gt;ThreadBlock: [128 × K] × [K × 128] → [128 × 128] | BLOCK_M=128, BLOCK_N=128, BLOCK_K=128" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="200" y="-30" width="800" height="50" as="geometry" />
        </mxCell>
        <mxCell id="w_tb" value="&lt;b&gt;Thread Block 组成 (384 threads)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;3&quot; style=&quot;border-collapse:collapse&quot;&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;th&gt;角色&lt;/th&gt;&lt;th&gt;Threads&lt;/th&gt;&lt;th&gt;Warps&lt;/th&gt;&lt;th&gt;寄存器/thread&lt;/th&gt;&lt;th&gt;职责&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;TMA WG&lt;/b&gt;&lt;/td&gt;&lt;td&gt;128&lt;/td&gt;&lt;td&gt;4&lt;/td&gt;&lt;td&gt;40&lt;/td&gt;&lt;td&gt;TMA异步加载 A,B,A_scale → Shared Mem&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFF9C4&quot;&gt;&lt;td&gt;&lt;b&gt;Math WG0&lt;/b&gt;&lt;/td&gt;&lt;td&gt;128&lt;/td&gt;&lt;td&gt;4&lt;/td&gt;&lt;td&gt;248&lt;/td&gt;&lt;td&gt;WGMMA: rows [0,63] + Scale Promotion&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFCCBC&quot;&gt;&lt;td&gt;&lt;b&gt;Math WG1&lt;/b&gt;&lt;/td&gt;&lt;td&gt;128&lt;/td&gt;&lt;td&gt;4&lt;/td&gt;&lt;td&gt;248&lt;/td&gt;&lt;td&gt;WGMMA: rows [64,127] + Scale Promotion&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#546E7A;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="100" y="40" width="900" height="120" as="geometry" />
        </mxCell>
        <mxCell id="w_loop1_label" value="&lt;font style=&quot;font-size:14px&quot; color=&quot;#1B5E20&quot;&gt;&lt;b&gt;第一层: k_iter (Pipeline Epoch)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="100" y="180" width="400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="w_loop1" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;for k_iter in range(kNumIterations):&lt;/b&gt;&lt;br&gt;&lt;br&gt;以 K=5120 为例:&lt;br&gt;num_k_blocks = 5120 / 128 = &lt;b&gt;40&lt;/b&gt;&lt;br&gt;kNumStages = &lt;b&gt;6&lt;/b&gt; (pipeline depth)&lt;br&gt;kNumIterations = ceil(40/6) = &lt;b&gt;7&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;2&quot; style=&quot;border-collapse:collapse;font-size:9px&quot;&gt;&lt;tr style=&quot;background:#C8E6C9&quot;&gt;&lt;th&gt;k_iter&lt;/th&gt;&lt;th&gt;Stages&lt;/th&gt;&lt;th&gt;K范围&lt;/th&gt;&lt;th&gt;K元素数&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;6 (full)&lt;/td&gt;&lt;td&gt;[0, 768)&lt;/td&gt;&lt;td&gt;768&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;6&lt;/td&gt;&lt;td&gt;[768, 1536)&lt;/td&gt;&lt;td&gt;768&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;2&lt;/td&gt;&lt;td&gt;6&lt;/td&gt;&lt;td&gt;[1536, 2304)&lt;/td&gt;&lt;td&gt;768&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;3&lt;/td&gt;&lt;td&gt;6&lt;/td&gt;&lt;td&gt;[2304, 3072)&lt;/td&gt;&lt;td&gt;768&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;4&lt;/td&gt;&lt;td&gt;6&lt;/td&gt;&lt;td&gt;[3072, 3840)&lt;/td&gt;&lt;td&gt;768&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;5&lt;/td&gt;&lt;td&gt;6&lt;/td&gt;&lt;td&gt;[3840, 4608)&lt;/td&gt;&lt;td&gt;768&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFECB3&quot;&gt;&lt;td&gt;&lt;b&gt;6&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;4&lt;/b&gt; (partial)&lt;/td&gt;&lt;td&gt;[4608, 5120)&lt;/td&gt;&lt;td&gt;&lt;b&gt;512&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;font color=&quot;#1B5E20&quot;&gt;总计: 768×6 + 512×1 = &lt;b&gt;5120&lt;/b&gt; ✓&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="100" y="210" width="430" height="280" as="geometry" />
        </mxCell>
        <mxCell id="w_loop1_ds" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;DeepSeek V3 (K=7168):&lt;/b&gt;&lt;br&gt;num_k_blocks = 7168/128 = 56&lt;br&gt;kNumIterations = ceil(56/6) = 10&lt;br&gt;前9轮: 9×6×128 = 6912&lt;br&gt;第10轮: 2×128 = 256&lt;br&gt;总计: 6912+256 = &lt;b&gt;7168&lt;/b&gt; ✓&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=1;" parent="1" vertex="1">
          <mxGeometry x="560" y="210" width="440" height="90" as="geometry" />
        </mxCell>
        <mxCell id="w_loop2_label" value="&lt;font style=&quot;font-size:14px&quot; color=&quot;#0D47A1&quot;&gt;&lt;b&gt;第二层: s (Pipeline Stage — TMA Buffer 轮转)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="100" y="510" width="500" height="30" as="geometry" />
        </mxCell>
        <mxCell id="w_loop2" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;for s in range(kNumInnerStages):  // 6 or 4&lt;/b&gt;&lt;br&gt;&lt;br&gt;每个 stage 处理一个 BLOCK_K=128 的 K 切片&lt;br&gt;6个 Shared Memory buffer 循环使用&lt;br&gt;&lt;br&gt;Producer-Consumer Pipeline:&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;2&quot; style=&quot;border-collapse:collapse;font-size:9px&quot;&gt;&lt;tr style=&quot;background:#BBDEFB&quot;&gt;&lt;th&gt;Stage&lt;/th&gt;&lt;th&gt;TMA WG (Producer)&lt;/th&gt;&lt;th&gt;Math WGs (Consumer)&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;s=0&lt;/td&gt;&lt;td&gt;TMA load A[128,128] + B[128,128] + A_s[128]&lt;br&gt;arrive(full_barrier[0])&lt;/td&gt;&lt;td&gt;(首轮等待)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;s=1&lt;/td&gt;&lt;td&gt;load → buffer[1]&lt;br&gt;wait(empty_barrier[0])&lt;/td&gt;&lt;td&gt;wait(full_barrier[0])&lt;br&gt;&lt;b&gt;4× WGMMA + scale&lt;/b&gt;&lt;br&gt;arrive(empty_barrier[0])&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;...&lt;/td&gt;&lt;td&gt;load → buffer[s%6]&lt;/td&gt;&lt;td&gt;WGMMA on buffer[(s-1)%6]&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;s=5&lt;/td&gt;&lt;td&gt;load → buffer[5]&lt;/td&gt;&lt;td&gt;WGMMA on buffer[4]&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;每 stage smem 用量: A(16KB) + B(16KB) + A_s(512B) ≈ 32.5KB&lt;br&gt;6 stages × 32.5KB ≈ &lt;b&gt;195KB&lt;/b&gt; shared memory&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="100" y="540" width="500" height="300" as="geometry" />
        </mxCell>
        <mxCell id="w_pipeline_viz" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Pipeline 时序 (Full Epoch = 6 stages):&lt;/b&gt;&lt;br&gt;&lt;br&gt;时间→ │t0│t1│t2│t3│t4│t5│t6│t7│...&lt;br&gt;─────┼──┼──┼──┼──┼──┼──┼──┼──┼&lt;br&gt;TMA  │&lt;font color=&quot;#1565C0&quot;&gt;L0│L1│L2│L3│L4│L5│L6│L7│&lt;/font&gt;...&lt;br&gt;Math │  │&lt;font color=&quot;#C62828&quot;&gt;C0│C1│C2│C3│C4│C5│C6│&lt;/font&gt;...&lt;br&gt;─────┼──┼──┼──┼──┼──┼──┼──┼──┼&lt;br&gt;     │  │←overlap→│  │  │  │  │&lt;br&gt;&lt;br&gt;L=Load(TMA), C=Compute(WGMMA+Scale)&lt;br&gt;★ TMA和Math完全overlap → 隐藏内存延迟&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=1;" parent="1" vertex="1">
          <mxGeometry x="630" y="540" width="370" height="180" as="geometry" />
        </mxCell>
        <mxCell id="w_loop3_label" value="&lt;font style=&quot;font-size:14px&quot; color=&quot;#B71C1C&quot;&gt;&lt;b&gt;第三层: k (WGMMA 指令 — Tensor Core)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="100" y="860" width="500" height="30" as="geometry" />
        </mxCell>
        <mxCell id="w_wgmma_inst" value="&lt;font style=&quot;font-size:11px&quot;&gt;&lt;b&gt;SM90_64x128x32_F32E4M3E4M3_SS_TN&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;3&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#FFCDD2&quot;&gt;&lt;th&gt;字段&lt;/th&gt;&lt;th&gt;值&lt;/th&gt;&lt;th&gt;含义&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;SM90&lt;/td&gt;&lt;td&gt;-&lt;/td&gt;&lt;td&gt;Hopper架构&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;M=64&lt;/b&gt;&lt;/td&gt;&lt;td&gt;WGMMA::M&lt;/td&gt;&lt;td&gt;每个warp group处理64行 (固定)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;N=128&lt;/b&gt;&lt;/td&gt;&lt;td&gt;WGMMA::N = BLOCK_N&lt;/td&gt;&lt;td&gt;处理128列 (=BLOCK_N)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;K=32&lt;/b&gt;&lt;/td&gt;&lt;td&gt;WGMMA::K&lt;/td&gt;&lt;td&gt;每条指令处理32个K元素&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;F32&lt;/td&gt;&lt;td&gt;accum dtype&lt;/td&gt;&lt;td&gt;FP32累加精度 (寄存器)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E4M3E4M3&lt;/td&gt;&lt;td&gt;A,B dtype&lt;/td&gt;&lt;td&gt;输入FP8 (float8_e4m3fn)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;SS&lt;/td&gt;&lt;td&gt;source&lt;/td&gt;&lt;td&gt;A和B均来自Shared Memory&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;TN&lt;/td&gt;&lt;td&gt;layout&lt;/td&gt;&lt;td&gt;A: row-major, B: col-major (NT)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="100" y="890" width="400" height="250" as="geometry" />
        </mxCell>
        <mxCell id="w_wgmma_loop" value="&lt;font style=&quot;font-size:11px&quot;&gt;&lt;b&gt;for k = 0; k &amp;lt; BLOCK_K/WGMMA::K; ++k&lt;/b&gt;&lt;br&gt;&lt;b&gt;= 128/32 = 4次 WGMMA&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;3&quot; style=&quot;border-collapse:collapse;font-size:9px&quot;&gt;&lt;tr style=&quot;background:#FFCDD2&quot;&gt;&lt;th&gt;k&lt;/th&gt;&lt;th&gt;A_desc 范围&lt;/th&gt;&lt;th&gt;B_desc 范围&lt;/th&gt;&lt;th&gt;accum&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;A[64, 0:32]&lt;/td&gt;&lt;td&gt;B[128, 0:32]&lt;/td&gt;&lt;td&gt;accum += A×B&lt;sup&gt;T&lt;/sup&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;A[64, 32:64]&lt;/td&gt;&lt;td&gt;B[128, 32:64]&lt;/td&gt;&lt;td&gt;accum += A×B&lt;sup&gt;T&lt;/sup&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;2&lt;/td&gt;&lt;td&gt;A[64, 64:96]&lt;/td&gt;&lt;td&gt;B[128, 64:96]&lt;/td&gt;&lt;td&gt;accum += A×B&lt;sup&gt;T&lt;/sup&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;3&lt;/td&gt;&lt;td&gt;A[64, 96:128]&lt;/td&gt;&lt;td&gt;B[128, 96:128]&lt;/td&gt;&lt;td&gt;accum += A×B&lt;sup&gt;T&lt;/sup&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;4次WGMMA覆盖完整BLOCK_K=128&lt;br&gt;accum: (64, 128) FP32 in registers&lt;br&gt;kNumAccum = 64×128/128 = &lt;b&gt;64 regs/thread&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="530" y="890" width="470" height="250" as="geometry" />
        </mxCell>
        <mxCell id="w_visual_label" value="&lt;font style=&quot;font-size:14px&quot; color=&quot;#4A148C&quot;&gt;&lt;b&gt;计算可视化: WG0 处理 rows[0:64]&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="100" y="1160" width="500" height="30" as="geometry" />
        </mxCell>
        <mxCell id="w_a_block" value="&lt;b&gt;A[64, 32]&lt;/b&gt;&lt;br&gt;FP8" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="100" y="1210" width="80" height="60" as="geometry" />
        </mxCell>
        <mxCell id="w_b_block" value="&lt;b&gt;B[32, 128]&lt;/b&gt;&lt;br&gt;FP8" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="200" y="1210" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="w_eq1" value="→" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=16;" parent="1" vertex="1">
          <mxGeometry x="310" y="1220" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="w_c_block" value="&lt;b&gt;C[64, 128]&lt;/b&gt;&lt;br&gt;FP32 accum" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCCBC;strokeColor=#BF360C;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="350" y="1200" width="100" height="70" as="geometry" />
        </mxCell>
        <mxCell id="w_x4" value="&lt;b&gt;×4&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;(k=0..3)&lt;br&gt;128/32=4&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=#757575;fillColor=#F5F5F5;rounded=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="470" y="1210" width="60" height="50" as="geometry" />
        </mxCell>
        <mxCell id="w_eq2" value="→" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=16;" parent="1" vertex="1">
          <mxGeometry x="540" y="1220" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="w_stage_block" value="&lt;b&gt;1 stage&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[64, 128] × [128, 128]&lt;br&gt;→ [64, 128]&lt;br&gt;+ Scale Promotion&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCCBC;strokeColor=#BF360C;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="580" y="1200" width="120" height="70" as="geometry" />
        </mxCell>
        <mxCell id="w_x6" value="&lt;b&gt;×6/4&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;stages&lt;br&gt;per epoch&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=#757575;fillColor=#F5F5F5;rounded=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="720" y="1210" width="60" height="50" as="geometry" />
        </mxCell>
        <mxCell id="w_eq3" value="→" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=16;" parent="1" vertex="1">
          <mxGeometry x="790" y="1220" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="w_epoch_block" value="&lt;b&gt;1 epoch&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[64, 768] × [768, 128]&lt;br&gt;→ final_accum [64, 128]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCCBC;strokeColor=#BF360C;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="830" y="1200" width="130" height="70" as="geometry" />
        </mxCell>
        <mxCell id="w_x7" value="&lt;b&gt;×7&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;epochs&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=#757575;fillColor=#F5F5F5;rounded=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="970" y="1210" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="w_final" value="&lt;b&gt;WG0 Output&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;final_accum&lt;br&gt;[64, 128] FP32&lt;br&gt;→ BF16 写回&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;strokeWidth=2;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="100" y="1310" width="130" height="65" as="geometry" />
        </mxCell>
        <mxCell id="w_plus" value="&lt;font style=&quot;font-size:16px&quot;&gt;&lt;b&gt;+&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="240" y="1320" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="w_final2" value="&lt;b&gt;WG1 Output&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;final_accum&lt;br&gt;[64, 128] FP32&lt;br&gt;→ BF16 写回&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCCBC;strokeColor=#BF360C;strokeWidth=2;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="280" y="1310" width="130" height="65" as="geometry" />
        </mxCell>
        <mxCell id="w_eq4" value="&lt;font style=&quot;font-size:16px&quot;&gt;&lt;b&gt;=&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="420" y="1320" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="w_tile_out" value="&lt;b&gt;Output Tile&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;[128, 128] BF16&lt;br&gt;STSM→smem_d→TMA Store&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#283593;strokeWidth=2;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="460" y="1310" width="170" height="65" as="geometry" />
        </mxCell>
        <mxCell id="w_scale_label" value="&lt;font style=&quot;font-size:14px&quot; color=&quot;#E65100&quot;&gt;&lt;b&gt;Scale Promotion 详解&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="100" y="1400" width="300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="w_scale" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;每个 BLOCK_K=128 stage 结束后:&lt;/b&gt;&lt;br&gt;&lt;br&gt;1. 读取 A_scale: scale_a = smem_sfa[stage][row]&lt;br&gt;   (TMA已加载到shared memory, 每行1个FP32)&lt;br&gt;&lt;br&gt;2. 读取 B_scale: scale_b = smem_sfb[k_block_idx]&lt;br&gt;   (Math WG用__ldg预加载到shared memory)&lt;br&gt;&lt;br&gt;3. &lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;final_accum[i] += (scale_a × scale_b) × accum[i]&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;数学等价:&lt;br&gt;C[i,j] = Σ&lt;sub&gt;g&lt;/sub&gt; A_s[i,g] × B_s[g] × Σ&lt;sub&gt;k&lt;/sub&gt; A[i,k] × B[j,k]&lt;br&gt;         │&lt;font color=&quot;#E65100&quot;&gt;scale_a×scale_b&lt;/font&gt;│   │&lt;font color=&quot;#C62828&quot;&gt;WGMMA raw&lt;/font&gt;    │&lt;br&gt;&lt;br&gt;★ WGMMA 不感知 quantization, 它就是做 FP8×FP8→FP32&lt;br&gt;★ Scale promotion 在软件层恢复真实值并累加&lt;br&gt;★ 这比显式反量化 (FP8→FP32→matmul) 节省大量带宽&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="100" y="1430" width="500" height="250" as="geometry" />
        </mxCell>
        <mxCell id="w_stats" value="&lt;font style=&quot;font-size:11px&quot;&gt;&lt;b&gt;计算统计 (K=5120)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;3&quot; style=&quot;border-collapse:collapse;font-size:9px&quot;&gt;&lt;tr style=&quot;background:#ECEFF1&quot;&gt;&lt;th&gt;指标&lt;/th&gt;&lt;th&gt;K=5120&lt;/th&gt;&lt;th&gt;K=7168&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;WGMMA指令/WG&lt;/td&gt;&lt;td&gt;40×4=160&lt;/td&gt;&lt;td&gt;56×4=224&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;WGMMA指令/TB&lt;/td&gt;&lt;td&gt;320&lt;/td&gt;&lt;td&gt;448&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Scale Promotion/WG&lt;/td&gt;&lt;td&gt;40次&lt;/td&gt;&lt;td&gt;56次&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Pipeline Epochs&lt;/td&gt;&lt;td&gt;7 (6+1)&lt;/td&gt;&lt;td&gt;10 (9+1)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Accum寄存器/thread&lt;/td&gt;&lt;td colspan=&quot;2&quot;&gt;64 FP32 = 256 bytes&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;SMEM/stage&lt;/td&gt;&lt;td colspan=&quot;2&quot;&gt;~32.5KB (A+B+A_s)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;SMEM total (6 stages)&lt;/td&gt;&lt;td colspan=&quot;2&quot;&gt;~195KB + 32KB(D) ≈ 227KB&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;FP8 TFLOPS (H800)&lt;/td&gt;&lt;td colspan=&quot;2&quot;&gt;~1550 peak&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#546E7A;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="630" y="1430" width="370" height="250" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="grid-block-launch" name="7. Kernel Launch: Grid / Block / Cluster">
    <mxGraphModel dx="1242" dy="1199" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="2800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="lb_title" value="&lt;font style=&quot;font-size:22px&quot;&gt;&lt;b&gt;DeepGEMM Kernel Launch 配置详解&lt;/b&gt;&lt;/font&gt;&lt;br&gt;Grid / Block / Cluster / Shared Memory | Host端 → Kernel端" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="200" y="-40" width="700" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lb_overview" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;Kernel Launch 全景&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;Host 端构造:&lt;/b&gt;&lt;br&gt;LaunchArgs(config.num_sms, config.thread_config.num_threads, config.smem_config.smem_size, config.multicast_config.num_multicast)&lt;br&gt;&lt;br&gt;&lt;b&gt;CUDA Launch:&lt;/b&gt;&lt;br&gt;cudaLaunchKernelEx(&amp;amp;launch_config, kernel, sfb, grouped_layout, shape_m, shape_n, shape_k, tensor_map_a, tensor_map_b, tensor_map_d, tensor_map_sfa)&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;5&quot; style=&quot;border-collapse:collapse;font-size:12px&quot;&gt;&lt;tbody&gt;&lt;tr style=&quot;background:#1565C0;color:#fff&quot;&gt;&lt;th&gt;参数&lt;/th&gt;&lt;th&gt;值&lt;/th&gt;&lt;th&gt;来源&lt;/th&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;td&gt;&lt;b&gt;Grid&lt;/b&gt;&lt;/td&gt;&lt;td&gt;dim3(num_sms, 1, 1)&lt;/td&gt;&lt;td&gt;= GPU SM数 (H100: 132)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;Block&lt;/b&gt;&lt;/td&gt;&lt;td&gt;dim3(num_threads, 1, 1)&lt;/td&gt;&lt;td&gt;= 384 (BLOCK_M=128) 或 256 (BLOCK_M≤64)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;td&gt;&lt;b&gt;Cluster&lt;/b&gt;&lt;/td&gt;&lt;td&gt;dim3(cluster_dim, 1, 1)&lt;/td&gt;&lt;td&gt;= 1 (无multicast) 或 2 (TMA multicast)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;Shared Memory&lt;/b&gt;&lt;/td&gt;&lt;td&gt;smem_size bytes&lt;/td&gt;&lt;td&gt;动态计算, ≤ 232,448 B (H100)&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;align=center;" parent="1" vertex="1">
          <mxGeometry x="50" y="30" width="1000" height="260" as="geometry" />
        </mxCell>
        <mxCell id="lb_grid" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;1. Grid Dimension — Persistent Kernel 核心&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;grid.x = num_sms (不是 tile 总数!)&lt;/b&gt;&lt;br&gt;&lt;br&gt;这是 Persistent Kernel 的标志: 每个 block 绑定一个 SM, 循环处理多个 tile&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;3&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#E8F5E9&quot;&gt;&lt;th&gt;GPU型号&lt;/th&gt;&lt;th&gt;SM数&lt;/th&gt;&lt;th&gt;grid.x&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;H100 SXM&lt;/td&gt;&lt;td&gt;132&lt;/td&gt;&lt;td&gt;132&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;H800&lt;/td&gt;&lt;td&gt;132&lt;/td&gt;&lt;td&gt;132&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;A100 80GB&lt;/td&gt;&lt;td&gt;108&lt;/td&gt;&lt;td&gt;108&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;b&gt;Tile 调度 (scheduler.get_next_block):&lt;/b&gt;&lt;br&gt;next_block_idx = (++iter) × num_sms + blockIdx.x&lt;br&gt;&lt;br&gt;iter=0: block[0] → tile[0], block[1] → tile[1], ..., block[131] → tile[131]&lt;br&gt;iter=1: block[0] → tile[132], block[1] → tile[133], ...&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#C62828&quot;&gt;DG_JIT_MINIMIZE_NUM_SMS 优化: tile少时减少grid.x, 降低L2竞争&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="50" y="320" width="480" height="310" as="geometry" />
        </mxCell>
        <mxCell id="lb_block" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;2. Block Dimension — Thread 组成&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;block.x = num_tma_threads + num_math_threads&lt;/b&gt;&lt;br&gt;num_tma_threads = 128 (固定, 4 warps)&lt;br&gt;num_math_threads = (BLOCK_M ≤ 64 ? 1 : 2) × 128&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;3&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#FFF3E0&quot;&gt;&lt;th&gt;BLOCK_M&lt;/th&gt;&lt;th&gt;TMA&lt;/th&gt;&lt;th&gt;Math&lt;/th&gt;&lt;th&gt;Total&lt;/th&gt;&lt;th&gt;Warps&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;16/32/64&lt;/td&gt;&lt;td&gt;128&lt;/td&gt;&lt;td&gt;128 (1WG)&lt;/td&gt;&lt;td&gt;&lt;b&gt;256&lt;/b&gt;&lt;/td&gt;&lt;td&gt;8&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFE0B2&quot;&gt;&lt;td&gt;&lt;b&gt;128 (典型)&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;128&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;256 (2WG)&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;384&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;12&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;256&lt;/td&gt;&lt;td&gt;128&lt;/td&gt;&lt;td&gt;256 (2WG)&lt;/td&gt;&lt;td&gt;&lt;b&gt;384&lt;/b&gt;&lt;/td&gt;&lt;td&gt;12&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;b&gt;__launch_bounds__(384, 1)&lt;/b&gt;&lt;br&gt;最大 384 threads/block, 最少 1 block/SM&lt;br&gt;&lt;br&gt;&lt;b&gt;寄存器重配置 (kernel内部):&lt;/b&gt;&lt;br&gt;TMA warps: warpgroup_reg_dealloc&amp;lt;40&amp;gt; → 40 regs/thread&lt;br&gt;Math warps: warpgroup_reg_alloc&amp;lt;248&amp;gt; → 248 regs/thread&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;将 TMA 不用的寄存器让给 Math, 避免 register spill&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="560" y="320" width="490" height="310" as="geometry" />
        </mxCell>
        <mxCell id="lb_thread_layout" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;Thread Block 内部线程布局 (BLOCK_M=128, 384 threads)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#C8E6C9&quot;&gt;&lt;th&gt;threadIdx.x&lt;/th&gt;&lt;th&gt;Warp&lt;/th&gt;&lt;th&gt;角色&lt;/th&gt;&lt;th&gt;职责&lt;/th&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E8F5E9&quot;&gt;&lt;td&gt;[0, 31]&lt;/td&gt;&lt;td&gt;warp 0&lt;/td&gt;&lt;td rowspan=&quot;4&quot;&gt;&lt;b&gt;Math WG 0&lt;/b&gt;&lt;br&gt;(128 threads)&lt;/td&gt;&lt;td rowspan=&quot;4&quot;&gt;WGMMA rows [0, 63]&lt;br&gt;warpgroup_reg_alloc&amp;lt;248&amp;gt;&lt;br&gt;FP32 accumulator&lt;br&gt;Scale Promotion&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E8F5E9&quot;&gt;&lt;td&gt;[32, 63]&lt;/td&gt;&lt;td&gt;warp 1&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E8F5E9&quot;&gt;&lt;td&gt;[64, 95]&lt;/td&gt;&lt;td&gt;warp 2&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E8F5E9&quot;&gt;&lt;td&gt;[96, 127]&lt;/td&gt;&lt;td&gt;warp 3&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFF3E0&quot;&gt;&lt;td&gt;[128, 159]&lt;/td&gt;&lt;td&gt;warp 4&lt;/td&gt;&lt;td rowspan=&quot;4&quot;&gt;&lt;b&gt;Math WG 1&lt;/b&gt;&lt;br&gt;(128 threads)&lt;/td&gt;&lt;td rowspan=&quot;4&quot;&gt;WGMMA rows [64, 127]&lt;br&gt;warpgroup_reg_alloc&amp;lt;248&amp;gt;&lt;br&gt;FP32 accumulator&lt;br&gt;Scale Promotion&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFF3E0&quot;&gt;&lt;td&gt;[160, 191]&lt;/td&gt;&lt;td&gt;warp 5&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFF3E0&quot;&gt;&lt;td&gt;[192, 223]&lt;/td&gt;&lt;td&gt;warp 6&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFF3E0&quot;&gt;&lt;td&gt;[224, 255]&lt;/td&gt;&lt;td&gt;warp 7&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;td&gt;[256, 287]&lt;/td&gt;&lt;td&gt;warp 8&lt;/td&gt;&lt;td rowspan=&quot;4&quot;&gt;&lt;b&gt;TMA Producer&lt;/b&gt;&lt;br&gt;(128 threads)&lt;/td&gt;&lt;td rowspan=&quot;4&quot;&gt;warpgroup_reg_dealloc&amp;lt;40&amp;gt;&lt;br&gt;仅 &lt;b&gt;warp 10, lane 0&lt;/b&gt;&lt;br&gt;执行实际 TMA 操作&lt;br&gt;barrier init/signal&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;td&gt;[288, 319]&lt;/td&gt;&lt;td&gt;warp 9&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;td&gt;[320, 351]&lt;/td&gt;&lt;td&gt;&lt;b&gt;warp 10&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;td&gt;[352, 383]&lt;/td&gt;&lt;td&gt;warp 11&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#424242;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="50" y="660" width="1000" height="360" as="geometry" />
        </mxCell>
        <mxCell id="lb_cluster" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;3. Cluster Dimension — TMA Multicast&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;cluster_dim = multicast_config.num_multicast&lt;/b&gt; (1 或 2)&lt;br&gt;&lt;br&gt;&lt;b&gt;条件 (M ≥ 512 时才启用):&lt;/b&gt;&lt;br&gt;1. num_sms % multicast == 0&lt;br&gt;2. tile数在 multicast 维度可整除&lt;br&gt;3. MGroupedContiguous: 相邻 m_block 属于同一 expert&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;3&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#E8EAF6&quot;&gt;&lt;th&gt;条件&lt;/th&gt;&lt;th&gt;cluster_dim&lt;/th&gt;&lt;th&gt;效果&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;M &amp;lt; 512 或不合法&lt;/td&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;无 multicast&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E8EAF6&quot;&gt;&lt;td&gt;M ≥ 512, on_a=true&lt;/td&gt;&lt;td&gt;&lt;b&gt;2&lt;/b&gt;&lt;/td&gt;&lt;td&gt;2 SM 共享 A tile&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;M ≥ 512, on_a=false&lt;/td&gt;&lt;td&gt;&lt;b&gt;2&lt;/b&gt;&lt;/td&gt;&lt;td&gt;2 SM 共享 B tile&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;b&gt;优先策略:&lt;/b&gt; multicast 较大维度 (block_m &amp;gt; block_n → 先 on_a)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#5C6BC0;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="50" y="1050" width="480" height="330" as="geometry" />
        </mxCell>
        <mxCell id="lb_smem" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;4. Shared Memory — 动态分配&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;H100 容量: 232,448 bytes (~227 KB)&lt;/b&gt;&lt;br&gt;&lt;br&gt;smem = smem_cd + stages×(smem_a + smem_b + smem_sfa)&lt;br&gt;       + smem_extra_sfb + smem_barrier&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;3&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#FCE4EC&quot;&gt;&lt;th&gt;组件&lt;/th&gt;&lt;th&gt;大小 (128×128)&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;smem_cd (output)&lt;/td&gt;&lt;td&gt;128×128×2B = 32 KB&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FCE4EC&quot;&gt;&lt;td&gt;smem_a / stage&lt;/td&gt;&lt;td&gt;128×128×1B = 16 KB&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;smem_b / stage&lt;/td&gt;&lt;td&gt;128×128×1B = 16 KB&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FCE4EC&quot;&gt;&lt;td&gt;smem_sfa / stage&lt;/td&gt;&lt;td&gt;align(128×4B, 128) = 512 B&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;smem_extra_sfb&lt;/td&gt;&lt;td&gt;K/128 × 4B × (1 or 2)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FCE4EC&quot;&gt;&lt;td&gt;barriers&lt;/td&gt;&lt;td&gt;stages × 8 × 2&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;b&gt;自动选最大 kNumStages:&lt;/b&gt;&lt;br&gt;128×128: 6 stages ≈ 227 KB ✓&lt;br&gt;128×128: 7 stages ≈ 260 KB ✗&lt;br&gt;&lt;br&gt;通过 cudaFuncSetAttribute 设置&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="560" y="1050" width="490" height="330" as="geometry" />
        </mxCell>
        <mxCell id="lb_heuristic" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;5. Block Size 启发式选择 (get_best_config)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;候选空间:&lt;/b&gt;&lt;br&gt;BLOCK_M ∈ {64, 128, 256} (MGroupedContiguous 固定 &lt;font color=&quot;#C62828&quot;&gt;128&lt;/font&gt;)&lt;br&gt;BLOCK_N ∈ {16, 32, 48, ..., 256} (步长 16)&lt;br&gt;BLOCK_K = 128 (FP8 固定)&lt;br&gt;&lt;br&gt;&lt;b&gt;优化目标 — 最小化 wave 数:&lt;/b&gt;&lt;br&gt;num_m_blocks = ceil(M / BLOCK_M)&lt;br&gt;num_n_blocks = ceil(N / BLOCK_N)&lt;br&gt;total_tiles = num_m_blocks × num_n_blocks × num_groups&lt;br&gt;num_waves = ceil(total_tiles / num_sms)&lt;br&gt;&lt;br&gt;&lt;b&gt;选择优先级:&lt;/b&gt;&lt;br&gt;1) num_waves 最小&lt;br&gt;2) 同 waves → last wave 利用率最高&lt;br&gt;3) 同 util → 较小 block (减少浪费) 或较大 BLOCK_N (GEMM效率)&lt;br&gt;&lt;br&gt;&lt;b&gt;额外约束:&lt;/b&gt;&lt;br&gt;• block_m ≤ 128 或 block_n ≤ 128 (寄存器限制)&lt;br&gt;• 1D2D kernel: block_n &amp;gt; 128 仅限 {144, 160, 192}&lt;br&gt;• FP32 output 不支持 block_m = 256&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="50" y="1400" width="480" height="350" as="geometry" />
        </mxCell>
        <mxCell id="lb_example" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;6. 数值示例 (H100, 132 SMs, DeepSeek V3)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;GEMM1: [M_sum, 7168] × [7168, 18432]&lt;/b&gt;&lt;br&gt;假设 M_sum = 2048:&lt;br&gt;• BLOCK_M=128 (固定), BLOCK_N=128&lt;br&gt;• num_m_blocks = 2048/128 = 16&lt;br&gt;• num_n_blocks = 18432/128 = 144&lt;br&gt;• total_tiles = 16 × 144 = &lt;b&gt;2304&lt;/b&gt;&lt;br&gt;• num_waves = ceil(2304/132) = &lt;b&gt;18&lt;/b&gt;&lt;br&gt;• 每SM平均 ≈ 17.5 tiles&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#1565C0&quot;&gt;Launch: grid=(132,1,1), block=(384,1,1)&lt;br&gt;cluster=2, smem≈227KB&lt;/font&gt;&lt;br&gt;&lt;hr&gt;&lt;b&gt;GEMM2: [M_sum, 9216] × [9216, 7168]&lt;/b&gt;&lt;br&gt;• num_m_blocks = 2048/128 = 16&lt;br&gt;• num_n_blocks = 7168/128 = 56&lt;br&gt;• total_tiles = 16 × 56 = &lt;b&gt;896&lt;/b&gt;&lt;br&gt;• num_waves = ceil(896/132) = &lt;b&gt;7&lt;/b&gt;&lt;br&gt;• 每SM平均 ≈ 6.8 tiles&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#1565C0&quot;&gt;Launch: grid=(132,1,1), block=(384,1,1)&lt;br&gt;cluster=2, smem≈227KB&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="560" y="1400" width="490" height="350" as="geometry" />
        </mxCell>
        <mxCell id="lb_callchain" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;7. 完整调用链: Host → Kernel&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;table border=&quot;0&quot; cellpadding=&quot;3&quot; style=&quot;font-size:10px&quot;&gt;&lt;tr&gt;&lt;td style=&quot;background:#E3F2FD;border:1px solid #1565C0;padding:4px&quot;&gt;&lt;b&gt;Python&lt;/b&gt;&lt;br&gt;deep_gemm.m_grouped_fp8_gemm_nt_contiguous(lhs, lhs_scales, rhs, rhs_scales, out, m_indices)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align=&quot;center&quot;&gt;↓&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;background:#E8F5E9;border:1px solid #2E7D32;padding:4px&quot;&gt;&lt;b&gt;C++ Host&lt;/b&gt;&lt;br&gt;sm90_m_grouped_fp8_gemm_contiguous_1d2d(a, sfa, b, sfb, d, m_indices, ...)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align=&quot;center&quot;&gt;↓&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;background:#FFF3E0;border:1px solid #E65100;padding:4px&quot;&gt;&lt;b&gt;Heuristic&lt;/b&gt;&lt;br&gt;get_best_config&amp;lt;SM90ArchSpec&amp;gt;(MGroupedContiguous, Kernel1D2D, m, n, k, ...)&lt;br&gt;→ block_m=128, block_n=128, block_k=128, stages=6, multicast=2&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align=&quot;center&quot;&gt;↓&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;background:#FCE4EC;border:1px solid #C62828;padding:4px&quot;&gt;&lt;b&gt;TMA Descriptor&lt;/b&gt;&lt;br&gt;make_tma_a_desc / make_tma_b_desc / make_tma_cd_desc / make_tma_sf_desc&lt;br&gt;→ CUtensorMap (2D TMA descriptor, swizzle-128B, L2-promote)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align=&quot;center&quot;&gt;↓&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;background:#EDE7F6;border:1px solid #5C6BC0;padding:4px&quot;&gt;&lt;b&gt;JIT Compile + Cache&lt;/b&gt;&lt;br&gt;compiler-&amp;gt;build(&quot;sm90_m_grouped_fp8_gemm_contiguous_1d2d&quot;, code)&lt;br&gt;→ kernel.cu → nvcc → kernel.cubin → load symbol&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align=&quot;center&quot;&gt;↓&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;background:#E0F2F1;border:1px solid #00695C;padding:4px&quot;&gt;&lt;b&gt;CUDA Launch&lt;/b&gt;&lt;br&gt;cudaLaunchKernelEx(grid=(132,1,1), block=(384,1,1), cluster=(2,1,1), smem=227KB)&lt;br&gt;→ sm90_fp8_gemm_1d2d_impl&amp;lt;...&amp;gt;(sfb, m_indices, M, N, K, tma_a, tma_b, tma_d, tma_sfa)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#424242;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="50" y="1790" width="1000" height="430" as="geometry" />
        </mxCell>
        <mxCell id="lb_kernel_sig" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;Kernel 签名 (JIT 生成)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;font-family:monospace&quot;&gt;&lt;br&gt;__global__ __launch_bounds__(384, 1)&lt;br&gt;void sm90_fp8_gemm_1d2d_impl&amp;lt;&lt;br&gt;    cute::UMMA::Major::MN,     // major_sfb&lt;br&gt;    0, 0, 0,                   // compiled M/N/K (0=dynamic)&lt;br&gt;    64,                        // num_groups (64 experts)&lt;br&gt;    128, 128, 128,             // BLOCK_M, BLOCK_N, BLOCK_K&lt;br&gt;    128, 128, 128,             // swizzle_a, swizzle_b, swizzle_cd&lt;br&gt;    6, 2,                      // num_stages, num_last_stages&lt;br&gt;    128, 256,                  // num_tma_threads, num_math_threads&lt;br&gt;    2, false,                  // num_multicast, is_multicast_on_a&lt;br&gt;    132,                       // kNumSMs&lt;br&gt;    GemmType::MGroupedContiguous,&lt;br&gt;    DefaultEpilogueType&lt;br&gt;&amp;gt;(float* sfb, int* grouped_layout,&lt;br&gt;  uint32_t shape_m, shape_n, shape_k,&lt;br&gt;  __grid_constant__ TmaDescriptor tma_a, tma_b, tma_d, tma_sfa);&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#263238;fontColor=#E0E0E0;strokeColor=#546E7A;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="50" y="2260" width="1000" height="280" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="dbo-detail" name="8. DBO (Dual Batch Overlap) 完整机制">
    <mxGraphModel dx="1656" dy="1465" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1600" pageHeight="4800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="dbo_title" value="&lt;font style=&quot;font-size:22px&quot;&gt;&lt;b&gt;DBO (Dual Batch Overlap) 完整机制&lt;/b&gt;&lt;/font&gt;&lt;br&gt;两线程交替执行 | Compute/Comm 双 Stream | SM 分区 | Handle 隔离" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="200" y="-40" width="800" height="50" as="geometry" />
        </mxCell>
        <mxCell id="dbo_overview" value="&lt;font style=&quot;font-size:14px&quot;&gt;&lt;b&gt;DBO 核心思想&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;将一个 batch 分为 2 个 micro-batch (ubatch 0, ubatch 1), 各由一个 &lt;b&gt;OS 线程&lt;/b&gt;驱动。&lt;br&gt;线程间通过 &lt;b&gt;CPU Event Ring&lt;/b&gt; 交替让出 CPU, 同时在 GPU 上使用 &lt;b&gt;两条 CUDA Stream&lt;/b&gt;:&lt;br&gt;&lt;br&gt;• &lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;Compute Stream&lt;/b&gt;&lt;/font&gt;: Gate/Router, FP8 Quant, DeepGEMM Expert Compute, Shared Expert MLP&lt;br&gt;• &lt;font color=&quot;#1565C0&quot;&gt;&lt;b&gt;Comm Stream&lt;/b&gt;&lt;/font&gt;: DeepEP Dispatch All2All, DeepEP Combine All2All&lt;br&gt;&lt;br&gt;关键: 一个 ubatch 在 Comm Stream 做通信时, 另一个 ubatch 的 Compute Stream 计算可并行&lt;br&gt;这样 RDMA 通信延迟被 Expert Compute 部分 &lt;b&gt;隐藏&lt;/b&gt;, 不再是纯等待开销。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="50" y="30" width="1100" height="150" as="geometry" />
        </mxCell>
        <mxCell id="dbo_arch_title" value="&lt;font style=&quot;font-size:16px&quot;&gt;&lt;b&gt;线程模型 + CUDA Stream 架构&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="350" y="200" width="500" height="25" as="geometry" />
        </mxCell>
        <mxCell id="dbo_thread_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#9E9E9E;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="50" y="235" width="1100" height="320" as="geometry" />
        </mxCell>
        <mxCell id="dbo_t0" value="&lt;font style=&quot;font-size:12px&quot;&gt;&lt;b&gt;OS Thread 0 (ubatch 0)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;UBatchContext(id=0):&lt;/b&gt;&lt;br&gt;• compute_stream = torch.cuda.current_stream()&lt;br&gt;• comm_stream = 共享 comm_stream&lt;br&gt;• gpu_compute_done_event&lt;br&gt;• gpu_comm_done_event&lt;br&gt;• cpu_signal_event → 唤醒 Thread 1&lt;br&gt;• cpu_wait_event ← 被 Thread 1 唤醒&lt;br&gt;&lt;br&gt;&lt;b&gt;数据:&lt;/b&gt;&lt;br&gt;• batched_hidden_states[&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;0&lt;/b&gt;&lt;/font&gt;] (max_tokens, 7168)&lt;br&gt;• batched_router_logits[&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;0&lt;/b&gt;&lt;/font&gt;] (max_tokens, 256)&lt;br&gt;• workspace[&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;0&lt;/b&gt;&lt;/font&gt;]&lt;br&gt;• handles[&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;0&lt;/b&gt;&lt;/font&gt;] (dispatch→combine)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="70" y="250" width="360" height="220" as="geometry" />
        </mxCell>
        <mxCell id="dbo_t1" value="&lt;font style=&quot;font-size:12px&quot;&gt;&lt;b&gt;OS Thread 1 (ubatch 1)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;&lt;b&gt;UBatchContext(id=1):&lt;/b&gt;&lt;br&gt;• compute_stream = torch.cuda.current_stream()&lt;br&gt;• comm_stream = 共享 comm_stream&lt;br&gt;• gpu_compute_done_event&lt;br&gt;• gpu_comm_done_event&lt;br&gt;• cpu_signal_event → 唤醒 Thread 0&lt;br&gt;• cpu_wait_event ← 被 Thread 0 唤醒&lt;br&gt;&lt;br&gt;&lt;b&gt;数据:&lt;/b&gt;&lt;br&gt;• batched_hidden_states[&lt;font color=&quot;#1565C0&quot;&gt;&lt;b&gt;1&lt;/b&gt;&lt;/font&gt;] (max_tokens, 7168)&lt;br&gt;• batched_router_logits[&lt;font color=&quot;#1565C0&quot;&gt;&lt;b&gt;1&lt;/b&gt;&lt;/font&gt;] (max_tokens, 256)&lt;br&gt;• workspace[&lt;font color=&quot;#1565C0&quot;&gt;&lt;b&gt;1&lt;/b&gt;&lt;/font&gt;]&lt;br&gt;• handles[&lt;font color=&quot;#1565C0&quot;&gt;&lt;b&gt;1&lt;/b&gt;&lt;/font&gt;] (dispatch→combine)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="470" y="250" width="360" height="220" as="geometry" />
        </mxCell>
        <mxCell id="dbo_cpu_ring" value="&lt;font style=&quot;font-size:11px&quot;&gt;&lt;b&gt;CPU Event Ring&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;br&gt;cpu_events = [Event0, Event1]&lt;br&gt;Thread 0: signal_event = events[1]&lt;br&gt;           wait_event = events[0]&lt;br&gt;Thread 1: signal_event = events[0]&lt;br&gt;           wait_event = events[1]&lt;br&gt;&lt;br&gt;yield_(): signal → wait → 恢复执行&lt;br&gt;(交替唤醒对方线程)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="860" y="250" width="270" height="150" as="geometry" />
        </mxCell>
        <mxCell id="dbo_cpu_arrow0" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#E65100;curved=1;" parent="1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="430" y="350" as="sourcePoint" />
            <mxPoint x="470" y="350" as="targetPoint" />
            <Array as="points">
              <mxPoint x="450" y="310" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="dbo_cpu_arrow1" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#E65100;curved=1;" parent="1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="470" y="400" as="sourcePoint" />
            <mxPoint x="430" y="400" as="targetPoint" />
            <Array as="points">
              <mxPoint x="450" y="440" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="dbo_cpu_label0" value="&lt;font style=&quot;font-size:8px&quot; color=&quot;#E65100&quot;&gt;cpu_signal→&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="430" y="295" width="70" height="15" as="geometry" />
        </mxCell>
        <mxCell id="dbo_cpu_label1" value="&lt;font style=&quot;font-size:8px&quot; color=&quot;#E65100&quot;&gt;←cpu_signal&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="430" y="440" width="70" height="15" as="geometry" />
        </mxCell>
        <mxCell id="dbo_sm_title" value="&lt;font style=&quot;font-size:16px&quot;&gt;&lt;b&gt;SM 分区 (SMControlContextManager)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="350" y="575" width="500" height="25" as="geometry" />
        </mxCell>
        <mxCell id="dbo_sm_box" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#263238;color:#fff&quot;&gt;&lt;th&gt;分区&lt;/th&gt;&lt;th&gt;SMs&lt;/th&gt;&lt;th&gt;控制 API&lt;/th&gt;&lt;th&gt;负责内容&lt;/th&gt;&lt;th&gt;环境变量&lt;/th&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;td&gt;&lt;font color=&quot;#1565C0&quot;&gt;&lt;b&gt;Comm SMs&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;20&lt;/b&gt; (默认)&lt;/td&gt;&lt;td&gt;all2all_manager.set_num_sms(20)&lt;/td&gt;&lt;td&gt;DeepEP dispatch/combine All2All 通信&lt;/td&gt;&lt;td&gt;VLLM_DBO_COMM_SMS=20&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFEBEE&quot;&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;Compute SMs&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;112&lt;/b&gt; (132-20)&lt;/td&gt;&lt;td&gt;deep_gemm.set_num_sms(112)&lt;/td&gt;&lt;td&gt;DeepGEMM Expert GEMM, Gate, Quant, Shared Expert&lt;/td&gt;&lt;td&gt;(total - comm_sms)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E8F5E9&quot;&gt;&lt;td&gt;&lt;b&gt;Total&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;132&lt;/b&gt; (H100)&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;DBO 关闭时: 所有 132 SMs 不分区&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot; color=&quot;#666666&quot;&gt;注: SM 分区是软件 hint (通过 DeepEP/DeepGEMM API 设置), 不是硬件 partition。&lt;br&gt;comm_sms 会被 all2all_manager.max_sms_used() 截断上限。&lt;br&gt;SMControlContextManager 在 UBatchWrapper._capture_ubatches / _run_ubatches 的 with 块中激活。&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#424242;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="50" y="610" width="1100" height="160" as="geometry" />
        </mxCell>
        <mxCell id="dbo_sm_viz" value="&lt;font style=&quot;font-size:10px&quot;&gt;H100 132 SMs 分配示意:&lt;br&gt;&lt;br&gt;│&lt;font color=&quot;#1565C0&quot;&gt;████████████████████&lt;/font&gt;│&lt;font color=&quot;#C62828&quot;&gt;████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████&lt;/font&gt;│&lt;br&gt;│← &lt;font color=&quot;#1565C0&quot;&gt;&lt;b&gt;20 Comm SMs&lt;/b&gt;&lt;/font&gt; →│← &lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;112 Compute SMs&lt;/b&gt;&lt;/font&gt; ─────────────────────────────────→│&lt;br&gt;│  DeepEP All2All    │  DeepGEMM + Gate + Quant + Shared Expert MLP              │&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#546E7A;" parent="1" vertex="1">
          <mxGeometry x="50" y="780" width="1100" height="80" as="geometry" />
        </mxCell>
        <mxCell id="dbo_timeline_title" value="&lt;font style=&quot;font-size:16px&quot;&gt;&lt;b&gt;两线程交替时序 (单层 MoE, 详细)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="300" y="880" width="600" height="25" as="geometry" />
        </mxCell>
        <mxCell id="dbo_timeline" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;5&quot; style=&quot;border-collapse:collapse;font-size:10px&quot;&gt;&lt;tr style=&quot;background:#263238;color:#fff&quot;&gt;&lt;th width=&quot;40&quot;&gt;阶段&lt;/th&gt;&lt;th width=&quot;80&quot;&gt;CPU 活跃&lt;/th&gt;&lt;th width=&quot;300&quot;&gt;Thread 0 (ubatch 0)&lt;/th&gt;&lt;th width=&quot;300&quot;&gt;Thread 1 (ubatch 1)&lt;/th&gt;&lt;th width=&quot;200&quot;&gt;GPU Compute Stream&lt;/th&gt;&lt;th width=&quot;200&quot;&gt;GPU Comm Stream&lt;/th&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFF8E1&quot;&gt;&lt;td&gt;&lt;b&gt;T0&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Thread 0&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;Gate + Router + FP8 Quant (ub0)&lt;/font&gt;&lt;br&gt;在 compute_stream 上&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#999&quot;&gt;(cpu_wait, 等待 Thread 0 yield)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;Gate(ub0)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;T1a&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Thread 0&lt;/td&gt;&lt;td&gt;&lt;b&gt;dbo_yield_and_switch_&lt;br&gt;from_compute_to_comm()&lt;/b&gt;&lt;br&gt;① record compute_done_event&lt;br&gt;② cpu_signal → 唤醒 Thread 1&lt;br&gt;③ cpu_wait ← 等待 Thread 1&lt;/td&gt;&lt;td&gt;(被唤醒, 开始执行)&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;wait(compute_done)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;td&gt;&lt;b&gt;T1b&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Thread 1&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#999&quot;&gt;(cpu_wait)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;Gate + Router + FP8 Quant (ub1)&lt;/font&gt;&lt;br&gt;在 compute_stream 上&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;Gate(ub1)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#1565C0&quot;&gt;Dispatch(ub0)&lt;/font&gt; 异步执行&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFEBEE&quot;&gt;&lt;td&gt;&lt;b&gt;T2a&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Thread 1&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#999&quot;&gt;(cpu_wait)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;dbo_yield_and_switch_&lt;br&gt;from_compute_to_comm()&lt;/b&gt;&lt;br&gt;→ 唤醒 Thread 0&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;wait(ub1 compute_done)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFF8E1&quot;&gt;&lt;td&gt;&lt;b&gt;T2b&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Thread 0&lt;/td&gt;&lt;td&gt;buffer.dispatch(ub0) 提交到 comm_stream&lt;br&gt;handles[0] = handle&lt;br&gt;&lt;b&gt;dbo_switch_to_compute_sync()&lt;/b&gt;&lt;br&gt;→ compute waits comm_done&lt;br&gt;&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;DeepGEMM Expert Compute (ub0)&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#999&quot;&gt;(cpu_wait)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;DeepGEMM(ub0)&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#1565C0&quot;&gt;Dispatch(ub1)&lt;/font&gt; 异步执行&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;td&gt;&lt;b&gt;T3&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Thread 1&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#999&quot;&gt;(cpu_wait)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;buffer.dispatch(ub1) 提交&lt;br&gt;handles[1] = handle&lt;br&gt;&lt;b&gt;dbo_switch_to_compute_sync()&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;DeepGEMM Expert Compute (ub1)&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;DeepGEMM(ub1)&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;(drain)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFF8E1&quot;&gt;&lt;td&gt;&lt;b&gt;T4a&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Thread 0&lt;/td&gt;&lt;td&gt;&lt;b&gt;dbo_yield_and_switch_&lt;br&gt;from_compute_to_comm()&lt;/b&gt;&lt;br&gt;buffer.combine(ub0, handle=handles[0])&lt;br&gt;&lt;b&gt;dbo_switch_to_compute()&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#999&quot;&gt;(cpu_wait)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#1565C0&quot;&gt;&lt;b&gt;Combine(ub0)&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;td&gt;&lt;b&gt;T4b&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Thread 1&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;Shared Expert MLP (ub0)&lt;/font&gt;&lt;br&gt;(async receiver: copy_ on comm)&lt;/td&gt;&lt;td&gt;&lt;b&gt;dbo_yield_and_switch_&lt;br&gt;from_compute_to_comm()&lt;/b&gt;&lt;br&gt;buffer.combine(ub1, handle=handles[1])&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;Shared Expert(ub0)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#1565C0&quot;&gt;&lt;b&gt;Combine(ub1)&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#FFF8E1&quot;&gt;&lt;td&gt;&lt;b&gt;T5&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Thread 0&lt;/td&gt;&lt;td&gt;Residual Add (ub0)&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;Shared Expert MLP (ub1)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font color=&quot;#C62828&quot;&gt;SharedExpert(ub1)&lt;/font&gt;&lt;/td&gt;&lt;td&gt;(drain)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#E3F2FD&quot;&gt;&lt;td&gt;&lt;b&gt;T6&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Thread 1&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;Residual Add (ub1)&lt;/td&gt;&lt;td&gt;ResAdd(ub1)&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#424242;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="50" y="915" width="1100" height="480" as="geometry" />
        </mxCell>
