ight="16" as="geometry"/></mxCell><mxCell id="v18" value="Split-K：每 token 的 Linear1 被多 SM 拆 K" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="658.0" y="83.52" width="260" height="16" as="geometry"/></mxCell><mxCell id="v19" value="必须跨 SM 规约 → atomicAdd 到 HBM" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="658.0" y="101.52" width="200" height="16" as="geometry"/></mxCell><mxCell id="v20" value="Linear2 要么再读 HBM，要么重划分" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="658.0" y="119.52" width="163" height="16" as="geometry"/></mxCell><mxCell id="v21" value="Output-Stationary 优势" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#1f5d1f;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="658.0" y="143.52" width="148" height="16" as="geometry"/></mxCell><mxCell id="v22" value="· 无跨 SM 规约，只在 pool_block 内做 k-loop" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="658.0" y="161.52" width="252" height="16" as="geometry"/></mxCell><mxCell id="v23" value="· L1 输出驻留 SMEM，L2 直接读" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="658.0" y="179.52" width="156" height="16" as="geometry"/></mxCell><mxCell id="v24" value="· 天然适合小 token 数 (tk=32~96) 的 MoE" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="658.0" y="197.52" width="238" height="16" as="geometry"/></mxCell>
