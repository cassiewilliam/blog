        <mxCell id="dbo_g_shared1" value="&lt;font style=&quot;font-size:8px&quot;&gt;Shared&lt;br&gt;Expert(ub1)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=8;" parent="1" vertex="1">
