        <mxCell id="v2" value="DeepEP LL 与 HT 在 kernel 层的差异" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#333;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="378.5" y="7.18" width="243" height="19" as="geometry"/></mxCell><mxCell id="v3" value="" style="rounded=1;arcSize=5;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="60.0" y="60.0" width="420.0" height="270.0" as="geometry"/></mxCell><mxCell id="v4" value="HT (High Throughput)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#4a1515;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="196.0" y="69.52" width="148" height="16" as="geometry"/></mxCell><mxCell id="v5" value="• kernel 内启动 SM 参与数据收发" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#4a1515;" vertex="1" parent="1"><mxGeometry x="80.0" y="95.52" width="163" height="16" as="geometry"/></mxCell><mxCell id="v6" value="• NVLink / RDMA layout 动态计算" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#4a1515;" vertex="1" parent="1"><mxGeometry x="80.0" y="117.52" width="200" height="16" as="geometry"/></mxCell><mxCell id="v7" value="• dispatch 阶段先分桶再写" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#4a1515;" vertex="1" parent="1"><mxGeometry x="80.0" y="139.52" width="133" height="16" as="geometry"/></mxCell><mxCell id="v8" value="• combine 用 BF16（2× dispatch 流量）" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#4a1515;" vertex="1" parent="1"><mxGeometry x="80.0" y="161.52" width="238" height="16" as="geometry"/></mxCell><mxCell id="v9" value="• 支持 async prepare / finalize hook" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#4a1515;" vertex="1" parent="1"><mxGeometry x="80.0" y="183.52" width="252" height="16" as="geometry"/></mxCell><mxCell id="v10" value="• 依赖 token 数 → 不能 CUDA Graph" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#4a1515;" vertex="1" parent="1"><mxGeometry x="80.0" y="205.52" width="208" height="16" as="geometry"/></mxCell><mxCell id="v11" value="适用：Prefill 大 batch 吞吐优先" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#4a1515;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80.0" y="233.52" width="171" height="16" as="geometry"/></mxCell><mxCell id="v12" value="单层延迟 ~20 ms" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#4a1515;" vertex="1" parent="1"><mxGeometry x="80.0" y="255.52" width="81" height="16" as="geometry"/></mxCell><mxCell id="v13" value="" style="rounded=1;arcSize=5;fillColor=#eef7ee;strokeColor=#5fa55f;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="520.0" y="60.0" width="420.0" height="270.0" as="geometry"/></mxCell><mxCell id="v14" value="LL (Low Latency)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#1a3d1a;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="670.5" y="69.52" width="119" height="16" as="geometry"/></mxCell><mxCell id="v15" value="• kernel 使用 cooperative launch" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#1a3d1a;" vertex="1" parent="1"><mxGeometry x="540.0" y="95.52" width="223" height="16" as="geometry"/></mxCell><mxCell id="v16" value="• num_sms=0，通信完全靠 RDMA HW" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#1a3d1a;" vertex="1" parent="1"><mxGeometry x="540.0" y="117.52" width="186" height="16" as="geometry"/></mxCell><mxCell id="v17" value="• 64 QPs/rank 最大化 IB 并发" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#1a3d1a;" vertex="1" parent="1"><mxGeometry x="540.0" y="139.52" width="171" height="16" as="geometry"/></mxCell><mxCell id="v18" value="• combine 内部做 weighted-sum" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#1a3d1a;" vertex="1" parent="1"><mxGeometry x="540.0" y="161.52" width="193" height="16" as="geometry"/></mxCell><mxCell id="v19" value="• dispatch 固定 max_tokens 形状" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#1a3d1a;" vertex="1" parent="1"><mxGeometry x="540.0" y="183.52" width="200" height="16" as="geometry"/></mxCell><mxCell id="v20" value="• 可录入 CUDA Graph，复用 pointer" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#1a3d1a;" vertex="1" parent="1"><mxGeometry x="540.0" y="205.52" width="200" height="16" as="geometry"/></mxCell><mxCell id="v21" value="适用：Decode 单 token 延迟优先" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#1a3d1a;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="540.0" y="233.52" width="163" height="16" as="geometry"/></mxCell><mxCell id="v22" value="单层延迟 ~1-2 ms" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#1a3d1a;" vertex="1" parent="1"><mxGeometry x="540.0" y="255.52" width="89" height="16" as="geometry"/></mxCell>
