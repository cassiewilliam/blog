        <mxCell id="p4-a" value="Triton-distributed primitive&#xa;rank / num_ranks&#xa;symm_at&#xa;wait / consume_token&#xa;notify&#xa;extern_call" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;" parent="1" vertex="1">
