        <mxCell id="d_3" value="<b>Load to registers</b><br>E scores stay on-chip<br><font style=&quot;font-size:13px&quot;>parallel over tokens T</font>" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=18;" vertex="1" parent="1"><mxGeometry x="270" y="100" width="210" height="90" as="geometry"/></mxCell>
