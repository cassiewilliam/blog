        <mxCell id="v2" value="" style="rounded=0;fillColor=#fff;strokeColor=none;html=1;" vertex="1" parent="1"><mxGeometry x="0.0" y="0.0" width="1200.0" height="660.0" as="geometry"/></mxCell><mxCell id="v3" value="为什么需要 STE，为什么 NVFP4 又不需要 · 数学对比" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontColor=#111827;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="446.5" y="8.84" width="307" height="22" as="geometry"/></mxCell><mxCell id="v4" value="核心：round() 导数为 0 → 梯度消失 → 用 STE 假装是恒等 · NVFP4 用随机 rounding 让 round 期望就是恒等" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#6b7280;" vertex="1" parent="1"><mxGeometry x="351.5" y="34.3" width="497" height="15" as="geometry"/></mxCell><mxCell id="v5" value="" style="rounded=1;arcSize=5;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=1.4;html=1;" vertex="1" parent="1"><mxGeometry x="40.0" y="72.0" width="540.0" height="560.0" as="geometry"/></mxCell><mxCell id="v6" value="确定性 round + STE" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#7a2f2b;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="245.0" y="83.18" width="130" height="19" as="geometry"/></mxCell><mxCell id="v7" value="V4 MXFP4 / LMSYS INT4 / 经典 QAT" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#7a2f2b;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="212.5" y="107.08" width="195" height="14" as="geometry"/></mxCell><mxCell id="v8" value="[前向] round-to-nearest" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#7a2f2b;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60.0" y="135.52" width="156" height="16" as="geometry"/></mxCell><mxCell id="v9" value="" style="rounded=1;arcSize=15;fillColor=#fff;strokeColor=#333;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="80.0" y="164.0" width="460.0" height="40.0" as="geometry"/></mxCell><mxCell id="v10" value="Q(x) = round(x · scale) / scale" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#111;" vertex="1" parent="1"><mxGeometry x="175.5" y="173.18" width="269" height="19" as="geometry"/></mxCell><mxCell id="v11" value="每步固定地把 x 投到最近的可表示点" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#7a2f2b;" vertex="1" parent="1"><mxGeometry x="249.0" y="208.3" width="122" height="15" as="geometry"/></mxCell><mxCell id="v12" value="" style="rounded=0;fillColor=#fff;strokeColor=#9ca3af;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="100.0" y="248.0" width="200.0" height="120.0" as="geometry"/></mxCell><mxCell id="v13" value="" style="endArrow=none;strokeColor=#333;strokeWidth=1;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="120.0" y="348.0" as="sourcePoint"/><mxPoint x="280.0" y="348.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v14" value="" style="endArrow=none;strokeColor=#333;strokeWidth=1;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="120.0" y="268.0" as="sourcePoint"/><mxPoint x="120.0" y="348.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v15" value="x" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontColor=#555;" vertex="1" parent="1"><mxGeometry x="100.0" y="353.64" width="40" height="12" as="geometry"/></mxCell><mxCell id="v16" value="Q(x)" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontColor=#555;" vertex="1" parent="1"><mxGeometry x="74.0" y="260.64" width="40" height="12" as="geometry"/></mxCell><mxCell id="v17" value="" style="endArrow=none;strokeColor=#b85450;strokeWidth=2;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="120.0" y="348.0" as="sourcePoint"/><mxPoint x="280.0" y="268.0" as="targetPoint"/><Array as="points"><mxPoint x="150.0" y="348.0"/><mxPoint x="150.0" y="328.0"/><mxPoint x="180.0" y="328.0"/><mxPoint x="180.0" y="308.0"/><mxPoint x="210.0" y="308.0"/><mxPoint x="210.0" y="288.0"/><mxPoint x="240.0" y="288.0"/><mxPoint x="240.0" y="268.0"/></Array></mxGeometry></mxCell><mxCell id="v18" value="阶梯函数 · 平台导数 = 0" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#7a2f2b;" vertex="1" parent="1"><mxGeometry x="153.5" y="372.08" width="93" height="14" as="geometry"/></mxCell><mxCell id="v19" value="" style="rounded=0;fillColor=#fff;strokeColor=#9ca3af;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="320.0" y="248.0" width="200.0" height="120.0" as="geometry"/></mxCell><mxCell id="v20" value="" style="endArrow=none;strokeColor=#333;strokeWidth=1;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="340.0" y="348.0" as="sourcePoint"/><mxPoint x="500.0" y="348.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v21" value="" style="endArrow=none;strokeColor=#333;strokeWidth=1;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="340.0" y="268.0" as="sourcePoint"/><mxPoint x="340.0" y="348.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v22" value="x" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontColor=#555;" vertex="1" parent="1"><mxGeometry x="320.0" y="353.64" width="40" height="12" as="geometry"/></mxCell><mxCell id="v23" value="dQ/dx" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontColor=#555;" vertex="1" parent="1"><mxGeometry x="294.0" y="260.64" width="40" height="12" as="geometry"/></mxCell><mxCell id="v24" value="" style="endArrow=none;strokeColor=#b85450;strokeWidth=2;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="340.0" y="348.0" as="sourcePoint"/><mxPoint x="500.0" y="348.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v25" value="" style="endArrow=none;strokeColor=#b85450;strokeWidth=1.5;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="370.0" y="348.0" as="sourcePoint"/><mxPoint x="370.0" y="268.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v26" value="" style="endArrow=none;strokeColor=#b85450;strokeWidth=1.5;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="400.0" y="348.0" as="sourcePoint"/><mxPoint x="400.0" y="268.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v27" value="" style="endArrow=none;strokeColor=#b85450;strokeWidth=1.5;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="430.0" y="348.0" as="sourcePoint"/><mxPoint x="430.0" y="268.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v28" value="" style="endArrow=none;strokeColor=#b85450;strokeWidth=1.5;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="460.0" y="348.0" as="sourcePoint"/><mxPoint x="460.0" y="268.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v29" value="几乎处处 = 0 · 边界为 δ" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#7a2f2b;" vertex="1" parent="1"><mxGeometry x="370.5" y="372.08" width="99" height="14" as="geometry"/></mxCell><mxCell id="v30" value="[反向] 梯度消失！" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#7a2f2b;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60.0" y="383.52" width="74" height="16" as="geometry"/></mxCell><mxCell id="v31" value="" style="rounded=1;arcSize=10;fillColor=#fff;strokeColor=#333;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="80.0" y="410.0" width="460.0" height="60.0" as="geometry"/></mxCell><mxCell id="v32" value="∂L/∂W_master = ∂L/∂W_q · ∂W_q/∂W_master" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#7a2f2b;" vertex="1" parent="1"><mxGeometry x="171.0" y="419.52" width="278" height="16" as="geometry"/></mxCell><mxCell id="v33" value="∂W_q/∂W_master ≈ 0 (a.e.) → 梯度被零乘掉" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#b85450;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="189.0" y="439.52" width="242" height="16" as="geometry"/></mxCell><mxCell id="v34" value="[STE 补丁] 假装是恒等" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#7a2f2b;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60.0" y="483.52" width="104" height="16" as="geometry"/></mxCell><mxCell id="v35" value="" style="rounded=1;arcSize=6;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=2;html=1;" vertex="1" parent="1"><mxGeometry x="80.0" y="510.0" width="460.0" height="86.0" as="geometry"/></mxCell><mxCell id="v36" value="∂W_q/∂W_master := 1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#7a2f2b;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="233.5" y="517.96" width="153" height="18" as="geometry"/></mxCell><mxCell id="v37" value="⇒ ∂L/∂W_master = ∂L/∂W_q   (直接透传)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#7a2f2b;" vertex="1" parent="1"><mxGeometry x="197.5" y="538.3" width="225" height="15" as="geometry"/></mxCell><mxCell id="v38" value="数学上是错的（round 导数明明是 0）" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#7a2f2b;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="242.0" y="559.08" width="136" height="14" as="geometry"/></mxCell><mxCell id="v39" value="实际可行：单步偏差小、多步平均近零" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#7a2f2b;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="255.0" y="575.08" width="110" height="14" as="geometry"/></mxCell><mxCell id="v40" value="" style="rounded=1;arcSize=5;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=1.4;html=1;" vertex="1" parent="1"><mxGeometry x="620.0" y="72.0" width="540.0" height="560.0" as="geometry"/></mxCell><mxCell id="v41" value="随机 rounding · 不需要 STE" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#1a5c1a;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="799.0" y="83.18" width="182" height="19" as="geometry"/></mxCell><mxCell id="v42" value="NVFP4 (NVIDIA Blackwell 预训练 recipe)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#1a5c1a;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="776.5" y="107.08" width="227" height="14" as="geometry"/></mxCell><mxCell id="v43" value="[前向 (gradient 路径)] stochastic rounding" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#1a5c1a;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="640.0" y="135.52" width="282" height="16" as="geometry"/></mxCell><mxCell id="v44" value="" style="rounded=1;arcSize=10;fillColor=#fff;strokeColor=#333;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="660.0" y="164.0" width="460.0" height="60.0" as="geometry"/></mxCell><mxCell id="v45" value="stoch_round(x) = ⌊x⌋ w.p. (⌈x⌉ - x)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#111;" vertex="1" parent="1"><mxGeometry x="749.0" y="171.96" width="282" height="18" as="geometry"/></mxCell><mxCell id="v46" value="⌈x⌉ w.p. (x - ⌊x⌋)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#111;" vertex="1" parent="1"><mxGeometry x="817.5" y="191.96" width="145" height="18" as="geometry"/></mxCell><mxCell id="v47" value="" style="rounded=1;arcSize=12;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=2;html=1;" vertex="1" parent="1"><mxGeometry x="660.0" y="238.0" width="460.0" height="50.0" as="geometry"/></mxCell><mxCell id="v48" value="关键性质：E[ stoch_round(x) ] = x" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#1a5c1a;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="777.5" y="245.96" width="225" height="18" as="geometry"/></mxCell><mxCell id="v49" value="即「期望意义上的恒等函数」（unbiased estimator）" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a5c1a;" vertex="1" parent="1"><mxGeometry x="777.5" y="266.3" width="225" height="15" as="geometry"/></mxCell><mxCell id="v50" value="" style="rounded=0;fillColor=#fff;strokeColor=#9ca3af;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="680.0" y="304.0" width="200.0" height="100.0" as="geometry"/></mxCell><mxCell id="v51" value="" style="endArrow=none;strokeColor=#333;strokeWidth=1;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="700.0" y="384.0" as="sourcePoint"/><mxPoint x="860.0" y="384.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v52" value="" style="endArrow=none;strokeColor=#333;strokeWidth=1;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="700.0" y="324.0" as="sourcePoint"/><mxPoint x="700.0" y="384.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v53" value="" style="endArrow=none;strokeColor=#9ca3af;strokeWidth=1;dashed=1;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="740.0" y="384.0" as="sourcePoint"/><mxPoint x="740.0" y="324.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v54" value="" style="endArrow=none;strokeColor=#9ca3af;strokeWidth=1;dashed=1;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="800.0" y="384.0" as="sourcePoint"/><mxPoint x="800.0" y="324.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v55" value="⌊x⌋" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontColor=#555;" vertex="1" parent="1"><mxGeometry x="720.0" y="386.64" width="40" height="12" as="geometry"/></mxCell><mxCell id="v56" value="⌈x⌉" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontColor=#555;" vertex="1" parent="1"><mxGeometry x="780.0" y="386.64" width="40" height="12" as="geometry"/></mxCell><mxCell id="v57" value="" style="endArrow=none;strokeColor=#5fa55f;strokeWidth=2;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="760.0" y="382.0" as="sourcePoint"/><mxPoint x="760.0" y="344.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v58" value="x" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontColor=#1a5c1a;" vertex="1" parent="1"><mxGeometry x="740.0" y="329.64" width="40" height="12" as="geometry"/></mxCell><mxCell id="v59" value="" style="rounded=0;fillColor=#5fa55f;strokeColor=none;html=1;" vertex="1" parent="1"><mxGeometry x="735.0" y="356.0" width="10.0" height="28.0" as="geometry"/></mxCell><mxCell id="v60" value="66%" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=8;fontColor=#1a5c1a;" vertex="1" parent="1"><mxGeometry x="720.0" y="343.42" width="40" height="11" as="geometry"/></mxCell><mxCell id="v61" value="" style="rounded=0;fillColor=#5fa55f;strokeColor=none;html=1;" vertex="1" parent="1"><mxGeometry x="795.0" y="368.0" width="10.0" height="16.0" as="geometry"/></mxCell><mxCell id="v62" value="33%" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=8;fontColor=#1a5c1a;" vertex="1" parent="1"><mxGeometry x="780.0" y="355.42" width="40" height="11" as="geometry"/></mxCell><mxCell id="v63" value="直观：" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a5c1a;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="900.0" y="312.3" width="40" height="15" as="geometry"/></mxCell><mxCell id="v64" value="x = 0.66 → 以 66% 概率舍到 0，" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#1a5c1a;" vertex="1" parent="1"><mxGeometry x="900.0" y="331.08" width="148" height="14" as="geometry"/></mxCell><mxCell id="v65" value="以 33% 概率舍到 1" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#1a5c1a;" vertex="1" parent="1"><mxGeometry x="900.0" y="347.08" width="74" height="14" as="geometry"/></mxCell><mxCell id="v66" value="期望 = 0×0.66 + 1×0.33 ≈ 0.33" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#1a5c1a;" vertex="1" parent="1"><mxGeometry x="900.0" y="369.08" width="167" height="14" as="geometry"/></mxCell><mxCell id="v67" value="… 等等？！" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#7a4e00;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="900.0" y="385.08" width="40" height="14" as="geometry"/></mxCell><mxCell id="v68" value="注：上图为离散网格示意，" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontColor=#1a5c1a;" vertex="1" parent="1"><mxGeometry x="900.0" y="402.64" width="66" height="12" as="geometry"/></mxCell><mxCell id="v69" value="实际是 ⌊⌉ 的概率应反过来。" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontColor=#1a5c1a;" vertex="1" parent="1"><mxGeometry x="900.0" y="416.64" width="83" height="12" as="geometry"/></mxCell><mxCell id="v70" value="[反向] 梯度自然通过" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#1a5c1a;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="640.0" y="419.52" width="81" height="16" as="geometry"/></mxCell><mxCell id="v71" value="" style="rounded=1;arcSize=5;fillColor=#fff;strokeColor=#333;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="660.0" y="446.0" width="460.0" height="120.0" as="geometry"/></mxCell><mxCell id="v72" value="把 stoch_round 写成 W_q = W_master + ε  (E[ε]=0)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#111;" vertex="1" parent="1"><mxGeometry x="737.0" y="454.3" width="306" height="15" as="geometry"/></mxCell><mxCell id="v73" value="y = matmul(W_q, x) = matmul(W_master + ε, x)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#111;" vertex="1" parent="1"><mxGeometry x="740.0" y="474.3" width="300" height="15" as="geometry"/></mxCell><mxCell id="v74" value="∂L/∂W_master = ∂L/∂y · x  +  E[∂ε/∂W_master · …]" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a5c1a;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="726.5" y="494.3" width="327" height="15" as="geometry"/></mxCell><mxCell id="v75" value="= ∂L/∂y · x  (噪声项期望 = 0)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a5c1a;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="808.5" y="514.3" width="163" height="15" as="geometry"/></mxCell><mxCell id="v76" value="无需任何「假定 ∂Q/∂x = 1」的作弊" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#1a5c1a;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="822.0" y="539.08" width="136" height="14" as="geometry"/></mxCell><mxCell id="v77" value="⇒ STE 在 NVFP4 体系下「不必要、有时反而损害精度」" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a5c1a;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="640.0" y="577.52" width="221" height="16" as="geometry"/></mxCell><mxCell id="v78" value="— NVIDIA Nemotron QAD blog" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#1a5c1a;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="640.0" y="597.08" width="161" height="14" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
