  <diagram id="page05-runtime" name="05 Runtime SHMEM 生命周期">
    <mxGraphModel dx="1242" dy="799" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
