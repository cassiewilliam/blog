tency_rdma_size_hint()" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#555;" vertex="1" parent="1"><mxGeometry x="71.0" y="199.52" width="238" height="16" as="geometry"/></mxCell><mxCell id="v11" value="" style="rounded=1;arcSize=7;fillColor=#fff;strokeColor=#4a6fd3;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="80.0" y="240.0" width="220.0" height="55.0" as="geometry"/></mxCell><mxCell id="v12" value="Expert Staging" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="138.0" y="251.52" width="104" height="16" as="geometry"/></mxCell><mxCell id="v13" value="(2, max_m, hidden) · DBO dim0" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#555;" vertex="1" parent="1"><mxGeometry x="82.5" y="269.52" width="215" height="16" as="geometry"/></mxCell><mxCell id="v14" value="" style="rounded=1;arcSize=5;fillColor=#fffcf1;strokeColor=#d9b860;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="400.0" y="60.0" width="540.0" height="280.0" as="geometry"/></mxCell><mxCell id="v15" value="关键启发式" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#7a4e00;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="650.0" y="69.52" width="40" height="16" as="geometry"/></mxCell><mxCell id="v16" value="num_nvl_bytes        = VLLM_DEEPEP_BUFFER_SIZE_MB &lt;&lt; 20   (≈ 1 GB)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="420.0" y="97.52" width="491" height="16" as="geometry"/></mxCell><mxCell id="v17" value="num_rdma_bytes       = get_low_latency_rdma_size_hint(max_tokens, H, ranks)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="420.0" y="119.52" width="558" height="16" as="geometry"/></mxCell><mxCell id="v18" value="num_qps_per_rank     = 64                    ← 固定多 QP，分摊 RDMA 延迟" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="420.0" y="141.52" width="476" height="16" as="geometry"/></mxCell><mxCell id="v19" value="low_latency_mode     = True                  ← cooperative kernel" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="420.0" y="163.52" width="483" height="16" as="geometry"/></mxCell><mxCell id="v20" value="allow_nvlink_for_ll  = True                  ← 同 Node 走 NVLink" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="420.0" y="185.52" width="461" height="16" as="geometry"/></mxCell><mxCell id="v21" value="num_sms (comm)       = 0                     ← 不占算力 SM，全靠 RDMA HW" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="420.0" y="207.52" width="483" height="16" as="geometry"/></mxCell><mxCell id="v22" value="max_m                = 256 (或其它 2 幂)     ← Masked 的 m 维" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="420.0" y="229.52" width="409" height="16" as="geometry"/></mxCell><mxCell id="v23" value="staging dim0         = 2                     ← DBO micro-batch 双 buffer" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="420.0" y="251.52" width="528" height="16" as="geometry"/></mxCell><mxCell id="v24" value="★ LL 模式下 dispatch / combine 几乎不占用 SM，释放 SM 给 Expert Compute" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#7a4e00;" vertex="1" parent="1"><mxGeometry x="451.0" y=