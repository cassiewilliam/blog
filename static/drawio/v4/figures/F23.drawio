ell><mxCell id="v32" value="∂L / ∂W_FP8 is already produced by the standard FP8 kernel and routed directly back to FP32 master W" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="248.3" width="682" height="15" as="geometry"/></mxCell><mxCell id="v33" value="⇒ no transposed re-quant, no backward kernel change — the entire FP8 training stack works unmodified" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#a33ea1;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="264.3" width="682" height="15" as="geometry"/></mxCell><mxCell id="v34" value="" style="rounded=1;arcSize=5;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="30.0" y="300.0" width="510.0" height="180.0" as="geometry"/></mxCell><mxCell id="v35" value="Inference / RL rollout" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="200.0" y="308.74" width="170" height="17" as="geometry"/></mxCell><mxCell id="v36" value="• weights shipped as real FP4 (not simulated)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="333.3" width="306" height="15" as="geometry"/></mxCell><mxCell id="v37" value="• MXFP4 × FP8 GEMM kernel in DeepGEMM" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="351.3" width="252" height="15" as="geometry"/></mxCell><mxCell id="v38" value="• current HW: peak FLOPs same as FP8 × FP8" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="369.3" width="286" height="15" as="geometry"/></mxCell><mxCell id="v39" value="• future HW: FP4×FP8 can be 1/3 more efficient" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="387.3" width="313" height="15" as="geometry"/></mxCell><mxCell id="v40" value="• kernel memory loading halved vs FP8 weights" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="409.3" width="306" height="15" as="geometry"/></mxCell><mxCell id="v41" value="→ rollout logits match training exactly (same path as forward)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#b85450;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="45.0" y="433.3" width="422" height="15" as="geometry"/></mxCell><mxCell id="v42" value="→ consistent with batch-invariant kernel library" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#b85450;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="45.0" y="453.3" width="327" height="15" as="geometry"/></mxCell><mxCell id="v43" value="" style="rounded=1;arcSize=5;fillColor=#eef7ee;strokeColor=#5fa55f;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="570.0" y="300.0" width="500.0" height="180.0" as="geometry"/></mxCell><mxCell id="v44" value="CSA lightning-indexer QK path (FP4 everywhere)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="642.0" y="308.74" width="356" height="17" as="geometry"/></mxCell><mxCell id="v45" value="• indexer Q quantized FP8/FP4 in fused kernel" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="333.3" width="306" height="15" as="geometry"/></mxCell><mxCell id="v46" value="• indexer K cached FP4 in DeepseekV4IndexerCache" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="351.3" width="327" height="15" as="geometry"/></mxCell><mxCell id="v47" value="• matmul FP4 × FP4 → fp8_mqa_logits emits logits" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="369.3" width="327" height="15" as="geometry"/></mxCell><mxCell id="v48" value="• index scores I_{:,:} further FP32 → BF16" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="387.3" width="286" height="15" as="geometry"/></mxCell><mxCell id="v49" value="• top-k selector: 2× faster with BF16 scores" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="409.3" width="300" height="15" as="geometry"/></mxCell><mxCell id="v50" value="→ recall of compressed KV entries stays 99.7%" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a3d1a;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="585.0" y="433.3" width="306" height="15" as="geometry"/></mxCell><mxCell id="v51" value="→ this is the only place V4 uses FP4 at inference outside MoE" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a3d1a;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="585.0" y="453.3" width="416" height="15" as="geometry"/></mxCell>
