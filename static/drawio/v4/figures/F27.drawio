s="targetPoint"/></mxGeometry></mxCell><mxCell id="v10" value="" style="rounded=0;fillColor=#eef3ff;strokeColor=#4a6fd3;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="30.0" y="60.0" width="200.0" height="28.0" as="geometry"/></mxCell><mxCell id="v11" value="prefetch data for step t" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="52.0" y="67.08" width="156" height="14" as="geometry"/></mxCell><mxCell id="v12" value="" style="endArrow=classic;strokeColor=#4a6fd3;strokeWidth=1;dashed=1;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="230.0" y="74.0" as="sourcePoint"/><mxPoint x="540.0" y="74.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v13" value="" style="rounded=0;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="245.0" y="60.0" width="250.0" height="28.0" as="geometry"/></mxCell><mxCell id="v14" value="compute routing on θ_{t−Δt}" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="282.5" y="67.08" width="175" height="14" as="geometry"/></mxCell><mxCell id="v15" value="" style="rounded=0;fillColor=#f9eef8;strokeColor=#a33ea1;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="540.0" y="60.0" width="400.0" height="28.0" as="geometry"/></mxCell><mxCell id="v16" value="step t:  features on θ_t  +  prefetched routing indices  → loss + bwd" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="515.5" y="67.08" width="449" height="14" as="geometry"/></mxCell><mxCell id="v17" value="" style="rounded=1;arcSize=5;fillColor=#fff4e0;strokeColor=#e0b300;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="30.0" y="160.0" width="510.0" height="170.0" as="geometry"/></mxCell><mxCell id="v18" value="Why it works" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="237.0" y="167.96" width="96" height="18" as="geometry"/></mxCell><mxCell id="v19" value="• conventional: features + routing both driven by θ_t" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="194.3" width="361" height="15" as="geometry"/></mxCell><mxCell id="v20" value="→ outlier in θ_t creates self-reinforcing loop via router" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="212.3" width="388" height="15" as="geometry"/></mxCell><mxCell id="v21" value="• V4: decouple synchronous update of backbone and router" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="230.3" width="381" height="15" as="geometry"/></mxCell><mxCell id="v22" value="• routing decisions use θ_{t−Δt} (already stable)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="248.3" width="334" height="15" as="geometry"/></mxCell><mxCell id="v23" value="→ breaks the outlier → expert imbalance → bigger outlier cycle" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#7a4e00;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="268.3" width="422" height="15" as="geometry"/></mxCell><mxCell id="v24" value="→ empirical: loss spikes around step 12k disappear" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#7a4e00;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="288.3" width="341" height="15" as="geometry"/></mxCell><mxCell id="v25" value="" style="rounded=1;arcSize=5;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="570.0" y="160.0" width="500.0" height="170.0" as="geometry"/></mxCell><mxCell id="v26" value="Engineering cost &amp; trigger" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="715.5" y="167.96" width="209" height="18" as="geometry"/></mxCell><mxCell id="v27" value="• extra forward pass for routing = ≈ 20% wall time if always on" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="194.3" width="429" height="15" as="geometry"/></mxCell><mxCell id="v28" value="• V4 triggers Anticipatory Routing ONLY on detected loss spike" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="212.3" width="422" height="15" as="geometry"/></mxCell><mxCell id="v29" value="• system rolls back, activates, runs a short window, then reverts" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="230.3" width="443" height="15" as="geometry"/></mxCell><mxCell id="v30" value="• amortized wall-time overhead ≈ 0" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="248.3" width="231" height="15" as="geometry"/></mxCell><mxCell id="v31" value="• pipeline carefully orchestrated with EP comm overlap" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="268.3" width="368" height="15" as="geometry"/></mxCell><mxCell id="v32" value="→ opportunistic fix: production uses it when needed, not by default" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a3d1a;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="288.3" width="456" height="15" as="geometry"/></mxCell>
