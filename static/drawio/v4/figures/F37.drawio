0;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="285.0" y="449.08" width="117" height="14" as="geometry"/></mxCell><mxCell id="v58" value="" style="ellipse;fillColor=#b85450;strokeColor=#fff;strokeWidth=2;html=1;" vertex="1" parent="1"><mxGeometry x="934.0" y="151.0" width="22.0" height="22.0" as="geometry"/></mxCell><mxCell id="v59" value="Rubin Ultra (next-next gen)" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#7a2f2b;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="733.0" y="137.52" width="200" height="16" as="geometry"/></mxCell><mxCell id="v60" value="35 PFLOPs · 3600 GB/s · NVLink 7" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#7a2f2b;" vertex="1" parent="1"><mxGeometry x="725.0" y="155.08" width="208" height="14" as="geometry"/></mxCell><mxCell id="v61" value="余量 0.62×（穿过阈值，BW 不足）" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#7a2f2b;" vertex="1" parent="1"><mxGeometry x="797.0" y="170.3" width="136" height="15" as="geometry"/></mxCell><mxCell id="v62" value="" style="endArrow=none;strokeColor=#a33ea1;strokeWidth=1.2;dashed=1;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="945.0" y="162.0" as="sourcePoint"/><mxPoint x="945.0" y="132.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v63" value="" style="ellipse;fillColor=#a33ea1;strokeColor=#fff;strokeWidth=1.5;html=1;" vertex="1" parent="1"><mxGeometry x="941.0" y="128.0" width="8.0" height="8.0" as="geometry"/></mxCell><mxCell id="v64" value="阈值要求: 5833 GB/s" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontColor=#a33ea1;" vertex="1" parent="1"><mxGeometry x="845.0" y="117.86" width="88" height="13" as="geometry"/></mxCell><mxCell id="v65" value="" style="endArrow=none;strokeColor=#9ca3af;strokeWidth=1.4;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="186.0" y="414.0" as="sourcePoint"/><mxPoint x="945.0" y="162.0" as="targetPoint"/><Array as="points"><mxPoint x="244.0" y="378.0"/></Array></mxGeometry></mxCell><mxCell id="v66" value="代际算力轨迹（同比例外推）" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#6b7280;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="580.0" y="258.3" width="88" height="15" as="geometry"/></mxCell><mxCell id="v67" value="" style="rounded=1;arcSize=8;fillColor=#f9fafb;strokeColor=#e5e7eb;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="60.0" y="516.0" width="980.0" height="92.0" as="geometry"/></mxCell><mxCell id="v68" value="• ：V4-Pro MoE 的通信可以完全藏在计算之下，NVLink 不是瓶颈。" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#333;" vertex="1" parent="1"><mxGeometry x="80.0" y="523.52" width="285" height="16" as="geometry"/></mxCell><mxCell id="v69" value="• （FP8 4.5P / NVLink 900 GB/s 都不变）；B300 升级在 FP4 (+50%) 与 HBM (180→288 GB)，对 V4 MoE 的 C/B 故事不变。" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#333;" vertex="1" parent="1"><mxGeometry x="80.0" y="541.52" width="670" height="16" as="geometry"/></mxCell><mxCell id="v70" value="• ：FP8 涨 7.8×（4.5 → 35P）但 NVLink 只涨 4×（900 → 3600 GB/s）→ 余量从 1.20× 跌到 0.62×。" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#333;" vertex="1" parent="1"><mxGeometry x="80.0" y="559.52" width="541" height="16" as="geometry"/></mxCell><mxCell id="v71" value="• 论文 §3.1.2 ① 真正预言的时刻：，从 Rubin 代起按 C/B 阈值重新平衡硬件设计成为必需。" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#333;" vertex="1" parent="1"><mxGeometry x="80.0" y="577.52" width="385" height="16" as="geometry"/></mxCell>
