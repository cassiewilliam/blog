        <mxCell id="v2" value="Output-Stationary 调度 · 同一个 pool_block 的 token 从 Linear1 到 Linear2 都在同一个 SM" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#1f3a6f;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="179.0" y="7.18" width="642" height="19" as="geometry"/></mxCell><mxCell id="v3" value="" style="rounded=1;arcSize=5;fillColor=#d5e8d4;strokeColor=#5fa55f;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="30.0" y="50.0" width="280.0" height="170.0" as="geometry"/></mxCell><mxCell id="v4" value="SM 0 (pool_block 0)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#1f5d1f;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="99.5" y="59.519999999999996" width="141" height="16" as="geometry"/></mxCell><mxCell id="v5" value="Linear1：读 x[tk 0..63] · W₁" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="38.0" y="83.52" width="193" height="16" as="geometry"/></mxCell><mxCell id="v6" value="→ TMEM[0..N] 累加" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="38.0" y="101.52" width="111" height="16" as="geometry"/></mxCell><mxCell id="v7" value="L1 epi：SwiGLU → FP8 → SMEM + HBM" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="38.0" y="119.52" width="238" height="16" as="geometry"/></mxCell><mxCell id="v8" value="Linear2：读 本地 SMEM · W₂" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="38.0" y="139.52" width="163" height="16" as="geometry"/></mxCell><mxCell id="v9" value="→ TMEM 第二段累加" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry 