        <mxCell id="nvl_label2" value="&lt;font color=&quot;#1565C0&quot; style=&quot;font-size:9px&quot;&gt;&lt;b&gt;NVLink&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" parent="1" vertex="1">
