        <mxCell id="dbo_g_res0" value="&lt;font style=&quot;font-size:8px&quot;&gt;Res&lt;br&gt;ub0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=8;" parent="1" vertex="1">
