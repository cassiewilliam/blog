eometry"/></mxCell><mxCell id="v9" value="DSML marker 不被识别 → 不被跳过 ✓" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#4a1515;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="40.0" y="169.08" width="162" height="14" as="geometry"/></mxCell><mxCell id="v10" value="但是 streaming detokenize 在某些路径上对" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#4a1515;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="40.0" y="189.08" width="201" height="14" as="geometry"/></mxCell><mxCell id="v11" value="未注册 marker 的 byte-level 缓冲处理不一致" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#4a1515;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="40.0" y="205.08" width="201" height="14" as="geometry"/></mxCell><mxCell id="v12" value="→ 部分 chunk 提前 emit &quot;&lt;&quot;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#4a1515;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="40.0" y="229.08" width="143" height="14" as="geometry"/></mxCell><mxCell id="v13" value="→ 后续 chunk emit &quot;DS&quot;、&quot;ML&quot;..." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#4a1515;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="40.0" y="247.08" width="182" height="14" as="geometry"/></mxCell><mxCell id="v14" value="客户端 detector 在 substring 匹配前可能" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#4a1515;fontStyle=2;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="40.0" y="267.08" width="195" height="14" as="geometry"/></mxCell><mxCell id="v15" value="看到拆碎的 marker" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#4a1515;fontStyle=2;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="40.0" y="282.08" width="78" height="14" as="geometry"/></mxCell><mxCell id="v16" value="" style="rounded=1;arcSize=5;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="500.0" y="120.0" width="460.0" height="180.0" as="geometry"/></mxCell><mxCell id="v17" value="skip_special_tokens=False（V32/V4 强制）" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#1a3d1a;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="520.0" y="128.74" width="279" height="17" as="geometry"/></mxCell><mxCell id="v18" value="deepseekv32_tool_parser.py:adjust_request" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#1a3d1a;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="520.0" y="149.08" width="266" height="14" as="geometry"/></mxCell><mxCell id="v19" value="关掉 skip 之后：" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#1a3d1a;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="520.0" y="169.08" width="71" height="14" as="geometry"/></mxCell><mxCell id="v20" value="• BOS/EOS 也不跳过（小代价）" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#1a3d1a;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="520.0" y="189.08" width="123" height="14" as="geometry"/></mxCell><mxCell id="v21" value="• DSML marker 一定被忠实输出" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#1a3d1a;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="520.0" y="209.08" width="136" height="14" as="geometry"/></mxCell><mxCell id="v22" value="• 副作用：transformers 5.x detokenizer" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#1a3d1a;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="520.0" y="229.08" width="221" height="14" as="geometry"/></mxCell><mxCell id="v23" value="在某些版本下对 byte-level chunked decode" style="text;html=1;align=left;verticalAlign=middle;whi