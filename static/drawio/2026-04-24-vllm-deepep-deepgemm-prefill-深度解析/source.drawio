        <mxCell id="nvl_label3" value="&lt;font color=&quot;#1565C0&quot; style=&quot;font-size:9px&quot;&gt;&lt;b&gt;NVLink&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="575" y="305" width="50" height="15" as="geometry" />
