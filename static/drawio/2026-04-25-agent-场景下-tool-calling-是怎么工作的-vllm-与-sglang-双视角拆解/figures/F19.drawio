        <mxCell id="v2" value="" style="rounded=1;arcSize=12;fillColor=#eef3ff;strokeColor=#4a6fd3;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="20.0" y="20.0" width="940.0" height="50.0" as="geometry"/></mxCell><mxCell id="v3" value="Layer 1 · 用户 / Client UI" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#1a2d55;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="40.0" y="27.96" width="193" height="18" as="geometry"/></mxCell><mxCell id="v4" value="浏览器、CLI、IDE 插件 — 发起 &quot;请帮我查 X&quot; 这种自然语言指令" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a2d55;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="40.0" y="48.3" width="252" height="15" as="geometry"/></mxCell><mxCell id="v5" value="React / iOS / VSCode" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a2d55;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="714.0" y="36.3" width="136" height="15" as="geometry"/></mxCell><mxCell id="v6" value="" style="rounded=1;arcSize=7;fillColor=#f9eef8;strokeColor=#a33ea1;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="20.0" y="90.0" width="940.0" height="80.0" as="geometry"/></mxCell><mxCell id="v7" value="Layer 2 · Agent Runtime（这一层执行 tool 函数 + 控制 loop）" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#4a1a48;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="40.0" y="97.96" width="386" height="18" as="geometry"/></mxCell><mxCell id="v8" value="• 维护 messages 状态、按 finish_reason 决定是否再调一次 LLM" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#4a1a48;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="40.0" y="118.3" width="306" height="15" as="geometry"/></mxCell><mxCell id="v9" value="• 用 ToolRegistry 找到 tool 函数、async 并行执行多个工具" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#4a1a48;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="40.0" y="134.3" width="286" height="15" as="geometry"/></mxCell><mxCell id="v10" value="• 把结果写回 role=tool 消息、回灌到下一轮请求" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#4a1a48;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="40.0" y="150.3" width="197" height="15" as="geometry"/></mxCell><mxCell id="v11" value="LangGraph / Claude SDK" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#4a1a48;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="700.0" y="118.3" width="150" height="15" as="geometry"/></mxCell><mxCell id="v12" value="OpenAI Agents SDK" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#4a1a48;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="735.0" y="134.3" width="115" height="15" as="geometry"/></mxCell><mxCell id="v13" value="自研 asyncio loop" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#4a1a48;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="748.0" y="150.3" width="102" height="15" as="geometry"/></mxCell><mxCell id="v14" value="" style="rounded=1;arcSize=7;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="20.0" y="190.0" width="940.0" height="80.0" as="geometry"/></mxCell><mxCell id="v15" value="Layer 3 · LLM Serving（无状态 HTTP）" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#4a1515;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="40.0" y="197.96" width="249" height="18" as="geometry"/></mxCell><mxCell id="v16" value="• OpenAI 兼容 endpoint：/v1/chat/completions、/v1/completions" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#4a1515;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="40.0" y="218.3" width="388" height="15" as="geometry"/></mxCell><mxCell id="v17" value="• 收到请求 → render chat template → tokenize → 提交 engine" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#4a1515;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="40.0" y="234.3" width="354" height="15" as="geometry"/></mxCell><mxCell id="v18" value="• 流式 emit SSE → detokenize → tool parser → 客户端" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#4a1515;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="40.0" y="250.3" width="313" height="15" as="geometry"/></mxCell><mxCell id="v19" value="vLLM 0.x" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#4a1515;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="796.0" y="218.3" width="54" height="15" as="geometry"/></mxCell><mxCell id="v20" value="sglang" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#4a1515;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="810.0" y="234.3" width="40" height="15" as="geometry"/></mxCell><mxCell id="v21" value="TensorRT-LLM / lmdeploy" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#4a1515;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="694.0" y="250.3" width="156" height="15" as="geometry"/></mxCell><mxCell id="v22" value="" style="rounded=1;arcSize=10;fillColor=#fff8e7;strokeColor=#e0b300;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="20.0" y="290.0" width="940.0" height="60.0" as="geometry"/></mxCell><mxCell id="v23" value="Layer 4 · GPU Engine" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#5a3f00;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="40.0" y="297.96" width="161" height="18" as="geometry"/></mxCell><mxCell id="v24" value="paged attention / chunked prefi