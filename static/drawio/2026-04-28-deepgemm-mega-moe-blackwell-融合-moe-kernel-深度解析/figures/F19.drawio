<mxfile host="app.diagrams.net" agent="svg2drawio" version="22.0.0">
  <diagram id="conv" name="Page-1">
    <mxGraphModel dx="1000" dy="230" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="230" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="v2" value="Swap A/B：B 做 multicast 操作数，让权重而非激活走 2-CTA 广播" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#1f3a6f;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="309.5" y="7.18" width="381" height="19" as="geometry"/></mxCell><mxCell id="v3" value="" style="rounded=1;arcSize=5;fillColor=#fde2e4;strokeColor=#b85450;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="40.0" y="50.0" width="420.0" height="150.0" as="geometry"/></mxCell><mxCell id="v4" value="默认：A = activations, B = weights" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#4a1515;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="135.0" y="57.519999999999996" width="230" height="16" as="geometry"/></mxCell><mxCell id="v5" value="A = [M×K]  per-CTA 独立（每 CTA 读自己的 token 分片）" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="50.0" y="83.52" width="312" height="16" as="geometry"/></mxCell><mxCell id="v6" value="B = [N×K]  multicast 候选（两 CTA 共享同一 weights）" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="50.0" y="101.52" width="319" height="16" as="geometry"/></mxCell><mxCell id="v7" value="问题：" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#b85450;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50.0" y="127.52" width="40" height="16" as="geometry"/></mxCell><mxCell id="v8" value="MoE decode/小 batch 下，M 小 (≤BLOCK_M) → A 也很小" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="50.0" y="145.52" width="319" height="16" as="geometry"/></mxCell><mxCell id="v9" value="B (权重) 反而是 HBM 大头，但它&quot;本来就应该 multicast&quot;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="50.0" y="163.52" width="275" height="16" as="geometry"/></mxCell><mxCell id="v10" value="→ 收益没完全榨取" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="50.0" y="181.52" width="66" height="16" as="geometry"/></mxCell><mxCell id="v11" value="" style="rounded=1;arcSize=5;fillColor=#d5e8d4;strokeColor=#5fa55f;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="500.0" y="50.0" width="440.0" height="150.0" as="geometry"/></mxCell><mxCell id="v12" value="Swap: A = weights, B = activations" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#1f5d1f;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="594.0" y="57.519999999999996" width="252" height="16" as="geometry"/></mxCell><mxCell id="v13" value="A = [N×K] weights per-CTA 独立分块（拆 N）" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="510.0" y="83.52" width="260" height="16" as="geometry"/></mxCell><mxCell id="v14" value="B = [M×K] activations multicast（两 CTA 共享 tokens）" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="510.0" y="101.52" width="357" height="16" as="geometry"/></mxCell><mxCell id="v15" value="收益：" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#1f5d1f;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="510.0" y="127.52" width="40" height="16" as="geometry"/></mxCell><mxCell id="v16" value="当 token 数 &lt; UMMA_M 时，activations 天然需要重复广播" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="510.0" y="145.52" width="305" height="16" as="geometry"/></mxCell><mxCell id="v17" value="让 UMMA multicast 帮忙，TMA-B 一次发 → 两 CTA 都收到" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="510.0" y="163.52" width="305" height="16" as="geometry"/></mxCell><mxCell id="v18" value="Blackwell SM100 实测 MoE decode +15-25% 吞吐" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="510.0" y="181.52" width="297" height="16" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
