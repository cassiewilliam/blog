nter;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="549.5" y="127.08" width="221" height="14" as="geometry"/></mxCell><mxCell id="v18" value="" style="rounded=1;arcSize=5;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="820.0" y="60.0" width="250.0" height="70.0" as="geometry"/></mxCell><mxCell id="v19" value="Python runtime" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="893.0" y="69.52" width="104" height="16" as="geometry"/></mxCell><mxCell id="v20" value="per-call host overhead &lt; 1 μs" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="851.0" y="89.08" width="188" height="14" as="geometry"/></mxCell><mxCell id="v21" value="down from hundreds of μs" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#5fa55f;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="867.0" y="107.08" width="156" height="14" as="geometry"/></mxCell><mxCell id="v22" value="" style="endArrow=classic;strokeColor=#333;strokeWidth=1;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="230.0" y="95.0" as="sourcePoint"/><mxPoint x="268.0" y="95.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v23" value="" style="endArrow=classic;strokeColor=#333;strokeWidth=1;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="500.0" y="70.0" as="sourcePoint"/><mxPoint x="538.0" y="62.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v24" value="" style="endArrow=classic;strokeColor=#333;strokeWidth=1;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="500.0" y="120.0" as="sourcePoint"/><mxPoint x="538.0" y="122.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v25" value="" style="endArrow=classic;strokeColor=#333;strokeWidth=1;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780.0" y="70.0" as="sourcePoint"/><mxPoint x="818.0" y="80.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v26" value="" style="endArrow=classic;strokeColor=#333;strokeWidth=1;html=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780.0" y="120.0" as="sourcePoint"/><mxPoint x="818.0" y="105.0" as="targetPoint"/></mxGeometry></mxCell><mxCell id="v27" value="" style="rounded=1;arcSize=5;fillColor=#eef3ff;strokeColor=#4a6fd3;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="30.0" y="170.0" width="510.0" height="120.0" as="geometry"/></mxCell><mxCell id="v28" value="Z3 SMT integration (QF_NIA, non-linear integer)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="96.0" y="177.96" width="378" height="18" as="geometry"/></mxCell><mxCell id="v29" value="• translates tensor-index arithmetic → Z3 quantifier-free non-linear" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="204.3" width="463" height="15" as="geometry"/></mxCell><mxCell id="v30" value="• compile-time budget ≤ a few seconds" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="222.3" width="252" height="15" as="geometry"/></mxCell><mxCell id="v31" value="• unlocks passes:  vectorization · barrier insertion · bound check · code simplify" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="240.3" width="559" height="15" as="geometry"/></mxCell><mxCell id="v32" value="→ handles vectorization over variable tensor shapes that static ILP alone cannot" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#4a6fd3;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="258.3" width="545" height="15" as="geometry"/></mxCell><mxCell id="v33" value="" style="rounded=1;arcSize=5;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="570.0" y="170.0" width="500.0" height="120.0" as="geometry"/></mxCell><mxCell id="v34" value="Bit-reproducibility &amp; IEEE-754 opt-in" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="671.0" y="177.96" width="298" height="18" as="geometry"/></mxCell><mxCell id="v35" value="• fast-math OFF by default (no --use_fast_math)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="204.3" width="320" height="15" as="geometry"/></mxCell><mxCell id="v36" value="• lowering aligned with NVCC — no unexpected algebraic rewrites" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="222.3" width="429" height="15" as="geometry"/></mxCell><mxCell id="v37" value="• T.__exp / T.__log / T.__sin : explicit opt-in approximations" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="240.3" width="422" height="15" as="geometry"/></mxCell><mxCell id="v38" value="• T.ieee_fsqrt / T.ieee_fdiv / T.ieee_add : explicit rounding" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="258.3" width="416" height="15" as="geometry"/></mxCell><mxCell id="v39" value="" style="rounded=1;arcSize=5;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="30.0" y="310.0" width="1040.0" height="110.0" as="geometry"/></mxCell><mxCell id="v40" value="Why V4 needs this particular combination" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="395.0" y="318.74" width="310" height="17" as="geometry"/></mxCell><mxCell id="v41" value="• V4 ships hundreds of one-off fused kernels (mHC, compressor, fused_qnorm+RoPE+KV-insert, indexer top-k, …)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="344.3" width="736" height="15" as="geometry"/></mxCell><mxCell id="v42" value="• hand-written CUDA is too slow to iterate; hand-written Triton lacks bitwise reproducibility" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="362.3" width="634" height="15" as="geometry"/></mxCell><mxCell id="v43" value="• TileLang: prototype in Python, lower to CUDA, and keep the byte-identical contract needed for SFT → RL → serve" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="380.3" width="763" height="15" as="geometry"/></mxCell><mxCell id="v44" value="• result: kernel dev productivity ≈ Triton, numerical contract ≈ hand-written CUDA" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#b85450;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="398.3" width="559" height="15" as="geometry"/></mxCell>
