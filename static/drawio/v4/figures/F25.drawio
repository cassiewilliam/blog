<mxfile host="app.diagrams.net" agent="svg2drawio" version="22.0.0">
  <diagram id="conv" name="Page-1">
    <mxGraphModel dx="1100" dy="440" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="440" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="v2" value="" style="rounded=0;fillColor=#fff;strokeColor=none;html=1;" vertex="1" parent="1"><mxGeometry x="0.0" y="0.0" width="1100.0" height="440.0" as="geometry"/></mxCell><mxCell id="v3" value="Contextual Parallelism · 两阶段通信保证压缩正确性" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="366.5" y="6.84" width="367" height="22" as="geometry"/></mxCell><mxCell id="v4" value="" style="rounded=1;arcSize=5;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="30.0" y="50.0" width="1040.0" height="70.0" as="geometry"/></mxCell><mxCell id="v5" value="Challenge: 每 rank 持 s tokens, 压缩需要 m (或 m') 个连续 token, 边界可能跨 rank" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="298.5" y="58.74" width="503" height="17" as="geometry"/></mxCell><mxCell id="v6" value="• 训练样本打包多序列 → 每条独立压缩, 尾部&lt;m 被丢弃 → 各 rank 的压缩 KV 长度 &lt; s/m 且不一致" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="82.3" width="409" height="15" as="geometry"/></mxCell><mxCell id="v7" value="• 某个压缩窗口可能横跨 rank i 和 rank i+1 → 必须跨 rank 传输原始 KV 才能正确压缩" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="100.3" width="381" height="15" as="geometry"/></mxCell><mxCell id="v8" value="" style="rounded=1;arcSize=5;fillColor=#eef3ff;strokeColor=#4a6fd3;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="30.0" y="140.0" width="500.0" height="120.0" as="geometry"/></mxCell><mxCell id="v9" value="Stage 1 · boundary shipment" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="171.5" y="147.96" width="217" height="18" as="geometry"/></mxCell><mxCell id="v10" value="rank i → rank i+1 : last m uncompressed KV entries" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="174.3" width="341" height="15" as="geometry"/></mxCell><mxCell id="v11" value="payload : [m, 576] bf16  +  positions [m] int64" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="192.3" width="320" height="15" as="geometry"/></mxCell><mxCell id="v12" value="rank i+1 compresses {received m + local s} → s/m + 1 entries" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="210.3" width="409" height="15" as="geometry"/></mxCell><mxCell id="v13" value="→ fixed length output (padding at tail)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a3a5c;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="45.0" y="228.3" width="265" height="15" as="geometry"/></mxCell><mxCell id="v14" value="" style="rounded=1;arcSize=5;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="570.0" y="140.0" width="500.0" height="120.0" as="geometry"/></mxCell><mxCell id="v15" value="Stage 2 · all-gather across CP ranks" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="675.0" y="147.96" width="290" height="18" as="geometry"/></mxCell><mxCell id="v16" value="all ranks exchange their (s/m + 1) compressed entries" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="174.3" width="361" height="15" as="geometry"/></mxCell><mxCell id="v17" value="fused select-and-pad operator rearranges into" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="192.3" width="306" height="15" as="geometry"/></mxCell><mxCell id="v18" value="final compressed KV of length cp_size · s/m  (padding at tail)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="210.3" width="422" height="15" as="geometry"/></mxCell><mxCell id="v19" value="→ every rank now has full global compressed KV view" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1a3d1a;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="585.0" y="228.3" width="347" height="15" as="geometry"/></mxCell><mxCell id="v20" value="" style="rounded=1;arcSize=5;fillColor=#fff4e0;strokeColor=#e0b300;strokeWidth=1;html=1;" vertex="1" parent="1"><mxGeometry x="30.0" y="280.0" width="1040.0" height="140.0" as="geometry"/></mxCell><mxCell id="v21" value="Visibility rules (per query token)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#000000;fontStyle=1;fontFamily=sans-serif;" vertex="1" parent="1"><mxGeometry x="418.5" y="288.74" width="263" height="17" as="geometry"/></mxCell><mxCell id="v22" value="• HCA + CSA-indexer: visible compressed-entry range is precomputed from rule  (block_id ≤ floor(t/m))" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="314.3" width="688" height="15" as="geometry"/></mxCell><mxCell id="v23" value="• CSA sparse attention: top-k selector output gives explicit indices to attend" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="332.3" width="531" height="15" as="geometry"/></mxCell><mxCell id="v24" value="• SWA: local n_win window, read from rank-local uncompressed buffer" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#000000;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="350.3" width="456" height="15" as="geometry"/></mxCell><mxCell id="v25" value="memory: stage-2 all-gather is only O(cp_size · s/m)  — compressed payload keeps comm budget small at 1 M" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#7a4e00;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="374.3" width="709" height="15" as="geometry"/></mxCell><mxCell id="v26" value="compared to Ring/Striped attention at length s, comm cost drops by another factor of m = 4 (CSA) / 128 (HCA)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#7a4e00;fontFamily=monospace;" vertex="1" parent="1"><mxGeometry x="60.0" y="392.3" width="736" height="15" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
