<mxfile host="embed.diagrams.net"><diagram name="figure" id="figure"><mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1120" pageHeight="470" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="title" value="Top-K kernel: make the sortable key carry the expert id" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=28;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="18" width="1040" height="40" as="geometry" /></mxCell><mxCell id="sub" value="This explains the paper Figure 15: ties disappear because equal scores still have distinct packed low mantissa bits." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=13;fontColor=#667085;" vertex="1" parent="1"><mxGeometry x="40" y="58" width="1020" height="24" as="geometry" /></mxCell><mxCell id="a" value="&lt;b&gt;Router row&lt;/b&gt;&lt;br&gt;&lt;br&gt;S[t, :]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef7ff;strokeColor=#4a6fd3;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1"><mxGeometry x="65" y="125" width="175" height="84" as="geometry" /></mxCell><mxCell id="b" value="&lt;b&gt;Pack key&lt;/b&gt;&lt;br&gt;&lt;br&gt;score high bits&lt;br&gt;expert id low bits" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1"><mxGeometry x="310" y="112" width="220" height="110" as="geometry" /></mxCell><mxCell id="c" value="&lt;b&gt;Register sort&lt;/b&gt;&lt;br&gt;&lt;br&gt;thread / warp&lt;br&gt;compare-swap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e7;strokeColor=#e0b300;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1"><mxGeometry x="600" y="112" width="220" height="110" as="geometry" /></mxCell><mxCell id="d" value="&lt;b&gt;Top-K&lt;/b&gt;&lt;br&gt;&lt;br&gt;π[t,k], score" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef7ff;strokeColor=#4a6fd3;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1"><mxGeometry x="890" y="125" width="175" height="84" as="geometry" /></mxCell><mxCell id="e1" edge="1" parent="1" source="a" target="b" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e2" edge="1" parent="1" source="b" target="c" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e3" edge="1" parent="1" source="c" target="d" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="formula" value="&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 22px;&quot;&gt;&lt;i&gt;key&lt;sub&gt;e&lt;/sub&gt; = score&lt;sub&gt;e&lt;/sub&gt; || e&lt;/i&gt;&lt;/font&gt;&lt;br&gt;Sort by the packed FP32 value; the score and column id move together." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e7;strokeColor=#e0b300;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1"><mxGeometry x="235" y="285" width="650" height="74" as="geometry" /></mxCell><mxCell id="d1" edge="1" parent="1" source="b" target="formula" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;dashed=1;strokeColor=#667085;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="d2" edge="1" parent="1" source="c" target="formula" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d556