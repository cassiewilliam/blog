  <diagram id="page11-nccl-ep-roadmap" name="11 NCCL EP 接入路线">
    <mxGraphModel dx="1242" dy="799" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p11-title" value="NCCL EP 类接入路线：从外部 op 到 compiler-native backend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=20;" parent="1" vertex="1">
          <mxGeometry x="80" y="40" width="1440" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p11-a" value="路线 A：外部库封装 推荐 v1&#xa;NCCL EP / Hybrid-EP 作为 PyTorch/C++ op&#xa;Triton-distributed 继续做 GEMM / GroupGEMM / fusion&#xa;改动小，风险低" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="100" y="170" width="380" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p11-b" value="路线 B：runtime bridge&#xa;runtime 管 NCCL communicator/window/devComm&#xa;kernel 侧 extern_call 或新 primitive 调 NCCL Device API&#xa;需要生命周期与 CUDA graph 设计" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="610" y="170" width="380" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p11-c" value="路线 C：compiler-native backend&#xa;新增 lowering 到 NCCL Device API&#xa;处理 ABI / device symbol / link / module init&#xa;长期收益高，工程风险最大" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="1120" y="170" width="360" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p11-d" value="对齐点&#xa;Triton symmetric tensor &lt;-&gt; NCCL symmetric window&#xa;rank/world &lt;-&gt; ncclDevComm team/rank&#xa;signal/wait &lt;-&gt; NCCL one-sided or barrier sessions&#xa;A2A metadata &lt;-&gt; dispatch/combine API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="300" y="460" width="1000" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p11-note" value="资料与源码&#xa;NCCL EP paper&#xa;NCCL Device API docs&#xa;python/triton_dist/function/nvidia/common.py&#xa;python/triton_dist/function/nvidia/ep_moe_fused.py&#xa;csrc/lib/*" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="1120" y="740" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p11-edge1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;" parent="1" source="p11-a" target="p11-b" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p11-edge2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;" parent="1" source="p11-b" target="p11-c" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p11-edge3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;" parent="1" source="p11-b" target="p11-d" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page12-mega-aot-lk" name="12 MegaKernel AOT little_kernel">
    <mxGraphModel dx="1242" dy="799" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
