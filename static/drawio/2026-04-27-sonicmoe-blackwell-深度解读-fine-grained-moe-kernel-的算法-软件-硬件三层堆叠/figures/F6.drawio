        <mxCell id="logits" value="&lt;b&gt;Logits&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 22px;&quot;&gt;&lt;i&gt;S&lt;sub&gt;t&lt;/sub&gt;&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef7ff;strokeColor=#4a6fd3;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1">
