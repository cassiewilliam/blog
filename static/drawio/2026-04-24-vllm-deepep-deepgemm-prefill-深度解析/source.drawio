        <mxCell id="dbo_g_comb0" value="&lt;font style=&quot;font-size:8px&quot;&gt;&lt;b&gt;Combine&lt;/b&gt;&lt;br&gt;All2All(ub0)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=8;" parent="1" vertex="1">
          <mxGeometry x="620" y="1560" width="130" height="40" as="geometry" />
