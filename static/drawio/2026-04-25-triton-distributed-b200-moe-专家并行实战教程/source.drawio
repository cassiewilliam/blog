        <mxCell id="p8-f" value="调优旋钮&#xa;NUM_GEMM_SMS&#xa;NUM_COMM_SMS&#xa;reduction SM 数&#xa;tile shape / swizzle&#xa;signal granularity&#xa;stream dependency" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="780" y="440" width="360" height="190" as="geometry" />
