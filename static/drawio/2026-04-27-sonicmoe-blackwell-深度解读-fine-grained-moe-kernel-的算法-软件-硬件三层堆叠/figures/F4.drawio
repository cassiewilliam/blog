        <mxCell id="d_14" value="&lt;b&gt;Select first K&lt;/b&gt;&lt;br&gt;top-K scores + expert ids&lt;br&gt;&lt;font style=&quot;font-size:13px&quot;&gt;K ≤ 16 in paper&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=17;" vertex="1" parent="1"><mxGeometry x="135" y="430" width="220" height="90" as="geometry"/></mxCell>
