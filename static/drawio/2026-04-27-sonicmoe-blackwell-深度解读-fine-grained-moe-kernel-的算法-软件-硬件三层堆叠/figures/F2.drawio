<mxfile host="embed.diagrams.net"><diagram name="figure" id="figure"><mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1160" pageHeight="500" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="title" value="SonicMoE: keep tensors close to the GEMM pipeline" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=28;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="18" width="1080" height="40" as="geometry" /></mxCell><mxCell id="sub" value="The workflow keeps the same MoE semantics but moves gather, activation, and reductions into the kernels that already touch the data." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=13;fontColor=#667085;" vertex="1" parent="1"><mxGeometry x="40" y="58" width="1050" height="24" as="geometry" /></mxCell><mxCell id="lane1" value="Forward: 3 kernels" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=14;fontColor=#667085;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="55" y="105" width="250" height="24" as="geometry" /></mxCell><mxCell id="f1" value="&lt;b&gt;Up-proj&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;H,A = f(X,π,W&lt;sub&gt;1&lt;/sub&gt;)&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="120" y="145" width="190" height="86" as="geometry" /></mxCell><mxCell id="f2" value="&lt;b&gt;Down-proj&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;Y&lt;sub&gt;e&lt;/sub&gt; = A&lt;sub&gt;e&lt;/sub&gt;W&lt;sub&gt;2,e&lt;/sub&gt;&lt;/i&gt;&lt;/font&gt;&lt;br&gt;transient" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="380" y="145" width="190" height="86" as="geometry" /></mxCell><mxCell id="ef2" edge="1" parent="1" source="f1" target="f2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="f3" value="&lt;b&gt;Aggregation&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;O&lt;sub&gt;t&lt;/sub&gt; = Σ&lt;sub&gt;e&lt;/sub&gt;πSY&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="645" y="145" width="190" height="86" as="geometry" /></mxCell><mxCell id="ef3" edge="1" parent="1" source="f2" target="f3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="f4" value="&lt;b&gt;Output&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;O ∈ ℝ&lt;sub&gt;T×d&lt;/sub&gt;&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef7ff;strokeColor=#4a6fd3;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="900" y="145" width="170" height="86" as="geometry" /></mxCell><mxCell id="ef4" edge="1" parent="1" source="f3" target="f4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="lane2" value="Backward: 5 kernels, but no Y / dY cache path" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=14;fontColor=#667085;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="55" y="285" width="430" height="24" as="geometry" /></mxCell><mxCell id="b1" value="&lt;b&gt;dX aggregation&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;dX&lt;sub&gt;t&lt;/sub&gt; = Σ&lt;sub&gt;e&lt;/sub&gt;dX̃&lt;sub&gt;t,e&lt;/sub&gt;&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="120" y="330" width="185" height="88" as="geometry" /></mxCell><mxCell id="b2" value="&lt;b&gt;Up act grad&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;dX̃&lt;sub&gt;e&lt;/sub&gt;, dW&lt;sub&gt;1,e&lt;/sub&gt;&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="380" y="330" width="185" height="88" as="geometry" /></mxCell><mxCell id="b3" value="&lt;b&gt;Fused dH kernel&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;dS&lt;sub&gt;e,t&lt;/sub&gt;=⟨dA′&lt;sub&gt;e,t&lt;/sub&gt;,A&lt;sub&gt;e,t&lt;/sub&gt;⟩&lt;/i&gt;&lt;/font&gt;&lt;br&gt;also emits dH, A′" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e7;strokeColor=#e0b300;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="645" y="318" width="220" height="112" as="geometry" /></mxCell><mxCell id="b4" value="&lt;b&gt;Weight grad&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;dW&lt;sub&gt;2,e&lt;/sub&gt;=A′&lt;sub&gt;e&lt;/sub&gt;&lt;sup&gt;T&lt;/sup&gt;dO&lt;sub&gt;e&lt;/sub&gt;&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="930" y="330" width="170" height="88" as="geometry" /></mxCell><mxCell id="eb12" edge="1" parent="1" source="b1" target="b2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="eb23" edge="1" parent="1" source="b2" target="b3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="eb34" edge="1" parent="1" source="b3" target="b4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4d5562;strokeWidth=2.2;endArrow=block;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="cache" value="&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 21px;&quot;&gt;&lt;i&gt;cache = {X,H,π,S}, |cache| = 2Td + 4TKn&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1"><mxGeometry x="350" y="246" width="460" height="44" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>
