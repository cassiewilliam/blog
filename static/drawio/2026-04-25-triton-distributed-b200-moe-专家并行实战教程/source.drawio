        <mxCell id="hw-leg2" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="2170" y="1065" width="30" height="15" as="geometry" />
        </mxCell>
        <mxCell id="hw-leg2t" value="后向 RDMA NIC (CX-7 400GbE)" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="2210" y="1062" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="hw-leg3" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
          <mxGeometry x="2170" y="1090" width="30" height="15" as="geometry" />
        </mxCell>
        <mxCell id="hw-leg3t" value="NVSwitch / NVLink" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="2210" y="1087" width="150" height="20" as="geometry" />
        </mxCell>
        <mxCell id="hw-leg4" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="2170" y="1115" width="30" height="15" as="geometry" />
        </mxCell>
        <mxCell id="hw-leg4t" value="后向 InfiniBand NIC" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="2210" y="1112" width="150" height="20" as="geometry" />
        </mxCell>
        <mxCell id="hw-leg5" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="2170" y="1140" width="30" height="15" as="geometry" />
        </mxCell>
        <mxCell id="hw-leg5t" value="前向管理网卡 / bond0" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="2210" y="1137" width="150" height="20" as="geometry" />
        </mxCell>
        <mxCell id="hw-leg6" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="2170" y="1165" width="30" height="15" as="geometry" />
        </mxCell>
        <mxCell id="hw-leg6t" value="NUMA 0 域" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="2210" y="1162" width="100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="hw-leg7" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="2170" y="1190" width="30" height="15" as="geometry" />
        </mxCell>
        <mxCell id="hw-leg7t" value="NUMA 1 域" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="2210" y="1187" width="100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="hw-decision-title" value="NIC 选路决策链 — 谁决定使用前向还是后向网卡？" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#16213e;fontStyle=1;fontSize=16;fontColor=#FFFFFF;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="40" y="1260" width="2520" height="50" as="geometry" />
        </mxCell>
        <mxCell id="hw-decision-subtitle" value="前向/后向不是用户手动选择——而是由 硬件设计 → 驱动/OS → 通信库 → 框架/环境变量 四层逐级决定。用户通过环境变量和配置间接影响最终选路。" style="text;html=1;fontSize=12;fontStyle=2;fillColor=none;strokeColor=none;fontColor=#666666;align=center;" parent="1" vertex="1">
          <mxGeometry x="40" y="1315" width="2520" height="25" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-L1" value="第 1 层: 硬件 / OEM 设计 (出厂固定)" style="text;html=1;fontSize=13;fontStyle=5;fillColor=none;strokeColor=none;fontColor=#333333;align=left;" parent="1" vertex="1">
          <mxGeometry x="60" y="1350" width="400" height="25" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-L1-oem" value="OEM / NVIDIA 主板设计&#xa;&#xa;• PCIe 拓扑: GPU_i 与 NIC_i 接在同一 PCIe Switch 下 (PIX)&#xa;• Rail-Optimized: 每 GPU 配一个专属 400GbE NIC&#xa;• 管理 NIC 接在 CPU 直连 PCIe (非 GPU Switch)&#xa;• NVSwitch 集成在 HGX Baseboard&#xa;&#xa;→ 硬件物理连接决定了哪些 NIC 能做 GPUDirect RDMA (后向)&#xa;→ 接在 CPU PCIe 上的 NIC 天然只能走 CPU 协议栈 (前向)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#5c6bc0;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="60" y="1380" width="580" height="180" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-L1-topo" value="PCIe 拓扑决定 NIC 角色 (本节点示例)&#xa;&#xa;┌─ PCIe Switch 0 ─┐     ┌─ CPU Root Complex ─┐&#xa;│  GPU0  ←PIX→ NIC0  │     │  CX-6 Dx (eth2/eth3)  │&#xa;│  (17:00) (18:00)  │     │  (4C:00.0 / 4C:00.1)  │&#xa;└─────────────────┘     └──────────────────────┘&#xa;        ↓                          ↓&#xa;  后向: GPUDirect RDMA         前向: TCP/IP 协议栈&#xa;  延迟 ~3μs, bypass CPU         延迟 ~ms, 经过 CPU&#xa;&#xa;如果把管理流量走 NIC0: 会挤占 GPU0 的 RDMA 带宽&#xa;如果把 GPU 数据走 eth2: 无法 GPUDirect, 延迟 10x" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#5c6bc0;fontSize=10;fontFamily=Courier New;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="660" y="1380" width="500" height="180" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-L1-dgx" value="DGX B200 vs OEM 差异&#xa;&#xa;│ DGX B200 官方:&#xa;│  Compute: 4xOSFP → 8xCX-7 (IB/ETH)&#xa;│  Storage:  2xBlueField-3 DPU&#xa;│  BMC: 1x1GbE RJ45&#xa;│&#xa;│ 本节点 (OEM HGX):&#xa;│  Compute: 8xCX-7 (ETH 400G)&#xa;│  IB: 1xCX-7 四端口 (HDR 100G)&#xa;│  管理: 1xCX-6 Dx 双口 bond&#xa;│&#xa;│ OEM 可按需选配网卡型号和数量&#xa;│ 但 PCIe 拓扑原则不变: GPU 旁挂后向" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#5c6bc0;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1180" y="1380" width="360" height="180" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-arrow-L1L2" value="" style="shape=mxgraph.arrows2.arrow;whiteSpace=wrap;html=1;fillColor=#5c6bc0;strokeColor=#5c6bc0;direction=south;" parent="1" vertex="1">
          <mxGeometry x="310" y="1565" width="20" height="30" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-L2" value="第 2 层: 操作系统 / 驱动 (自动识别)" style="text;html=1;fontSize=13;fontStyle=5;fillColor=none;strokeColor=none;fontColor=#333333;align=left;" parent="1" vertex="1">
          <mxGeometry x="60" y="1600" width="400" height="25" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-L2-driver" value="Linux 内核 + OFED 驱动&#xa;&#xa;• mlx5_core 枚举所有 Mellanox 设备&#xa;• udev 规则生成 ens*np* 接口名 (predictable naming)&#xa;• PCIe ACS/IOMMU 确定 GPUDirect 可达性&#xa;• nvidia-peermem 模块注册 GPU 页面到 NIC RDMA&#xa;&#xa;→ 驱动层 自动 识别哪些 NIC 支持 GPUDirect&#xa;→ 用户不需要手动指定 NIC 是前向还是后向" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="60" y="1630" width="580" height="160" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-L2-topo" value="nvidia-smi topo -m 输出的 NIC 关系:&#xa;&#xa;PIX  = GPU 和 NIC 在同一 PCIe Switch → ✅ 后向首选&#xa;NODE = 同一 NUMA, 不同 PCIe Switch → ⚠️ 可用但非最优&#xa;SYS  = 跨 NUMA, 需走 UPI → ❌ 延迟高, 避免用于 RDMA&#xa;&#xa;本节点:&#xa;  GPU0↔NIC0 = PIX ✅  |  GPU0↔NIC4 = SYS ❌&#xa;  GPU4↔NIC4 = PIX ✅  |  GPU4↔NIC0 = SYS ❌&#xa;  所有 GPU↔bond0(CX-6) = NODE 或 SYS → 前向" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=10;fontFamily=Courier New;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="660" y="1630" width="500" height="160" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-L2-verify" value="验证命令&#xa;&#xa;# 查看 GPU-NIC PCIe 亲和性&#xa;nvidia-smi topo -m&#xa;&#xa;# 查看 NIC 是否注册 GPUDirect&#xa;cat /sys/kernel/mm/memory_peers/&#xa;    nv_mem/*/version&#xa;&#xa;# 查看 RDMA 设备&#xa;ibv_devices&#xa;rdma link show" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=10;fontFamily=Courier New;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1180" y="1630" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-arrow-L2L3" value="" style="shape=mxgraph.arrows2.arrow;whiteSpace=wrap;html=1;fillColor=#43a047;strokeColor=#43a047;direction=south;" parent="1" vertex="1">
          <mxGeometry x="310" y="1795" width="20" height="30" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-L3" value="第 3 层: 通信库 (自动选路 + 环境变量微调)" style="text;html=1;fontSize=13;fontStyle=5;fillColor=none;strokeColor=none;fontColor=#333333;align=left;" parent="1" vertex="1">
          <mxGeometry x="60" y="1830" width="500" height="25" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-L3-nccl" value="NCCL — 后向网卡 (自动)&#xa;&#xa;NCCL 内置拓扑感知引擎:&#xa;  1. 解析 PCIe 拓扑 (hwloc/sysfs)&#xa;  2. 识别 GPU-NIC PIX 对&#xa;  3. 自动选 GPUDirect RDMA 最优路径&#xa;  4. 构建 Ring/Tree 通信拓扑&#xa;&#xa;用户可微调 (通常不需要):&#xa;  NCCL_NET_GDR_LEVEL=PIX  # 强制 PIX&#xa;  NCCL_IB_HCA=mlx5_0,...  # 指定 HCA&#xa;  NCCL_SOCKET_IFNAME=bond0 # bootstrap 用前向" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ff9800;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="60" y="1860" width="400" height="200" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-L3-nvshmem" value="NVSHMEM — 后向网卡 (自动) + bootstrap 走前向&#xa;&#xa;NVSHMEM 数据通道 (自动):&#xa;  • 使用 ibv_* 接口直接操作 RDMA 设备&#xa;  • 自动选择 GPU 对应的 PIX NIC&#xa;  • 走 GPUDirect, 用户无需配置&#xa;&#xa;NVSHMEM bootstrap (需用户指定前向网卡!):&#xa;  NVSHMEM_BOOTSTRAP_UID_SOCK_IFNAME=bond0&#xa;  NVSHMEM_BOOTSTRAP_UID_SOCK_FAMILY=AF_INET&#xa;  ↑ 这是因为 bootstrap 走 TCP Socket (前向)&#xa;    而默认 eth0 在本机不存在&#xa;    数据通道 仍自动走后向 RDMA NIC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ff9800;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="480" y="1860" width="440" height="200" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-L3-gloo" value="Gloo / torchrun — 前向网卡 (用户指定)&#xa;&#xa;PyTorch Distributed bootstrap:&#xa;  • torchrun 的 rdzv_endpoint&#xa;  • Gloo 后端的 socket 通信&#xa;  • 这些都走 TCP/IP → 前向网卡&#xa;&#xa;用户必须配置:&#xa;  --rdzv_endpoint=10.77.188.34:23456&#xa;  (bond0 的 IP, 不是 RDMA NIC 的 IP)&#xa;&#xa;如果错指 RDMA NIC 的 IP:&#xa;  其他节点可能无法路由到达 ❌" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ff9800;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="940" y="1860" width="400" height="200" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-L3-summary" value="第 3 层总结: 通信库的选路规则&#xa;&#xa;┌───────────────┬─────────┬──────────┐&#xa;│ 通信类型         │ 走哪个网卡  │ 谁决定     │&#xa;├───────────────┼─────────┼──────────┤&#xa;│ AllReduce 梯度  │ 后向 NIC  │ NCCL 自动  │&#xa;│ AllToAll(EP)   │ 后向 NIC  │ NCCL 自动  │&#xa;│ NVSHMEM put/get│ 后向 NIC  │ NVSHMEM自动│&#xa;│ dl.symm_at()   │ NVLink    │ 硬件自动   │&#xa;│ NVSHMEM boot  │ 前向bond0 │ 用户 ENV   │&#xa;│ torchrun rdzv │ 前向bond0 │ 用户 ENV   │&#xa;│ SSH/监控/API   │ 前向bond0 │ OS路由表   │&#xa;│ Checkpoint I/O│ 前向bond0 │ OS路由表   │&#xa;│ BMC/IPMI      │ OOB 1GbE  │ BMC 固件   │&#xa;└───────────────┴─────────┴──────────┘" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ff9800;fontSize=10;fontFamily=Courier New;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1360" y="1860" width="420" height="200" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-arrow-L3L4" value="" style="shape=mxgraph.arrows2.arrow;whiteSpace=wrap;html=1;fillColor=#ff9800;strokeColor=#ff9800;direction=south;" parent="1" vertex="1">
          <mxGeometry x="310" y="2065" width="20" height="30" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-L4" value="第 4 层: 用户 / 应用 (环境变量 &amp; 代码)" style="text;html=1;fontSize=13;fontStyle=5;fillColor=none;strokeColor=none;fontColor=#333333;align=left;" parent="1" vertex="1">
          <mxGeometry x="60" y="2100" width="500" height="25" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-L4-env" value="用户需要设置的环境变量 (完整清单)&#xa;&#xa;# ✅ 必须设置 (本节点特有):&#xa;NVSHMEM_BOOTSTRAP_UID_SOCK_IFNAME=bond0&#xa;NVSHMEM_BOOTSTRAP_UID_SOCK_FAMILY=AF_INET&#xa;NCCL_SOCKET_IFNAME=bond0&#xa;MASTER_ADDR=10.77.188.34&#xa;&#xa;# ⚙️ 可选微调 (通常不需要):&#xa;NCCL_NET_GDR_LEVEL=PIX&#xa;NCCL_IB_HCA=mlx5_0,mlx5_5,mlx5_8,...&#xa;NCCL_IB_GID_INDEX=3&#xa;CUDA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e53935;fontSize=10;fontFamily=Courier New;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="60" y="2130" width="500" height="200" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-L4-code" value="Triton-distributed 代码中的选路体现&#xa;&#xa;# 后向 NIC: NVSHMEM 自动选 PIX NIC&#xa;dl.symm_at(ptr, peer_rank)  # NVLink&#xa;nvshmem_putmem(...)         # RDMA (后向 NIC)&#xa;&#xa;# 前向 NIC: bootstrap 阶段&#xa;torch.distributed.init_process_group(&#xa;    backend=&#39;nccl&#39;,  # 数据通道: 后向&#xa;    init_method=&#39;env://&#39;  # bootstrap: 前向&#xa;)&#xa;&#xa;# scripts/launch.sh 中:&#xa;# NVSHMEM_BOOTSTRAP_UID_SOCK_IFNAME=bond0&#xa;# → bootstrap 走 前向 bond0&#xa;# → 之后的 put/get 自动走 后向 RDMA NIC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e53935;fontSize=10;fontFamily=Courier New;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="580" y="2130" width="500" height="200" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-L4-decision" value="最终选路决策树&#xa;&#xa;                   ┌─── GPU 间数据? ───┐&#xa;                   │                  │&#xa;              同一节点内?           不同节点?&#xa;                   │                  │&#xa;             NVLink/NVSwitch      ┌── RDMA 可达? ──┐&#xa;              (自动, 900GB/s)     │                │&#xa;                              GPU-NIC PIX?    非 PIX?&#xa;                                  │              │&#xa;                            后向NIC直连      后向NIC跨NUMA&#xa;                           (GPUDirect      (经 UPI, 仍可用&#xa;                            3μs, 92%)       但性能降低)&#xa;&#xa;                   ┌─── 非 GPU 数据? ──┐&#xa;                   │                   │&#xa;              前向 bond0          OOB BMC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e53935;fontSize=10;fontFamily=Courier New;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1100" y="2130" width="460" height="200" as="geometry" />
        </mxCell>
        <mxCell id="hw-dec-insight" value="💡 核心结论: 用户并不 &quot;选择&quot; 使用前向还是后向网卡&#xa;&#xa;① 硬件设计 (PCIe 拓扑) 决定了哪些 NIC 能做 GPUDirect → 这些自然成为 后向网卡&#xa;② 通信库 (NCCL/NVSHMEM) 自动 根据 PCIe 亲和性选择后向 NIC, 无需用户干预&#xa;③ 用户唯一需要做的: 告诉 bootstrap/管理层用哪个 前向网卡 的 IP (因为 RDMA NIC 的 IP 通常在独立子网, 外部不可路由)&#xa;④ 所以用户设的 NCCL_SOCKET_IFNAME=bond0 和 NVSHMEM_BOOTSTRAP_UID_SOCK_IFNAME=bond0 都是指定前向 NIC&#xa;⑤ 后向 NIC 的选择完全自动: NCCL 和 NVSHMEM 会遍历 PCIe 拓扑, 找到每个 GPU 最近的 RDMA NIC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#16213e;fontColor=#FFEB3B;fontSize=12;fontStyle=1;align=left;spacingLeft=15;spacingRight=15;" parent="1" vertex="1">
          <mxGeometry x="1580" y="2130" width="980" height="200" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page15-moe-evolution" name="15 MoE 算法演进时间线">
    <mxGraphModel dx="1774" dy="1141" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p15-title" value="MoE 算法演进时间线：从 GShard 到 DeepSeek-V3 / Qwen3-MoE&#xa;专家数量 ↑ 100×、激活率 ↓ 5×、aux loss → aux-free bias、引入节点限制" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=18;" parent="1" vertex="1">
          <mxGeometry x="60" y="30" width="1480" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p15-2020" value="2020 · GShard&#xa;arxiv 2006.16668&#xa;━━━━━━━━&#xa;up to 600B&#xa;2048 experts/层&#xa;Top-2&#xa;capacity factor&#xa;aux loss" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="60" y="160" width="180" height="200" as="geometry" />
        </mxCell>
        <mxCell id="p15-2021" value="2021 · Switch&#xa;arxiv 2101.03961&#xa;━━━━━━━━&#xa;up to 1.6T&#xa;2048 experts&#xa;Top-1 (简化)&#xa;aux loss = α·N·Σ(f_i·P_i)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="270" y="160" width="180" height="200" as="geometry" />
        </mxCell>
        <mxCell id="p15-2023" value="2023 · Mixtral 8×7B&#xa;mistral.ai&#xa;━━━━━━━━&#xa;46.7B / 12.9B&#xa;8 experts (大粒度)&#xa;Top-2&#xa;无 shared expert&#xa;~25% 激活率" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="480" y="160" width="180" height="200" as="geometry" />
        </mxCell>
        <mxCell id="p15-2024a" value="2024 · DeepSeekMoE/V2&#xa;arxiv 2401.06066&#xa;━━━━━━━━&#xa;236B / 21B&#xa;160 routed + 2 shared&#xa;Top-6&#xa;细粒度 expert&#xa;MLA attention" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="690" y="160" width="180" height="200" as="geometry" />
        </mxCell>
        <mxCell id="p15-2024b" value="2024 · DeepSeek-V3 / R1&#xa;arxiv 2412.19437&#xa;━━━━━━━━&#xa;671B / 37B (5.5%)&#xa;256 routed + 1 shared&#xa;Top-8&#xa;Aux-loss-free bias&#xa;Node-limited M=4&#xa;MTP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;spacingLeft=10;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="900" y="160" width="180" height="200" as="geometry" />
        </mxCell>
        <mxCell id="p15-2025" value="2025 · Qwen3-MoE&#xa;qwenlm.github.io&#xa;━━━━━━━━&#xa;235B / 22B&#xa;128 experts&#xa;Top-8&#xa;无 shared expert&#xa;global aux loss" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1110" y="160" width="180" height="200" as="geometry" />
        </mxCell>
        <mxCell id="p15-trend" value="趋势小结&#xa;━━━━━━━━&#xa;✓ Experts: 8 → 256+&#xa;✓ Top-K: 1-2 → 8&#xa;✓ 激活率: 25% → 5.5%&#xa;✓ Routing: softmax → sigmoid&#xa;✓ 均衡: aux loss → aux-free bias&#xa;✓ 节点限制: 无 → M=4 (DeepSeek)&#xa;✓ Shared expert: 无 → 1-2&#xa;✓ Quant: BF16 → FP8 → NVFP4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1320" y="160" width="220" height="240" as="geometry" />
        </mxCell>
        <mxCell id="p15-arrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=classic;" parent="1" source="p15-2020" target="p15-2021" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p15-arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=classic;" parent="1" source="p15-2021" target="p15-2023" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p15-arrow3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=classic;" parent="1" source="p15-2023" target="p15-2024a" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p15-arrow4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=classic;" parent="1" source="p15-2024a" target="p15-2024b" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p15-arrow5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=classic;" parent="1" source="p15-2024b" target="p15-2025" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p15-routing" value="Routing 数学（DeepSeek-V3 完整版）&#xa;&#xa;1. 门控分数（sigmoid，不再 softmax）:&#xa;   s_i = sigmoid(x · W_gate[i])&#xa;&#xa;2. 加均衡偏置:&#xa;   ŝ_i = s_i + b_i        ← b 在线更新&#xa;&#xa;3. 节点限制（M=4）:&#xa;   node_top = topM(node_aggregated_score(ŝ))&#xa;   ŝ_i = ŝ_i if expert.node ∈ node_top else -∞&#xa;&#xa;4. Top-K=8 选择:&#xa;   selected = topK(ŝ)&#xa;&#xa;5. Combine 权重（注意：用 raw s，不含 b）:&#xa;   g_i = s_i / Σ_{j∈selected} s_j   for i ∈ selected&#xa;&#xa;6. 输出:&#xa;   y = shared_expert(x) + Σ g_i · expert_i(x)&#xa;&#xa;Bias 更新（每 step 末尾，host 侧）:&#xa;   load_avg = mean(load)&#xa;   b_i ← b_i + γ · sign(load_avg - load_i),  γ ≈ 1e-3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffacd;strokeColor=#bdbd00;fontSize=12;align=left;spacingLeft=15;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="60" y="430" width="600" height="430" as="geometry" />
        </mxCell>
        <mxCell id="p15-comm" value="通信量启示（为什么 EP 必须）&#xa;━━━━━━━━━━━━━━━━━&#xa;&#xa;Forward dispatch + combine:&#xa;  bytes = 2 × B × K × d × dtype_bytes&#xa;&#xa;DeepSeek-V3 (B=4096, K=8, d=7168, BF16):&#xa;  → 938 MiB / MoE 层 / micro-batch&#xa;  → 58 MoE 层 + backward&#xa;  → 100+ GiB / training step&#xa;&#xa;关键:&#xa;  ✓ K=8 让 EP 通信 = dense AllReduce 的 8×&#xa;  ✓ A2A 没有 ring 摊薄&#xa;  ✓ 节点限制 M=4 把 fan-out 钉在 4 节点&#xa;&#xa;这就是 DeepEP / Hybrid-EP / Wide-EP 的来由" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f8ff;strokeColor=#4682b4;fontSize=12;align=left;spacingLeft=15;" parent="1" vertex="1">
          <mxGeometry x="690" y="430" width="430" height="430" as="geometry" />
        </mxCell>
        <mxCell id="p15-note" value="教程关联&#xa;━━━━━━━&#xa;§2 演进时间线&#xa;§7 路由优化&#xa;§14 通信量公式&#xa;&#xa;源码:&#xa;DeepSeek-V3 paper §3.2/§3.3&#xa;DeepSeek-V2 paper (MLA)&#xa;GShard / Switch papers&#xa;&#xa;Triton-distributed:&#xa;tutorials/04-deepseek-infer-all2all.py&#xa;python/triton_dist/kernels/&#xa;  nvidia/moe_utils.py" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1150" y="430" width="380" height="430" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page16-eplb" name="16 EPLB hot-expert 重排">
    <mxGraphModel dx="1774" dy="1141" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p16-title" value="EPLB（Expert Parallelism Load Balancer）：动态重排 hot expert + 冗余 slot&#xa;TRT-LLM 实测 EP=32 上 hottest rank +1.56× → +0.11×，~1.8× per-GPU 吞吐" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=18;" parent="1" vertex="1">
          <mxGeometry x="60" y="30" width="1480" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p16-before" value="无 EPLB&#xa;━━━━━━━━━━&#xa;Rank 0:  expert 0..7&#xa;Rank 1:  expert 8..15&#xa;Rank 2:  expert 16..23&#xa;...&#xa;Rank 13: expert 104..111  ← 含 hot expert #109&#xa;...&#xa;Rank 31: expert 248..255&#xa;&#xa;某 prompt 触发 #109 路由 50%&#xa;→ Rank 13 forward 时间 = 2× 平均&#xa;→ 全集群 wall = max(per-rank)&#xa;→ throughput 砍 50%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="60" y="160" width="350" height="320" as="geometry" />
        </mxCell>
        <mxCell id="p16-arrow" value="EPLB 重排&#xa;step_interval=3000&#xa;num_redundant=32" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="450" y="270" width="180" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p16-after" value="有 EPLB（num_slots=288 = 256+32）&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;Rank 0:  expert 0..7   + slot[#287]→#42&#xa;Rank 1:  expert 8..15  + slot[#288]→#109a (hot replica)&#xa;Rank 2:  expert 16..23 + slot[#289]→#205&#xa;...&#xa;Rank 13: expert 104..111 (#109 仍在但有 replica)&#xa;Rank 14: expert 112..119 + slot[#300]→#109b (hot replica)&#xa;...&#xa;&#xa;Hot expert #109 现在有 3 份副本&#xa;routing 时按 rank 当前负载选其中之一&#xa;→ 单 rank 负载下降到接近平均&#xa;→ wall ≈ avg, throughput 恢复&#xa;&#xa;实测: hottest rank +1.56× → +0.11×&#xa;       per-GPU throughput ~1.8×" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="670" y="160" width="430" height="320" as="geometry" />
        </mxCell>
        <mxCell id="p16-loop" value="EPLB 在线流程（per step）&#xa;━━━━━━━━━━━━━━━━&#xa;每 forward step:&#xa;  └─ atomicAdd 累计每 expert 命中数 (sliding window=1000)&#xa;&#xa;每 step_interval (3000):&#xa;  └─ EplbState.step()&#xa;       ├─ 计算 hot/cold (top-N hottest)&#xa;       ├─ 决定 swap 或 add replica&#xa;       ├─ side stream 上 NCCL P2P 搬权重&#xa;       ├─ double-buffered weight slot 切换 (指针 swap)&#xa;       └─ 更新 expert→slot 映射表 (POSIX shm)&#xa;&#xa;CUDA Graph 不被打断（地址不变，只指针 swap）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="60" y="510" width="600" height="280" as="geometry" />
        </mxCell>
        <mxCell id="p16-frameworks" value="各框架 EPLB 实现&#xa;━━━━━━━━━━━&#xa;TRT-LLM: MoeLoadBalancer&#xa;  shm name: TRTLLM_EPLB_SHM_NAME&#xa;  examples/wide_ep/ep_load_balancer/&#xa;  3 步: 收集 trace → generate yaml → 上线&#xa;&#xa;SGLang: routed_experts_capturer&#xa;  --enable-eplb --eplb-algorithm deepseek&#xa;  --ep-num-redundant-experts 32&#xa;  --ep-dispatch-algorithm dynamic&#xa;&#xa;vLLM: EplbState (PR #18343)&#xa;  --enable-eplb&#xa;  --eplb-config &#39;{&quot;step_interval&quot;:3000,&quot;num_redundant_experts&quot;:32}&#39;&#xa;&#xa;DeepSeek: 自家 EPLB repo&#xa;  github.com/deepseek-ai/EPLB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="690" y="510" width="500" height="280" as="geometry" />
        </mxCell>
        <mxCell id="p16-note" value="教程关联&#xa;━━━━━━━&#xa;§8 EPLB 详解&#xa;Lab 8 hot expert + EPLB&#xa;§18 CUDA Graph 兼容&#xa;&#xa;关键洞察:&#xa;不均衡是 time-varying&#xa;→ 静态 routing 解决不了&#xa;→ 必须 online rebalance&#xa;&#xa;Triton-distributed 适配:&#xa;expert→slot 映射放 symmetric tensor&#xa;routing kernel 内 lookup&#xa;weight transfer 走 NCCL P2P" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1220" y="510" width="320" height="280" as="geometry" />
        </mxCell>
        <mxCell id="p16-arrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=3;endArrow=classic;strokeColor=#9673a6;" parent="1" source="p16-before" target="p16-arrow" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p16-arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=3;endArrow=classic;strokeColor=#9673a6;" parent="1" source="p16-arrow" target="p16-after" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page17-deepep-modes" name="17 DeepEP normal/LL 时序">
    <mxGraphModel dx="1774" dy="1141" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p17-title" value="DeepEP 双模式时序对比：Normal (HT, prefill) vs Low-Latency (LL, decode)&#xa;两段式 NVLink+RDMA  vs  纯 RDMA + IBGDA + Hook (0 SM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=18;" parent="1" vertex="1">
          <mxGeometry x="60" y="30" width="1480" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p17-normal-title" value="Normal (HT) 模式 — Prefill / Training&#xa;Buffer.set_num_sms(20)，~20 SM 驱动 NVLink+RDMA，单大 kernel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="60" y="140" width="700" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p17-normal" value="                Node A (8 GPUs)               Node B (8 GPUs)&#xa;┌────────────────────────────────┐  ┌────────────────────────────────┐&#xa;│ GPU0  ──NVLink──&gt; GPU{1..7}    │  │ GPU8  ──NVLink──&gt; GPU{9..15}   │&#xa;│   │                            │  │   ▲                            │&#xa;│   │  RDMA NVSHMEM PUT+SIGNAL   │  │   │  RDMA NVSHMEM PUT+SIGNAL   │&#xa;│   └────────────────────────────┼─►│   │                            │&#xa;│                                │ CX-7 400Gb                       │&#xa;└────────────────────────────────┘  └────────────────────────────────┘&#xa;&#xa;Stage 1: token 按目标节点 NVLink 聚合到 proxy GPU&#xa;Stage 2: proxy GPU NVSHMEM PUT 到远端 symmetric heap (1 次 RDMA / 节点对)&#xa;Stage 3: 远端 receiver NVLink 散发到本地 expert owner&#xa;&#xa;H800 + CX-7 实测:&#xa;  Intranode EP=8:  153 GB/s NVLink (吃满)&#xa;  Internode EP=32: 58 GB/s RDMA (超 CX-7 标称, 因双向叠加)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="60" y="200" width="700" height="380" as="geometry" />
        </mxCell>
        <mxCell id="p17-ll-title" value="Low-Latency 模式 — Decode&#xa;纯 RDMA + IBGDA + Hook，0 SM 占用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="800" y="140" width="740" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p17-ll" value="                t0       t1            t2            t3&#xa;                │        │             │             │&#xa;GPU SM:      [disp_k]──────────────►[expert_GEMM]───►[recv_hook]&#xa;                │                          │             │&#xa;NIC (IBGDA): [send WQE]──[RDMA WRITE]──[done signal]  │&#xa;                │                          │             │&#xa;peer:                       ←──[recv]───[ack]            │&#xa;                                                       (hook 返回)&#xa;            ◄────── overlap window ──────►&#xa;            (RDMA 在背景, expert GEMM 全占 SM, 0 SM RDMA driving)&#xa;&#xa;关键 3 招:&#xa;  1. 纯 RDMA (跳过 NVLink 中转)&#xa;  2. IBGDA: GPU thread 直接构造 IB WQE + ring NIC doorbell&#xa;  3. Hook 模式: dispatch/combine 返回 callable&#xa;     RDMA 在背景, expert GEMM 用全 SM, 用户后调 hook() poll&#xa;&#xa;H800 实测 (128 tokens/batch):&#xa;  EP=8  dispatch 77 µs, combine 114 µs&#xa;  EP=32 dispatch 155 µs, combine 273 µs&#xa;  EP=256 dispatch 194 µs, combine 360 µs&#xa;&#xa;CUDA Graph 兼容: ✓ (padded buffer, fixed shape)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="800" y="200" width="740" height="380" as="geometry" />
        </mxCell>
        <mxCell id="p17-compare" value="对比表（DeepEP normal vs LL vs Pplx vs NCCL EP）&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;维度              | DeepEP normal      | DeepEP LL          | Pplx-kernels        | NCCL EP (LSA+GIN)&#xa;Buffer            | NVSHMEM symm       | NVSHMEM symm       | NVSHMEM symm        | NCCL window (LSA)&#xa;Signal            | NVSHMEM signal     | IB atomics (WQE)   | NVSHMEM signal      | ncclSignalSet&#xa;SM 占用           | 高 (~20 SM)        | 0 (hook)           | 中                  | 0 (LSA + GIN)&#xa;Scope             | 单 + 多节点         | 多节点 (含节点内 IB) | 单 + 多节点         | 任意&#xa;Kernel count      | 2 (大 kernel)      | 2 (大 kernel)      | 多个 split          | 1 大 kernel&#xa;CUDA Graph        | ✗                  | ✓                  | ✓                   | ✓ (设计目标)&#xa;Runtime 依赖      | NVSHMEM            | NVSHMEM + IBGDA    | NVSHMEM             | 无 (NCCL 已存在)&#xa;生产成熟度        | 高 (DeepSeek 自家) | 高 (SGLang LL)     | 高 (vLLM 单节点)    | beta (TRT-LLM 先行)&#xa;数据类型          | BF16/FP8           | BF16/FP8 (默认)    | BF16/FP8            | BF16/FP8/NVFP4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="60" y="610" width="1480" height="270" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page18-pd-disagg" name="18 PD 分离 + EP 数据流">
    <mxGraphModel dx="1774" dy="1141" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p18-title" value="PD 分离 + EP：Prefill 用 HT 模式 + Decode 用 LL 模式 + KV 通过 RDMA 转移&#xa;SGLang 96×H100 实测：合并 4.3k tok/s/node → 分离 22.3k tok/s/node (5.2×)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=18;" parent="1" vertex="1">
          <mxGeometry x="60" y="30" width="1480" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p18-client" value="Client&#xa;━━━━━&#xa;HTTP / gRPC&#xa;requests" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="100" y="170" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p18-lb" value="Mini Load Balancer&#xa;━━━━━━━━━━━━&#xa;sglang.srt.disaggregation.mini_lb&#xa;─ 新 prompt → 选最闲 prefill&#xa;─ prefill 完成 → 路由 KV → 选 decode&#xa;─ 续接 decode 请求 → 已有 KV 节点" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="280" y="160" width="350" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p18-prefill1" value="Prefill Node #1&#xa;━━━━━━━━━━━&#xa;HT mode (DeepEP normal)&#xa;EP=32&#xa;TP=32 + DP=32&#xa;moe-dense-tp-size=1&#xa;chunked-prefill-size=524288&#xa;disable-radix-cache&#xa;TBO 启用&#xa;&#xa;输出: KV pages (MLA latent)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="80" y="320" width="250" height="220" as="geometry" />
        </mxCell>
        <mxCell id="p18-prefill2" value="Prefill Node #2&#xa;━━━━━━━━━━━&#xa;HT mode (DeepEP normal)&#xa;EP=32&#xa;同上配置" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="80" y="570" width="250" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p18-kvtransfer" value="KV Transfer Layer&#xa;━━━━━━━━━━━━━━━&#xa;Mooncake / NIXL / Dynamo&#xa;over GPUDirect RDMA&#xa;&#xa;关键设计:&#xa;✓ Pull-based (decode 主动 READ)&#xa;✓ Object store 抽象&#xa;✓ Staging buffer (TP 不同时 2-5×)&#xa;✓ MR cache 复用 (避免重 register)&#xa;&#xa;CLI (SGLang):&#xa;--disaggregation-transfer-backend mooncake&#xa;--disaggregation-ib-device mlx5_1&#xa;SGLANG_MOONCAKE_CUSTOM_MEM_POOL=NVLINK&#xa;SGLANG_DISAGG_STAGING_BUFFER=1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="430" y="370" width="380" height="320" as="geometry" />
        </mxCell>
        <mxCell id="p18-decode1" value="Decode Node #1&#xa;━━━━━━━━━━━&#xa;LL mode (DeepEP LL + IBGDA)&#xa;EP=72&#xa;TP=72 + DP=72&#xa;cuda-graph-bs 128&#xa;mem-fraction-static 0.835&#xa;max-running-requests 18432&#xa;SGLANG_DEEPEP_NUM_MAX_DISPATCH&#xa;_TOKENS_PER_RANK=512" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="900" y="320" width="280" height="220" as="geometry" />
        </mxCell>
        <mxCell id="p18-decode2" value="Decode Node #2-9&#xa;━━━━━━━━━━━━&#xa;LL mode 同上&#xa;9 节点 = 72 GPU = EP=72" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="900" y="570" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p18-numbers" value="为什么需要分离&#xa;━━━━━━━━━━━&#xa;Prefill / Decode 矛盾:&#xa;• 计算: compute-bound vs memory-bound&#xa;• Batch: 长×少 vs 短×多&#xa;• A2A: 大 message HT vs 小 message LL&#xa;• SLO: TTFT vs ITL&#xa;• EP 后端: deepep_HT vs deepep_LL&#xa;• CUDA Graph: 可选 vs 必须&#xa;&#xa;混部三大灾难:&#xa;1. Prefill 阻塞 Decode → ITL 飙升&#xa;2. EP 后端无法兼容&#xa;3. 资源利用率失衡&#xa;&#xa;LMSYS 96×H100 实测:&#xa;TTFT P99: 4s → 1.2s&#xa;ITL P99: 80ms → 30ms&#xa;throughput: 4.3k → 22.3k tok/s/node" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1240" y="160" width="300" height="380" as="geometry" />
        </mxCell>
        <mxCell id="p18-note" value="教程关联&#xa;━━━━━━━&#xa;§14 PD 分离详解&#xa;§7.7 SGLang 配方&#xa;§10/11 HT/LL 通信&#xa;§13 Registered buffer&#xa;&#xa;参考:&#xa;Mooncake paper (2407.00079)&#xa;LMSYS large-scale EP&#xa;NVIDIA Dynamo docs" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1240" y="570" width="300" height="220" as="geometry" />
        </mxCell>
        <mxCell id="p18-arr1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeWidth=2;" parent="1" source="p18-client" target="p18-lb" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p18-arr2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeWidth=2;" parent="1" source="p18-lb" target="p18-prefill1" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p18-arr3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeWidth=2;" parent="1" source="p18-lb" target="p18-prefill2" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p18-arr4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeWidth=3;strokeColor=#9673a6;" parent="1" source="p18-prefill1" target="p18-kvtransfer" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p18-arr5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeWidth=3;strokeColor=#9673a6;" parent="1" source="p18-prefill2" target="p18-kvtransfer" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p18-arr6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeWidth=3;strokeColor=#9673a6;" parent="1" source="p18-kvtransfer" target="p18-decode1" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p18-arr7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeWidth=3;strokeColor=#9673a6;" parent="1" source="p18-kvtransfer" target="p18-decode2" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page19-wide-ep-nvl72" name="19 Wide-EP NVL72 rack-scale">
    <mxGraphModel dx="1774" dy="1141" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p19-title" value="Wide-EP on GB200 NVL72：72 GPU 当一个 EP 域，全 NVLink 0 RDMA&#xa;TRT-LLM 实测 EP=32 vs EP=8 → 1.8× per-GPU；SGLang GB200 vs H100 → 4.8× decode" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=18;" parent="1" vertex="1">
          <mxGeometry x="60" y="30" width="1480" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p19-rack" value="GB200 NVL72 物理结构&#xa;━━━━━━━━━━━━━━━━━━━&#xa;1 rack = 18 compute trays × 4 GPU = 72 GPU&#xa;       + 9 NVSwitch trays&#xa;       + 18 (Grace + 4 GPU) compute&#xa;       = 18 Grace CPU + 72 Blackwell GPU&#xa;&#xa;每 GPU 18 NVLink5 链路 → NVSwitch&#xa;任意 GPU pair 带宽: 1.8 TB/s 单向&#xa;跨 tray 延迟: ~150 ns (vs 节点内 ~50 ns)&#xa;总聚合带宽: 130 TB/s&#xa;&#xa;前置:&#xa;• /dev/nvidia-caps-imex-channels 挂载&#xa;• 72 GPU IMEX domain 配好&#xa;• NCCL ≥ 2.28&#xa;• CUDA 12.8+/13.x&#xa;• NVL72 fabric manager 启动" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="60" y="160" width="500" height="320" as="geometry" />
        </mxCell>
        <mxCell id="p19-flow" value="Wide-EP 单层 forward (EP=72)&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;┌─ rank 0 ──┐  ┌─ rank 1 ──┐  ...  ┌─ rank 71 ─┐&#xa;│ attn (TP) │  │ attn (TP) │       │ attn (TP) │&#xa;│  router   │  │  router   │       │  router   │&#xa;└─────┬─────┘  └─────┬─────┘       └─────┬─────┘&#xa;      ▼              ▼                   ▼&#xa;┌──── MNNVL all-to-all (dispatch) ───────────┐&#xa;│ moeCommKernels.h (PR #3504)                │&#xa;│   GroupSharedBuffer                         │&#xa;│   WARP_PER_GROUP / GROUP_COUNT_PER_BLOCK    │&#xa;│   动态 launch grid (按 EP 计算)             │&#xa;│   全 NVLink, 0 RDMA, kernel ld/st 远端 HBM  │&#xa;└─────────────────┬───────────────────────────┘&#xa;                  ▼&#xa;        GroupGEMM (NVFP4/FP8)&#xa;                  ▼&#xa;┌──── MNNVL all-to-all (combine) ────────────┐&#xa;│ hierarchical reduce: 同 tray 先聚合         │&#xa;│ 再跨 tray, NVSwitch SHARP in-network reduce │&#xa;└─────────────────┬───────────────────────────┘&#xa;                  ▼&#xa;          next layer attention" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="600" y="160" width="500" height="380" as="geometry" />
        </mxCell>
        <mxCell id="p19-eplb" value="WideEPMoE 关键抽象&#xa;━━━━━━━━━━━━━━━&#xa;logical experts ≠ physical slots&#xa;num_slots ≥ num_experts (e.g. 288 = 256+32)&#xa;&#xa;MoeLoadBalancer 持有:&#xa;  initial_global_assignments[layer][slot] → expert_id&#xa;  POSIX shm: TRTLLM_EPLB_SHM_NAME&#xa;&#xa;旋转 slot 不破坏 CUDA Graph (双 buffered)&#xa;&#xa;NCCL Device API 4 类 transport:&#xa;✓ LSA  - intra-NVL72 dispatch (P2P load/store)&#xa;✓ Multimem - combine reduce (NVSwitch SHARP)&#xa;✓ GIN  - 未来 rack 间&#xa;✓ CE   - prefill 大 message AllGather (~1.25× BW)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1140" y="160" width="400" height="380" as="geometry" />
        </mxCell>
        <mxCell id="p19-yaml" value="config_eplb.yaml (TRT-LLM LLM-API)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━&#xa;backend: pytorch&#xa;tensor_parallel_size: 32&#xa;moe_expert_parallel_size: 32&#xa;moe_config:&#xa;    backend: WIDEEP&#xa;    max_num_tokens: 9216&#xa;    load_balancer: ./moe_load_balancer.yaml&#xa;kv_cache_config:&#xa;    free_gpu_memory_fraction: 0.85&#xa;&#xa;moe_load_balancer.yaml (生成):&#xa;num_slots: 288&#xa;layer_updates_per_iter: 2     # 在线更新&#xa;initial_global_assignments:&#xa;  3:  [0, 1, ..., 255, 17, 42, ...]   # 288 entries&#xa;  ...&#xa;&#xa;EPLB 三步工作流:&#xa;1. trtllm-bench 收集 trace&#xa;2. python generate_eplb_config.py&#xa;3. trtllm-llmapi-launch trtllm-serve" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="60" y="510" width="540" height="370" as="geometry" />
        </mxCell>
        <mxCell id="p19-topo" value="NVL72 单 rack 部署拓扑选择&#xa;━━━━━━━━━━━━━━━━━━━━━&#xa;拓扑              | TP | EP | DP(attn) | 场景&#xa;Decode-optimized  | 1  | 32 | 32       | Disaggregated decode&#xa;Balanced          | 8  | 32 | 4        | 单实例 serving&#xa;Max scale         | 1  | 64 | 64       | 全 rack 大 EP&#xa;Disagg 全 rack    | 4 P / 48 D | 32/48 | mixed | LMSYS GB200 配方&#xa;&#xa;实测数字 (LMSYS GB200 Part II):&#xa;━━━━━━━━━━━━━━━━━━━━━━━━&#xa;配置: BF16 FP8 attn + NVFP4 MoE&#xa;Decode: 13,386 output tok/s/GPU&#xa;Prefill: 26,156 input tok/s/GPU&#xa;相对 H100: 3.8× prefill / 4.8× decode&#xa;&#xa;TRT-LLM tech blog #4 (DeepSeek-R1 EP=32):&#xa;hottest rank 偏差 +1.56× → +0.11× (有 EPLB)&#xa;EP=32 vs EP=8: 每 GPU 1.8× 吞吐&#xa;MNNVL kernel: 2.8× 单 GPU 吞吐 (无 staging)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="640" y="570" width="900" height="310" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page20-primitive-mapping" name="20 Primitive ↔ 通信库 Mapping">
    <mxGraphModel dx="1774" dy="1141" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p20-title" value="Triton-distributed Primitive ↔ NVSHMEM / NCCL Device API / DeepEP 映射&#xa;同一段 Python kernel 可以在不同 lowering 后端跑（路线 C 长期目标）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=18;" parent="1" vertex="1">
          <mxGeometry x="60" y="30" width="1480" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p20-mapping" value="Primitive 映射表（核心 6 + 扩展 4）&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Triton-distributed primitive | NVSHMEM 实现             | NCCL Device API           | DeepEP&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;dl.rank()                   | nvshmem_my_pe()         | ncclCommRank()           | group.rank()&#xa;dl.num_ranks()              | nvshmem_n_pes()         | ncclCommCount()          | group.size()&#xa;dl.symm_at(ptr, peer)        | nvshmem_ptr(ptr, pe)    | ncclGetLsaPointer(win,p) | (Buffer 内部)&#xa;dl.notify(sig, peer, val)    | nvshmemx_signal_op      | ncclSignalSet(win,p,v)   | IB native atomic&#xa;dl.wait(sig, val)            | inline PTX ld.acquire   | ncclSignalWait(win, val) | recv_hook() poll&#xa;dl.consume_token(value, t)   | (compiler 内部)          | (compiler 内部)           | (compiler 内部)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;put(remote, local, size)     | nvshmemx_putmem_nbi     | LSA st.global / GIN put  | (kernel 内部)&#xa;get(remote, local, size)     | nvshmemx_getmem_nbi     | LSA ld.global            | -&#xa;fence()                      | nvshmem_fence           | __threadfence_system()   | -&#xa;multimem_reduce(ptr, op)     | nvshmemx_alltoall_nbi   | ncclMultimemAddReduce    | (combine 内部)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="60" y="160" width="1480" height="380" as="geometry" />
        </mxCell>
        <mxCell id="p20-routeA" value="路线 A：外部 op 封装（v1 推荐）&#xa;━━━━━━━━━━━━━━━━━━━━━&#xa;✓ 改动面小&#xa;✓ 不碰 Triton MLIR lowering&#xa;✓ 快速对比 NVSHMEM vs DeepEP vs NCCL&#xa;&#xa;实现:&#xa;NCCL Device API dispatch/combine&#xa;包成 C++/Python op&#xa;Triton kernel 做 GroupGEMM/激活/reduce&#xa;dispatcher 可插拔" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="60" y="570" width="470" height="280" as="geometry" />
        </mxCell>
        <mxCell id="p20-routeB" value="路线 B：Runtime bridge（v2）&#xa;━━━━━━━━━━━━━━━━━━━━━&#xa;✓ 保留 Triton kernel 内 fusion&#xa;✓ 渐进替换 SHMEM primitive&#xa;⚠ ABI / linker 细节&#xa;⚠ module init / window lifetime&#xa;&#xa;实现:&#xa;triton_dist.jit post-compile 阶段&#xa;注入 ncclWindow_t / ncclComm_t&#xa;kernel 内 dl.extern_call(&quot;ncclGetLsaPointer&quot;,...)&#xa;DistributedOpToLLVM 加 NCCL 符号 lowering" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="555" y="570" width="470" height="280" as="geometry" />
        </mxCell>
        <mxCell id="p20-routeC" value="路线 C：Compiler-native 后端（长期）&#xa;━━━━━━━━━━━━━━━━━━━━━━━━&#xa;✓ kernel 源码不关心后端&#xa;✓ 编译器按 topo 自动选 NVSHMEM/NCCL&#xa;✓ API 统一&#xa;⚠ 改动最大&#xa;⚠ 需新 backend abstraction&#xa;⚠ 与 Triton 上游长期兼容&#xa;&#xa;实现:&#xa;distributed.symm_at → ncclGetLsaPointer&#xa;distributed.notify  → ncclSignalSet&#xa;distributed.wait    → ncclSignalWait&#xa;按 scope/semantic 在 lowering 时选后端" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1050" y="570" width="490" height="280" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page21-tbo-timeline" name="21 TBO/DBO Nsight 时间线">
    <mxGraphModel dx="1774" dy="1141" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p21-title" value="TBO / DBO 端到端 MoE forward Nsight 时间线视图&#xa;μB1 的 A2A 与 μB2 的 attention/GEMM 时间 overlap → SGLang +30% / vLLM +47%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=18;" parent="1" vertex="1">
          <mxGeometry x="60" y="30" width="1480" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p21-no-tbo-title" value="无 TBO（基线）— 单 batch 顺序" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="60" y="140" width="1480" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p21-no-tbo" value="时间轴: ───────────────────────────────────────────────────────────────────────────────────────►&#xa;&#xa;Layer i:&#xa;  attn ──► router ──► dispatch_A2A ──────► GEMM ──────► combine_A2A ──────► attn (Layer i+1)&#xa;  5ms     1ms        8ms                  12ms          8ms                   ...&#xa;&#xa;SM 占用:    100%  100%   ████ idle SM ████  100%        ████ idle SM ████&#xa;NIC 占用:                  100% (RDMA)                   100% (RDMA)&#xa;&#xa;问题: dispatch / combine 时 SM 大部分闲置 (IBGDA + Hook 后只有 NIC 在动)&#xa;&#xa;Wall time / layer = 5+1+8+12+8 = 34 ms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe4e1;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="60" y="190" width="1480" height="200" as="geometry" />
        </mxCell>
        <mxCell id="p21-tbo-title" value="开 TBO — 两 micro-batch 时间 overlap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="60" y="420" width="1480" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p21-tbo" value="时间轴: ───────────────────────────────────────────────────────────────────────────────────────►&#xa;&#xa;μB1: attn ──► router ──► disp ─────────► GEMM ──────► comb ──────► attn (next layer)&#xa;                                  ╲                            ╱&#xa;                                   ╲                          ╱&#xa;μB2:                                 attn ──► router ──► disp ──────► GEMM ──────► comb&#xa;                                          ◄──── overlap ────►&#xa;&#xa;SM 占用:  μB1.attn  μB1.GEMM  μB2.attn  μB2.GEMM       (始终高利用率)&#xa;NIC 占用:                  μB1.RDMA       μB2.RDMA       μB1.RDMA  μB2.RDMA&#xa;&#xa;关键:&#xa;✓ μB1.dispatch 与 μB2.attn 并行  ← 用 NIC + 用 SM 互不冲突&#xa;✓ μB1.combine  与 μB2.GEMM 并行  ← 用 NIC + 用 SM 互不冲突&#xa;✓ 两套 NVSHMEM signal buffer 区分两 micro-batch&#xa;✓ 内存峰值 ~1.5× (不是 2×)&#xa;✓ CUDA Graph 捕获两 micro-batch 的同一个交错路径&#xa;&#xa;Wall time / layer ≈ 5+12+8 = 25 ms (节省 ~30%)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="60" y="470" width="1480" height="320" as="geometry" />
        </mxCell>
        <mxCell id="p21-implementations" value="各框架实现&#xa;━━━━━━━━━━&#xa;• SGLang TBO:        --enable-two-batch-overlap          (V1 scheduler)&#xa;• vLLM DBO:           --enable-dbo --dbo-decode-token-threshold 32   (V1)&#xa;• Megatron delay-wgrad: --delay-wgrad-compute --overlap-moe-expert-parallel-comm (训练)&#xa;• DeepSeek-V3 DualPipe: 训练 fwd+bwd 双向 overlap, 4 micro-batch (~30% 气泡 → ~5%)&#xa;&#xa;实测收益:&#xa;SGLang TBO:  DeepSeek-V3 96×H100 prefill +30% 吞吐, 峰值显存 -50%&#xa;vLLM DBO:    H200 wide-EP sustained 1.5k → 2.2k tok/s/GPU (+47%)&#xa;DeepSeek-V3: 训练 step 利用率 70% → 95%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="60" y="820" width="1480" height="170" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page22-hybrid-ep-warps" name="22 Hybrid-EP 4 warp-group">
    <mxGraphModel dx="1774" dy="1141" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p22-title" value="Hybrid-EP 4 Warp-Group 内核分工：用 TMA 把 RDMA-driving SM 占用降到 ~4&#xa;DeepSeek-V3 +14% / Megatron-FSDP +8% / Qwen3-235B MXFP8 +9.9%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=18;" parent="1" vertex="1">
          <mxGeometry x="60" y="30" width="1480" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p22-block" value="1 CUDA Block (256 threads = 8 warps) 内部分工&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;&#xa;┌─────────────────────────────────────────────────────────────────────────┐&#xa;│  WG0 - G2S (2 warps, 64 threads)                                         │&#xa;│  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━     │&#xa;│  • 用 TMA 把 input[token_chunk] 异步搬到 shared mem FIFO                  │&#xa;│  • cp.async.bulk.tensor.* (Hopper TMA / Blackwell TMA5)                  │&#xa;│  • 0 占 register, 单 thread issue 全 warp 数据可见                       │&#xa;└─────────────────────────────────────────────────────────────────────────┘&#xa;&#xa;┌─────────────────────────────────────────────────────────────────────────┐&#xa;│  WG1 - RDMA (2 warps)                                                    │&#xa;│  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━     │&#xa;│  • 从 shared FIFO 读出 chunk                                              │&#xa;│  • IBGDA put 到对端节点 (device-side WQE + doorbell)                     │&#xa;│  • mbarrier 与 G2S 同步                                                   │&#xa;└─────────────────────────────────────────────────────────────────────────┘&#xa;&#xa;┌─────────────────────────────────────────────────────────────────────────┐&#xa;│  WG2 - NVLink (2 warps)                                                  │&#xa;│  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━     │&#xa;│  • 从 shared FIFO 读出 chunk (同节点 target)                              │&#xa;│  • st.global.NVLINK 直接写对端 HBM                                       │&#xa;│  • Multimem 或 LSA mode                                                  │&#xa;└─────────────────────────────────────────────────────────────────────────┘&#xa;&#xa;┌─────────────────────────────────────────────────────────────────────────┐&#xa;│  WG3 - Reduction (2 warps, combine 阶段)                                 │&#xa;│  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━     │&#xa;│  • 从 shared FIFO 读 partial sum                                          │&#xa;│  • SIMT BF16 add reduce                                                   │&#xa;│  • TMA store 到输出                                                       │&#xa;└─────────────────────────────────────────────────────────────────────────┘&#xa;&#xa;共享 Shared Memory FIFO（4 个 producer/consumer 解耦）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="60" y="160" width="900" height="600" as="geometry" />
        </mxCell>
        <mxCell id="p22-compare" value="SM 占用对比&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;实现        | NVLink 驱动 | RDMA 驱动 | 总占用 SM&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;NCCL alltoall | -          | host proxy + 8 SM spin | 8&#xa;DeepEP normal | 12 SM      | 8 SM      | 20&#xa;Hybrid-EP    | 2 SM (TMA) | 2 SM (RDMA WG) | 4&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;&#xa;B200 132 SM 总数下：&#xa;Hybrid-EP 把 12% 计算资源回收给 GroupedGEMM&#xa;&#xa;关键 enabler:&#xa;✓ TMA (cp.async.bulk.tensor.*)&#xa;  - 硬件异步内存搬运&#xa;  - 0 register 占用&#xa;  - Hopper/Blackwell 限定&#xa;✓ mbarrier&#xa;  - thread group 同步&#xa;  - 比 __syncthreads 灵活&#xa;✓ IBGDA (device-side WQE)&#xa;✓ NVLink5 P2P (st.global.NVLINK)&#xa;✓ Warp specialization&#xa;  - 不同 warp 跑不同代码路径&#xa;  - 编译器要 unroll 友好" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="990" y="160" width="550" height="430" as="geometry" />
        </mxCell>
        <mxCell id="p22-when" value="什么场景有效 / 何时反而有害&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;✓ Hopper / Blackwell（必须有 TMA）&#xa;✓ 大 batch prefill / 训练&#xa;✓ 跨节点 EP（IBGDA 路径成熟）&#xa;✗ Ampere / 早期硬件（无 TMA）&#xa;✗ 极小 batch decode（4 WG 调度本身有开销）&#xa;✗ 移植成本高，调试复杂&#xa;&#xa;Triton-distributed 实现:&#xa;Triton 当前 TMA 支持还不稳 (3.0+)&#xa;先用 Triton inline asm 调 cp.async.bulk&#xa;或用 little_kernel 写 CUDA 原型&#xa;&#xa;参考:&#xa;Hybrid-EP NVIDIA blog (2026-03)&#xa;DeepEP hybrid-ep 分支" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="990" y="610" width="550" height="220" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page23-cx7-arch" name="23 ConnectX-7 内部架构详解">
    <mxGraphModel dx="1774" dy="1141" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="cx7-title" value="Mellanox/NVIDIA ConnectX-7 (MT4129) 单卡内部架构详解&#xa;ASIC + PCIe + 双协议引擎 + RDMA 硬件加速 + 硬件原子操作" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=18;" parent="1" vertex="1">
          <mxGeometry x="40" y="30" width="1620" height="70" as="geometry" />
        </mxCell>

        <mxCell id="cx7-asic-frame" value="ConnectX-7 ASIC (MT4129)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5f5;strokeColor=#b85450;fontStyle=1;fontSize=14;verticalAlign=top;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="120" width="1080" height="640" as="geometry" />
        </mxCell>

        <mxCell id="cx7-pcie" value="PCIe Gen5 x16 接口&#xa;━━━━━━━━━━━━━━&#xa;• 32 GT/s × 16 lane = 64 GB/s 单向&#xa;• MMIO BAR0/1/2 暴露给 host&#xa;• AtomicOpsCap: 32+ / 64+ / 128CAS+&#xa;• ASPM not supported (AI 默认关)&#xa;• MSI-X interrupt vector pool" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="60" y="160" width="350" height="160" as="geometry" />
        </mxCell>

        <mxCell id="cx7-port" value="Network Port (1 端口型 / 多端口型)&#xa;━━━━━━━━━━━━━━━━━━&#xa;OSFP / QSFP-DD / QSFP112 物理接口&#xa;━━━━━━━━━━━━━━━━━━&#xa;支持的协议模式 (mlxconfig LINK_TYPE_P1):&#xa;• Ethernet: 200GbE / 400GbE (with 8 lane PAM4)&#xa;• InfiniBand: NDR 400Gb / NDR200 / HDR 200Gb / HDR100&#xa;• 同 ASIC 可双模式运行 (一端口 IB + 一端口 ETH)&#xa;━━━━━━━━━━━━━━━━━━&#xa;本节点配置:&#xa;• mlx5_0,5,8-13 (8 张) → Ethernet 400GbE (RoCE v2)&#xa;• mlx5_1-4 (1 张 4 端口) → InfiniBand HDR100 (2 lane HDR)&#xa;• mlx5_6-7 (1 张 2 端口, bond) → Ethernet 100GbE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="430" y="160" width="670" height="200" as="geometry" />
        </mxCell>

        <mxCell id="cx7-rdma" value="RDMA Engine (核心硬件)&#xa;━━━━━━━━━━━━━━━&#xa;• Queue Pair (QP) hardware mgmt&#xa;  - SQ (Send Queue), RQ (Receive Queue), CQ (Completion Queue)&#xa;  - up to 256K QPs per port&#xa;• Memory Region (MR) lookup engine&#xa;  - 注册过的 GPU/Host 内存 lkey/rkey 翻译&#xa;  - peermem 模块让 GPU HBM 也能注册成 MR&#xa;• Protection Domain (PD) hardware checks&#xa;• Completion event generation (interrupt 或 poll mode)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="60" y="340" width="500" height="180" as="geometry" />
        </mxCell>

        <mxCell id="cx7-doorbell" value="Doorbell Register (MMIO)&#xa;━━━━━━━━━━━━━━━━━&#xa;• 8 字节 MMIO 寄存器&#xa;• host CPU 或 GPU 写入 = 触发 NIC fetch WQE&#xa;• 不需要中断 / 系统调用&#xa;• ★ IBGDA 关键: 把 doorbell 映射到 GPU BAR1&#xa;  让 GPU thread 直接 st.global 戳 NIC&#xa;• 通过 cuMemImportFromShareableHandle 实现" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="580" y="380" width="520" height="140" as="geometry" />
        </mxCell>

        <mxCell id="cx7-misc" value="其他硬件 Block&#xa;━━━━━━━━━━━━&#xa;• Hardware FEC (Forward Error Correction) - 链路层纠错&#xa;• Congestion Control HW (DCQCN for RoCE)&#xa;• PFC (Priority Flow Control) HW state machine&#xa;• ECN marking engine&#xa;• Hardware Timestamp engine (PTP)&#xa;• ASAP² (offloaded virtual switch, OVS-DPDK)&#xa;• IPSec / TLS Crypto offload (per-QP)&#xa;• DPU split mode (CX-7 可作为 BlueField 模式运行)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="60" y="540" width="1040" height="200" as="geometry" />
        </mxCell>

        <mxCell id="cx7-numbers-frame" value="ConnectX-7 关键数据 / 规格" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=14;verticalAlign=top;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="1140" y="120" width="520" height="640" as="geometry" />
        </mxCell>

        <mxCell id="cx7-spec" value="型号 / 标识&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;PCIe DeviceID    : 1021 (MT4129)&#xa;Linux device     : mlx5_*&#xa;FW (本节点)      : 28.43.2026 (RoCE 卡)&#xa;                   28.45.1020 (IB 卡)&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;物理规格&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;PCIe             : Gen5 x16 (32 GT/s × 16)&#xa;Form factor      : OCP3.0 / PCIe HHHL&#xa;Max BW (PCIe)    : 64 GB/s 单向&#xa;Max BW (Network) : 400 Gb/s = 50 GB/s 单向&#xa;TDP              : ~25 W&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;协议能力&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;Ethernet         : 1/10/25/40/50/100/200/400 GbE&#xa;InfiniBand       : SDR/DDR/QDR/FDR/EDR/HDR/NDR&#xa;RoCE             : v1 / v2&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;RDMA 能力&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;Verbs            : Send/Recv, RDMA Write/Read,&#xa;                   Atomic FetchAdd, CAS&#xa;Max QP           : 256K per port&#xa;Max MR           : 16M&#xa;Max in-flight WR : 65K per QP&#xa;Atomic           : 32-bit, 64-bit, 128-bit CAS ✓&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;高级特性&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;DCT (Dyn Conn)   : ✓ (类似 connection multiplex)&#xa;SR-IOV VFs       : up to 1024&#xa;ASAP²            : OVS / OpenFlow offload&#xa;TLS / IPSec      : crypto offload&#xa;Programmable     : Programmable Congestion Control" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="1160" y="160" width="490" height="580" as="geometry" />
        </mxCell>

        <mxCell id="cx7-flow-title" value="一次 GPUDirect RDMA WRITE 的完整路径 (传统 vs IBGDA)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=14;" parent="1" vertex="1">
          <mxGeometry x="40" y="780" width="1620" height="40" as="geometry" />
        </mxCell>

        <mxCell id="cx7-flow-trad" value="传统路径 (CPU proxy):&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;1. GPU kernel 把 payload 写到注册过的 GPU HBM (走 nvidia-peermem MR)&#xa;2. GPU kernel 通知 CPU proxy thread (写 host pinned mem flag)&#xa;3. CPU proxy spin/poll 看到任务, 调 ibv_post_send()&#xa;4. ibv_post_send: 在 NIC SQ 构造 WQE → MMIO 写 doorbell&#xa;5. NIC fetch WQE, 通过 PCIe DMA 直接读 GPU HBM (peermem)&#xa;6. NIC 发 RDMA WRITE 包 (RoCEv2 over Ethernet 或 IB)&#xa;7. CPU 解析 CQE 通知 GPU 完成 (反向同样开销)&#xa;⏱ 总延迟 ~7-10 μs (好), 可能 50+ μs (CPU 抢占)&#xa;⚠ CPU 必须参与, decode 小 message 时 CPU overhead 主导" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="40" y="830" width="800" height="240" as="geometry" />
        </mxCell>

        <mxCell id="cx7-flow-ibgda" value="IBGDA 路径 (GPU 直接戳):&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;1. NIC 的 SQ + Doorbell mmap 到 GPU BAR1 VA&#xa;   (init 时通过 cuMemImportFromShareableHandle 完成)&#xa;2. GPU thread 直接在 SQ 上构造 WQE:&#xa;   wqe.opcode = RDMA_WRITE&#xa;   wqe.raddr  = 远端地址&#xa;   wqe.lkey   = 本地 MR key&#xa;3. __threadfence_system() 保证 WQE 写完&#xa;4. GPU thread 通过 st.global 写 doorbell (PCIe MMIO)&#xa;5. NIC 立即 fetch WQE 发 RDMA WRITE&#xa;6. ★ CPU 完全没参与 ★ 没有 proxy thread&#xa;⏱ 总延迟 ~2-3 μs (vs 7-10 μs 传统快 3-5×)&#xa;✓ 不受 CPU 调度抖动影响&#xa;✓ DeepEP LL 模式 / NCCL GIN 都用这个" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="860" y="830" width="800" height="240" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page24-b200-arch" name="24 B200 GPU 内部架构详解">
    <mxGraphModel dx="1774" dy="1141" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="b200-title" value="NVIDIA B200 (Blackwell GB100) GPU 内部架构详解&#xa;132 SM + 18 NVLink + 8 HBM3e + Copy Engine + TMA + 5th-gen Tensor Core" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#666666;strokeColor=#333333;fontStyle=1;fontSize=18;fontColor=#FFFFFF;" parent="1" vertex="1">
          <mxGeometry x="40" y="30" width="1620" height="70" as="geometry" />
        </mxCell>

        <mxCell id="b200-die" value="B200 双 die 封装 (2 个 reticle-limit die 通过 10 TB/s C2C 互联, 在软件层面表现为 1 颗 GPU)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#666666;fontStyle=1;fontSize=13;verticalAlign=top;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="120" width="1620" height="640" as="geometry" />
        </mxCell>

        <mxCell id="b200-sm-frame" value="计算单元: 132 个 SM (Streaming Multiprocessor)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;verticalAlign=top;" parent="1" vertex="1">
          <mxGeometry x="60" y="160" width="780" height="290" as="geometry" />
        </mxCell>

        <mxCell id="b200-sm" value="单个 SM 内部&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;• 4 个 Processing Block, 每 block:&#xa;  - 16 INT32 + 16 FP32 + 16 FP64 cores&#xa;  - 1 Tensor Core (5th gen, 支持 FP4/FP6/FP8/BF16/FP16/TF32)&#xa;  - 1 SFU (Special Function Unit)&#xa;• Warp Scheduler × 4 (每 block 1 个)&#xa;• 共享: 256 KB Register File + 256 KB SMEM/L1$&#xa;• Tensor Memory Accelerator (TMA): 异步内存搬运&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;132 SM × 4 block × 16 FP32 = 8448 FP32 cores&#xa;BF16 tensor: 2250 TFLOPS&#xa;FP8  tensor: 4500 TFLOPS&#xa;NVFP4 tensor: 9000 TFLOPS (Blackwell 独有)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="80" y="200" width="430" height="240" as="geometry" />
        </mxCell>

        <mxCell id="b200-tma" value="TMA (Tensor Memory Accelerator)&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;Hopper+ 引入, Blackwell 增强&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;• 异步 GMEM↔SMEM 搬运硬件&#xa;• 单 thread issue, 整 warp 数据可见&#xa;• cp.async.bulk.tensor.* PTX 指令&#xa;• mbarrier 配合, 不阻塞 SM 计算&#xa;• 0 register 占用&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;在 §17 Hybrid-EP 4 warp-group 中:&#xa;G2S warp 用 TMA 把 input 搬到 SMEM&#xa;S2G warp 用 TMA 把 output 写回 GMEM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="530" y="200" width="290" height="240" as="geometry" />
        </mxCell>

        <mxCell id="b200-mem-frame" value="内存子系统" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=12;verticalAlign=top;" parent="1" vertex="1">
          <mxGeometry x="860" y="160" width="780" height="290" as="geometry" />
        </mxCell>

        <mxCell id="b200-hbm" value="HBM3e Memory&#xa;━━━━━━━━━━━━━━━━━&#xa;• 8 个 HBM3e 堆叠 (4 个 / die)&#xa;• 单 stack 容量 24 GB → 总 192 GB&#xa;• 实际可用 180 GB (留 ECC + spare)&#xa;• 每 stack 1024-bit 总线 @ 9.6 GT/s&#xa;• 单 stack BW = 1.2 TB/s&#xa;• 整 GPU BW = 8 × 1.2 = ★ 8 TB/s ★&#xa;━━━━━━━━━━━━━━━━━&#xa;ECC: SECDED + chipkill" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="880" y="200" width="380" height="240" as="geometry" />
        </mxCell>

        <mxCell id="b200-cache" value="L2 / L1 / Cache 层次&#xa;━━━━━━━━━━━━━━&#xa;• L2 Cache: ~60 MB (双 die 共享)&#xa;• L1 / SMEM: 256 KB / SM&#xa;• L1 BW: 多 TB/s 级别&#xa;• MMU + page walk engine&#xa;━━━━━━━━━━━━━━&#xa;C2C inter-die link:&#xa;• 10 TB/s coherent link&#xa;• 软件层面看作单 GPU&#xa;━━━━━━━━━━━━━━&#xa;CUDA VMM (cuMemMap):&#xa;支持跨 GPU P2P virtual addressing&#xa;LSA / NVSHMEM 的基础" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1280" y="200" width="350" height="240" as="geometry" />
        </mxCell>

        <mxCell id="b200-io-frame" value="I/O 子系统 (NVLink + PCIe + Copy Engine)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;verticalAlign=top;" parent="1" vertex="1">
          <mxGeometry x="60" y="465" width="1580" height="285" as="geometry" />
        </mxCell>

        <mxCell id="b200-nvlink" value="NVLink5 (18 ports)&#xa;━━━━━━━━━━━━━━━━━━&#xa;• 18 个独立 NVLink5 PHY&#xa;• 每 port: 8 lane × 100 Gbps PAM4&#xa;• 单 port payload BW: 53.125 GB/s 单向&#xa;• 整 GPU 聚合: 18 × 53.125 = 956 GB/s 单向&#xa;                双向 ~1.91 TB/s&#xa;━━━━━━━━━━━━━━━━━━&#xa;能力 (nvidia-smi nvlink -c):&#xa;• P2P load/store (LSA 基础)&#xa;• Access to system memory&#xa;• P2P atomics (32/64/128 CAS)&#xa;• 系统级 atomics&#xa;━━━━━━━━━━━━━━━━━━&#xa;HGX 节点内: 全 18 链路上 NVSwitch&#xa;NVL72: 18 链路通过 OSFP 出 tray 上 rack switch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="80" y="500" width="500" height="240" as="geometry" />
        </mxCell>

        <mxCell id="b200-pcie" value="PCIe Gen5 x16 接口&#xa;━━━━━━━━━━━━━━&#xa;• 32 GT/s × 16 lane&#xa;• 单向 64 GB/s, 双向 128 GB/s&#xa;• AtomicOpsCap: 32+/64+/128CAS-&#xa;• AtomicOpsCtl: ReqEn+&#xa;• ASPM not supported&#xa;━━━━━━━━━━━━━━&#xa;BAR0: register / config (~64 KB)&#xa;BAR1: HBM 部分 mapped (large)&#xa;BAR3: PCI legacy&#xa;━━━━━━━━━━━━━━&#xa;PIX 直连 ConnectX-7 NIC&#xa;通过 Broadcom PEX890xx switch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="600" y="500" width="370" height="240" as="geometry" />
        </mxCell>

        <mxCell id="b200-ce" value="Copy Engines (DMA 硬件)&#xa;━━━━━━━━━━━━━━━━━━━&#xa;• 6-8 个独立 DMA 引擎 (与 SM 并行)&#xa;• 每 CE 能并发跑一个 stream&#xa;• 不占 SM, 不占 register&#xa;• HBM↔HBM (节点内 NVLink P2P)&#xa;• HBM↔Host RAM (PCIe DMA)&#xa;• 用于:&#xa;  - cudaMemcpyAsync&#xa;  - NCCL CE collectives (AllGather/AllToAll)&#xa;  - Implicit prefetch&#xa;━━━━━━━━━━━━━━━━━━━&#xa;NCCL ncclAllGatherCE 走这里, 0 SM 占用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="990" y="500" width="640" height="240" as="geometry" />
        </mxCell>

        <mxCell id="b200-spec" value="B200 关键数据汇总&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Architecture: Blackwell (GB100), SM100, dual-die reticle&#xa;HBM:    180 GB HBM3e, 8 TB/s    | SM count: 132    | Tensor Cores: 5th gen (FP4/FP6/FP8/BF16/FP16/TF32)&#xa;Compute: BF16 2250 TFLOPS / FP8 4500 TFLOPS / NVFP4 9000 TFLOPS    | TDP: 1000 W&#xa;NVLink: 18 ports, 50 GB/s/port 单向 (实测 53.125), 整聚合 1.8 TB/s 双向    | PCIe: Gen5 x16, 64 GB/s 单向&#xa;Copy Engine: 6-8 个 DMA, 与 SM 独立    | TMA: 异步 GMEM↔SMEM, 0 register&#xa;支持 NCCL Device API (LSA/Multimem/GIN/CE), NVSHMEM, IBGDA, MNNVL (NVL72)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#16213e;fontColor=#FFEB3B;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="40" y="780" width="1620" height="200" as="geometry" />
        </mxCell>

        <mxCell id="b200-note" value="本节点实测 (nvidia-smi -q -i 0): VBIOS 97.00.C5.00.0E | Driver 580.105.08 | Persistence Mode Enabled | Power Limit 1000W&#xa;本节点 NVLink 错误计数 (nvidia-smi nvlink -e -i 0): Tx packets 3.45T, Tx bytes 490 TB, Errors 全 0, FEC bucket 3+ = 0 ✓ 健康" style="shape=note;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="40" y="1000" width="1620" height="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page25-nvswitch5-arch" name="25 NVSwitch5 内部架构详解">
    <mxGraphModel dx="1774" dy="1141" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="nvs-title" value="NVSwitch (5th gen) ASIC 内部架构详解&#xa;144 NVLink5 端口 + Crossbar + SHARP Reduction Engine + Multimem + IMEX" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=18;fontColor=#FFFFFF;" parent="1" vertex="1">
          <mxGeometry x="40" y="30" width="1620" height="70" as="geometry" />
        </mxCell>

        <mxCell id="nvs-asic-frame" value="NVSwitch5 ASIC (台积电 4NP, ~50 Tbit/s 总吞吐)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#9673a6;fontStyle=1;fontSize=14;verticalAlign=top;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="120" width="1620" height="700" as="geometry" />
        </mxCell>

        <mxCell id="nvs-ports" value="144 NVLink5 端口 (PHY)&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;• 每 port: 8 lane × 100 Gbps PAM4&#xa;• 单 port BW: 53.125 GB/s 单向 / 106 GB/s 双向&#xa;• 144 port × 53.125 GB/s = 7.65 TB/s 单 ASIC 单向&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;在 HGX B200 的接线 (每 NVSwitch):&#xa;• 8 GPU × 9 link = 72 port → GPU 侧&#xa;• 剩余 72 port → 不接 (单 HGX) 或上 OSFP (NVL72)&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;在 NVL72 rack 的接线:&#xa;• 9 NVSwitch tray × 2 ASIC = 18 NVSwitch5&#xa;• 总 18 × 144 = 2592 port&#xa;• 部分接 GPU, 部分跨 tray, 部分 OSFP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="60" y="160" width="500" height="280" as="geometry" />
        </mxCell>

        <mxCell id="nvs-crossbar" value="Internal Crossbar Switch&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;• Non-blocking 144 × 144 crossbar&#xa;• 任意 port → 任意 port 路由&#xa;• 单跳延迟 ~50-100 ns&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;路由策略:&#xa;• Static (启动时建路由表)&#xa;• 按目标 GPU id 哈希到 link&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;为什么 GPU 之间 18 link 等效:&#xa;crossbar 让发送方 GPU 的全部 18 link&#xa;能路由到任意单一接收方 GPU&#xa;→ 单对独占时拿满 18 link 的 956 GB/s&#xa;→ 这就是 nvidia-smi NV18 的真实含义" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="580" y="160" width="500" height="280" as="geometry" />
        </mxCell>

        <mxCell id="nvs-sharp" value="SHARP Reduction Engine (硬件加法器)&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;★ NVSwitch5 的杀手锏 ★&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;• ASIC 内置 reduction engine&#xa;• 收到多 port 写同一 multimem 地址时:&#xa;  - 在 switch ASIC 里直接做加法 (BF16/FP16/FP32/int)&#xa;  - 也支持 min / max / and / or / xor&#xa;  - 不支持 mul / div (非交换律)&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;Multicast Engine:&#xa;• 一次 store 可同时发到 N 个 receiver&#xa;• combine 阶段一次 read 给所有 rank&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;NCCL Multimem / NVLS 算法的硬件基础&#xa;实测: NVL72 BF16 64MB AllReduce&#xa;Ring 450 GB/s → NVLS 900 GB/s (~2× 提升)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1100" y="160" width="540" height="280" as="geometry" />
        </mxCell>

        <mxCell id="nvs-imex" value="IMEX (Internal Memory Export) Channels&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;NVL72 跨 tray P2P 的关键 (单 HGX 不需要)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;• /dev/nvidia-caps-imex-channels 暴露给 host&#xa;• NVSwitch5 之间通过 IMEX channel 协议互联&#xa;• 让 tray A 的 GPU 能 P2P-map tray B 的 GPU HBM&#xa;• 这是 MNNVL (Multi-Node NVLink) 的硬件基础&#xa;• 跨 tray 延迟 ~150 ns (vs 同 tray ~50 ns)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;在 NVL72 rack 配置:&#xa;• 每 NVSwitch tray 含 2 颗 NVSwitch5 + IMEX 控制器&#xa;• 9 tray 通过铜缆互联组成 rack-scale fabric&#xa;• 最终 72 GPU 互相 P2P-mappable, 像一台 NUMA 机器&#xa;• 这就是 TRT-LLM Wide-EP / SGLang GB200 部署的硬件前提" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="60" y="460" width="780" height="340" as="geometry" />
        </mxCell>

        <mxCell id="nvs-config" value="NVSwitch 在不同硬件平台的配置&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;HGX H100 (Hopper):&#xa;• 4 颗 NVSwitch3 (3rd gen)&#xa;• 8 GPU × 18 link, 单向 ~900 GB/s/GPU&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;HGX H200:&#xa;• 同 H100 拓扑, NVSwitch3&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;HGX B200:  (本节点)&#xa;• 2 颗 NVSwitch5 (5th gen)&#xa;• 8 GPU × 18 link, 单向 ~956 GB/s/GPU&#xa;• 无 IMEX (单节点用不到)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;GB200 NVL72:  (rack-scale)&#xa;• 9 tray × 2 = 18 颗 NVSwitch5&#xa;• 72 GPU, 整 rack ~130 TB/s 总聚合&#xa;• IMEX channel 启用, 跨 tray P2P&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;GB300 NVL72: (next gen)&#xa;• NVSwitch5 增强&#xa;• Blackwell Ultra GPU (B300, FP4 性能更高)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="860" y="460" width="780" height="340" as="geometry" />
        </mxCell>

        <mxCell id="nvs-ascii" value="NVSwitch5 在 HGX B200 baseboard 上的实际接线 (本节点)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;          GPU0(18 link) ─┐         ┌─ GPU0(18 link)&#xa;          GPU1(18 link) ─┤  9 each ├─ GPU1(18 link)&#xa;          GPU2(18 link) ─┤  to     ├─ GPU2(18 link)&#xa;          GPU3(18 link) ─┤  each   ├─ GPU3(18 link)&#xa;          GPU4(18 link) ─┼─ Sw A ──├─ GPU4(18 link) ─ Sw B&#xa;          GPU5(18 link) ─┤         ├─ GPU5(18 link)&#xa;          GPU6(18 link) ─┤  72     ├─ GPU6(18 link)&#xa;          GPU7(18 link) ─┘  port   └─ GPU7(18 link)&#xa;                            used      72 port used&#xa;          ┌─────────────────────────────────────────────┐&#xa;          │ NVSwitch_A (NVS5)    │ NVSwitch_B (NVS5)    │  144 port 全部用完, 共 144 物理线&#xa;          │ 144 port total       │ 144 port total       │  72 + 72 接 GPU&#xa;          │ 72 used / 72 free    │ 72 used / 72 free    │  72 free 留给 NVL72 扩展 (本节点不接)&#xa;          └─────────────────────────────────────────────┘" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#16213e;fontColor=#FFEB3B;fontSize=10;align=left;spacingLeft=10;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="40" y="830" width="1620" height="240" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page26-sharp-multimem" name="26 NVSwitch SHARP Multimem Reduce">
    <mxGraphModel dx="900" dy="780" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="780" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Multimem / NVSwitch SHARP — in-network BF16 reduce" style="text;html=1;align=center;fontSize=18;fontStyle=1;fontColor=#1f3a6f" vertex="1" parent="1">
          <mxGeometry x="100" y="0" width="630" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="gpu_top_0" value="GPU 0&#10;partial_0&#10;store mm_addr" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4e5ff;strokeColor=#4a6fd3;fontSize=13;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="50" y="40" width="160" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="gpu_top_1" value="GPU 1&#10;partial_1&#10;store mm_addr" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4e5ff;strokeColor=#4a6fd3;fontSize=13;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="230" y="40" width="160" height="80" as="geometry"/>
        </mxCell>
