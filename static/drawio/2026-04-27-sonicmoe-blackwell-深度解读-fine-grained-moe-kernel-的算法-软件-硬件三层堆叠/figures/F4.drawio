        <mxCell id="d_9" value="&lt;b&gt;Raw FP32 score&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-family:Menlo;font-size:14px&quot;&gt;sign | exponent | mantissa&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;strokeWidth=1.5;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=15;" vertex="1" parent="1"><mxGeometry x="70" y="260" width="330" height="80" as="geometry"/></mxCell>
        <mxCell id="d_10" value="&lt;b&gt;Packed sortable key&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-family:Menlo;font-size:14px&quot;&gt;sign | exponent | higher mantissa | expert_id&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;strokeWidth=1.5;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=15;" vertex="1" parent="1"><mxGeometry x="470" y="260" width="420" height="80" as="geometry"/></mxCell>
        <mxCell id="d_11" value="&lt;b&gt;Why pack?&lt;/b&gt;&lt;br&gt;equal scores become ordered&lt;br&gt;argtopK follows score&lt;br&gt;no separate index traffic" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=16;" vertex="1" parent="1"><mxGeometry x="930" y="250" width="220" height="100" as="geometry"/></mxCell>
